{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["../../client/*"],
      "@lib/*": ["../../lib/*"],
      "@shared/*": ["../../shared/*"],
      "@assets/*": ["../../attached_assets/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "../../lib",
    "../../server",
    "../../client/components",
    "../../client/hooks",
    "../../client/utils",
    "../../client/App.tsx"
  ]
}
