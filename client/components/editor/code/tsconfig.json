{
  "extends": "../../../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../../../../",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["client/*"],
      "@lib/*": ["lib/*"],
      "@shared/*": ["shared/*"],
      "@assets/*": ["attached_assets/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "exclude": ["node_modules", "../../../../lib"]
}
