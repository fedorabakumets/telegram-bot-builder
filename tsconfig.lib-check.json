{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "outDir": "./dist/lib-check",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@shared/*": ["./shared/*"],
      "@client/*": ["./client/*"]
    }
  },
  "include": ["lib/**/*", "shared/**/*"],
  "exclude": ["node_modules", "dist", "lib/tests", "client/components", "client/pages", "client/hooks"]
}
