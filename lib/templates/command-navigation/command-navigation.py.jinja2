{#
  Шаблон навигации к узлу команды

  @fileoverview Генерирует Python-код для вызова обработчика команды
  через fake_message из callback-контекста.

  @param {string} commandName   — имя команды без '/' (например 'start', 'help')
  @param {string} handlerName   — имя функции-обработчика (например 'start_handler')
  @param {string} indentLevel   — базовый отступ (по умолчанию '    ')
#}

{% set ind = indentLevel or '    ' %}

{{ ind }}# Выполняем команду /{{ commandName }}
{{ ind }}fake_message = SimpleNamespace()
{{ ind }}fake_message.from_user = callback_query.from_user
{{ ind }}fake_message.chat = callback_query.message.chat
{{ ind }}fake_message.date = callback_query.message.date
{{ ind }}fake_message.answer = callback_query.message.answer
{{ ind }}await {{ handlerName }}(fake_message)
