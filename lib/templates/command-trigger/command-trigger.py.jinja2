{#
  Шаблон обработчиков командных триггеров

  @fileoverview Генерирует Python код для обработки командных триггеров (command_trigger узлов)
  @param {array} commandTriggerEntries - Массив объектов CommandTriggerEntry:
    - nodeId: string          — ID узла command_trigger
    - command: string         — команда, например "/start"
    - description: string     — описание команды
    - showInMenu: bool        — показывать в меню
    - targetNodeId: string    — ID целевого узла
    - targetNodeType: string  — тип целевого узла
    - isPrivateOnly: bool     — только приватные чаты
    - adminOnly: bool         — только администраторы (вызывает is_admin())
    - requiresAuth: bool      — требуется авторизация (вызывает check_auth())
    - messageText: string     — текст сообщения (опционально)
    - formatMode: string      — режим форматирования: 'html', 'markdown', 'none'
    - hasVariables: bool      — содержит ли текст переменные {var}
#}

# Обработчики командных триггеров
{% for entry in commandTriggerEntries -%}
{%- set sanitized_node_id = entry.nodeId | safe_name -%}
{%- set sanitized_target_id = entry.targetNodeId | safe_name -%}
{%- set cmd = entry.command | replace('/', '') -%}

@dp.message(Command("{{ cmd }}"))
async def command_trigger_{{ sanitized_node_id }}_handler(message: types.Message):
    # Командный триггер для узла {{ entry.nodeId }}, команда: {{ entry.command }}
    user_id = message.from_user.id
    logging.info(f"Пользователь {user_id} вызвал команду '{{ entry.command }}' — триггер узла {{ entry.nodeId }}")
    {%- if entry.isPrivateOnly %}
    if message.chat.type != 'private':
        await message.answer("❌ Эта команда доступна только в приватных чатах")
        return
    {%- endif %}
    {%- if entry.adminOnly %}
    if not await is_admin(user_id):
        await message.answer("❌ У вас нет прав для выполнения этой команды")
        return
    {%- endif %}
    {%- if entry.requiresAuth %}
    if not await check_auth(user_id):
        await message.answer("❌ Сначала запустите бота: /start")
        return
    {%- endif %}

    {%- if entry.messageText is defined and entry.messageText != '' %}
    # Сохранение информации о пользователе
    username = message.from_user.username
    first_name = message.from_user.first_name
    last_name = message.from_user.last_name
    if user_id not in user_data:
        user_data[user_id] = {}
    user_data[user_id]["username"] = username
    user_data[user_id]["first_name"] = first_name
    user_data[user_id]["last_name"] = last_name

    # Текст сообщения
    text = {{ entry.messageText | format_python_text }}

    {%- if entry.hasVariables %}
    # Замена переменных в тексте
    all_user_vars = await init_all_user_vars(user_id)
    text = replace_variables_in_text(text, all_user_vars, {})
    {%- endif %}

    {%- if entry.formatMode == 'html' %}
    await message.answer(text, parse_mode="HTML")
    {%- elif entry.formatMode == 'markdown' %}
    await message.answer(text, parse_mode="Markdown")
    {%- else %}
    await message.answer(text)
    {%- endif %}
    {%- else %}

    class MockCallback:
        def __init__(self, data, user, msg):
            self.data = data
            self.from_user = user
            self.message = msg

        async def answer(self):
            pass

        async def edit_text(self, text, **kwargs):
            try:
                return await self.message.edit_text(text, **kwargs)
            except Exception as e:
                logging.warning(f"Не удалось отредактировать сообщение: {e}")
                return await self.message.answer(text, **kwargs)

    mock_callback = MockCallback("{{ entry.targetNodeId }}", message.from_user, message)
    await handle_callback_{{ sanitized_target_id }}(mock_callback)
    {%- endif %}

{% endfor %}
