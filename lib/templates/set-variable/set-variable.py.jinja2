{#
  Шаблон узла set_variable — установка переменных пользователя

  @param {string} nodeId        — ID узла
  @param {array}  assignments   — список присваиваний [{id, variable, value, mode}]
  @param {string} autoTransitionTo — ID следующего узла (пустая строка если нет)
#}
{%- set safe_node_id = nodeId | safe_name -%}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ safe_node_id }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Узел set_variable: устанавливает переменные пользователя."""
    try:
        user_id = callback_query.from_user.id
        logging.info(f"📝 set_variable [{{ nodeId }}]: начало установки переменных для пользователя {user_id}")
        if user_id not in user_data:
            user_data[user_id] = {}
        {% for assignment in assignments %}
        {%- set safe_var = assignment.variable %}
        {%- if assignment.mode == 'expression' %}
        # Вычисляем арифметическое выражение
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_old_{{ loop.index }} = user_data[user_id].get("{{ safe_var }}")
        _sv_expr_{{ loop.index }} = {{ assignment.value | tojson }}
        user_data[user_id]["{{ safe_var }}"] = _eval_expr(_sv_expr_{{ loop.index }}, _sv_vars_{{ loop.index }})
        logging.info(f"📝 set_variable [{{ nodeId }}]: «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (было: {_sv_old_{{ loop.index }}!r}, выражение: {_sv_expr_{{ loop.index }}!r})")
        {%- elif assignment.mode == 'lookup' %}
        # Поиск в таблице {{ assignment.lookupTable }}
        {%- set outer_idx = loop.index %}
        _sv_vars_{{ outer_idx }} = await init_all_user_vars(user_id)
        _sv_old_{{ outer_idx }} = user_data[user_id].get("{{ safe_var }}")
        _sv_table_{{ outer_idx }} = _sv_vars_{{ outer_idx }}.get("table.{{ assignment.lookupTable }}", [])
        if isinstance(_sv_table_{{ outer_idx }}, str):
            try:
                import json as _json_lk
                _sv_table_{{ outer_idx }} = _json_lk.loads(_sv_table_{{ outer_idx }})
            except Exception:
                _sv_table_{{ outer_idx }} = []
        _sv_match_{{ outer_idx }} = None
        for _sv_row in (_sv_table_{{ outer_idx }} if isinstance(_sv_table_{{ outer_idx }}, list) else []):
            _sv_row_match = True
            {%- for cond in assignment.lookupWhere %}
            _sv_cond_val_{{ loop.index }}_{{ outer_idx }} = replace_variables_in_text({{ cond.value | tojson }}, _sv_vars_{{ outer_idx }})
            if str(_sv_row.get("{{ cond.field }}", "")) != str(_sv_cond_val_{{ loop.index }}_{{ outer_idx }}):
                _sv_row_match = False
            {%- endfor %}
            if _sv_row_match:
                _sv_match_{{ outer_idx }} = _sv_row
                break
        if _sv_match_{{ outer_idx }} is not None:
            user_data[user_id]["{{ safe_var }}"] = str(_sv_match_{{ outer_idx }}.get("{{ assignment.lookupField }}", ""))
        else:
            user_data[user_id]["{{ safe_var }}"] = ""
        logging.info(f"📝 set_variable [{{ nodeId }}]: lookup «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (таблица: {{ assignment.lookupTable }}, поле: {{ assignment.lookupField }})")
        {%- elif assignment.mode == 'str_replace' %}
        # Замена подстроки в переменной
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_old_{{ loop.index }} = str(user_data[user_id].get("{{ safe_var }}", ""))
        _sv_search_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_replace_{{ loop.index }} = replace_variables_in_text({{ assignment.replaceWith | tojson }}, _sv_vars_{{ loop.index }})
        user_data[user_id]["{{ safe_var }}"] = _sv_old_{{ loop.index }}.replace(_sv_search_{{ loop.index }}, _sv_replace_{{ loop.index }})
        logging.info(f"📝 set_variable [{{ nodeId }}]: str_replace «{{ safe_var }}» (искали: {_sv_search_{{ loop.index }}!r}, заменили на: {_sv_replace_{{ loop.index }}!r})")
        {%- else %}
        # Устанавливаем переменную через шаблон
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        {%- if '{' in assignment.variable %}
        _sv_varname_{{ loop.index }} = replace_variables_in_text({{ assignment.variable | tojson }}, _sv_vars_{{ loop.index }})
        {%- else %}
        _sv_varname_{{ loop.index }} = "{{ safe_var }}"
        {%- endif %}
        _sv_old_{{ loop.index }} = user_data[user_id].get(_sv_varname_{{ loop.index }})
        user_data[user_id][_sv_varname_{{ loop.index }}] = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        logging.info(f"📝 set_variable [{{ nodeId }}]: «{_sv_varname_{{ loop.index }}}» = {user_data[user_id][_sv_varname_{{ loop.index }}]!r} (было: {_sv_old_{{ loop.index }}!r})")
        {%- endif %}
        {% endfor %}
        logging.info(f"✅ set_variable [{{ nodeId }}]: установлено {{ assignments | length }} переменных для {user_id}")
        {% if autoTransitionTo %}
        {%- set safe_target = autoTransitionTo | safe_name %}
        logging.info(f"⚡ set_variable [{{ nodeId }}]: автопереход → {{ autoTransitionTo }} для {user_id}")
        # Автопереход к следующему узлу
        class FakeCallback:
            def __init__(self, data, user, msg):
                self.data = data
                self.from_user = user
                self.message = msg
                self._is_fake = True
            async def answer(self, *args, **kwargs):
                pass
        fake_cb = FakeCallback("{{ autoTransitionTo }}", callback_query.from_user, callback_query.message)
        await handle_callback_{{ safe_target }}(fake_cb, state=state)
        {% endif %}
    except Exception as e:
        logging.error(f"❌ Ошибка в set_variable [{{ nodeId }}]: {e}")
