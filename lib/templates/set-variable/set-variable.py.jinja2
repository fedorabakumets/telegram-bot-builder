{#
  Шаблон узла set_variable — установка переменных пользователя

  @param {string} nodeId        — ID узла
  @param {array}  assignments   — список присваиваний [{id, variable, value, mode}]
  @param {string} autoTransitionTo — ID следующего узла (пустая строка если нет)
#}
{%- set safe_node_id = nodeId | safe_name -%}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ safe_node_id }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Узел set_variable: устанавливает переменные пользователя."""
    try:
        user_id = callback_query.from_user.id
        logging.info(f"📝 set_variable [{{ nodeId }}]: начало установки переменных для пользователя {user_id}")
        if user_id not in user_data:
            user_data[user_id] = {}
        {% for assignment in assignments %}
        {%- set safe_var = assignment.variable %}
        {%- if assignment.mode == 'expression' %}
        # Вычисляем арифметическое выражение
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_old_{{ loop.index }} = user_data[user_id].get("{{ safe_var }}")
        _sv_expr_{{ loop.index }} = {{ assignment.value | tojson }}
        user_data[user_id]["{{ safe_var }}"] = _eval_expr(_sv_expr_{{ loop.index }}, _sv_vars_{{ loop.index }})
        logging.info(f"📝 set_variable [{{ nodeId }}]: «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (было: {_sv_old_{{ loop.index }}!r}, выражение: {_sv_expr_{{ loop.index }}!r})")
        {%- elif assignment.mode == 'lookup' %}
        # Поиск в таблице {{ assignment.lookupTable }}
        {%- set outer_idx = loop.index %}
        _sv_vars_{{ outer_idx }} = await init_all_user_vars(user_id)
        _sv_old_{{ outer_idx }} = user_data[user_id].get("{{ safe_var }}")
        _sv_table_{{ outer_idx }} = _sv_vars_{{ outer_idx }}.get("table.{{ assignment.lookupTable }}", [])
        if isinstance(_sv_table_{{ outer_idx }}, str):
            try:
                import json as _json_lk
                _sv_table_{{ outer_idx }} = _json_lk.loads(_sv_table_{{ outer_idx }})
            except Exception:
                _sv_table_{{ outer_idx }} = []
        _sv_match_{{ outer_idx }} = None
        for _sv_row in (_sv_table_{{ outer_idx }} if isinstance(_sv_table_{{ outer_idx }}, list) else []):
            _sv_row_match = True
            {%- for cond in assignment.lookupWhere %}
            _sv_cond_val_{{ loop.index }}_{{ outer_idx }} = replace_variables_in_text({{ cond.value | tojson }}, _sv_vars_{{ outer_idx }})
            if str(_sv_row.get("{{ cond.field }}", "")) != str(_sv_cond_val_{{ loop.index }}_{{ outer_idx }}):
                _sv_row_match = False
            {%- endfor %}
            if _sv_row_match:
                _sv_match_{{ outer_idx }} = _sv_row
                break
        if _sv_match_{{ outer_idx }} is not None:
            _sv_lookup_field_{{ outer_idx }} = replace_variables_in_text({{ assignment.lookupField | tojson }}, _sv_vars_{{ outer_idx }})
            user_data[user_id]["{{ safe_var }}"] = str(_sv_match_{{ outer_idx }}.get(_sv_lookup_field_{{ outer_idx }}, ""))
        else:
            _sv_lookup_field_{{ outer_idx }} = {{ assignment.lookupField | tojson }}
            user_data[user_id]["{{ safe_var }}"] = ""
        logging.info(f"📝 set_variable [{{ nodeId }}]: lookup «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (таблица: {{ assignment.lookupTable }}, поле: {_sv_lookup_field_{{ outer_idx }}})")
        {%- elif assignment.mode == 'str_replace' %}
        # Замена подстроки в переменной
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_old_{{ loop.index }} = str(user_data[user_id].get("{{ safe_var }}", ""))
        _sv_search_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_replace_{{ loop.index }} = replace_variables_in_text({{ assignment.replaceWith | tojson }}, _sv_vars_{{ loop.index }})
        user_data[user_id]["{{ safe_var }}"] = _sv_old_{{ loop.index }}.replace(_sv_search_{{ loop.index }}, _sv_replace_{{ loop.index }})
        logging.info(f"📝 set_variable [{{ nodeId }}]: str_replace «{{ safe_var }}» (искали: {_sv_search_{{ loop.index }}!r}, заменили на: {_sv_replace_{{ loop.index }}!r})")
        {%- elif assignment.mode == 'json_push' %}
        # Добавляем объект в массив-переменную (поддерживает ={{выражения}})
        import json as _json_lk
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_arr_{{ loop.index }} = user_data[user_id].get("{{ safe_var }}", [])
        if isinstance(_sv_arr_{{ loop.index }}, str):
            try:
                _sv_arr_{{ loop.index }} = _json_lk.loads(_sv_arr_{{ loop.index }})
            except Exception:
                _sv_arr_{{ loop.index }} = []
        if not isinstance(_sv_arr_{{ loop.index }}, list):
            _sv_arr_{{ loop.index }} = []
        _sv_push_tpl_{{ loop.index }} = {{ assignment.value | tojson }}
        _sv_push_str_{{ loop.index }} = replace_variables_in_text(_sv_push_tpl_{{ loop.index }}, _sv_vars_{{ loop.index }})
        # Обрабатываем inline-выражения (синтаксис: равно + двойные фигурные скобки)
        _sv_expr_vars_{{ loop.index }} = _sv_vars_{{ loop.index }}
        def _resolve_expr_{{ loop.index }}(_m):
            try:
                return str(_eval_expr(_m.group(1), _sv_expr_vars_{{ loop.index }}))
            except Exception:
                return "0"
        _sv_re_sub = getattr(__import__('re'), 'sub')
        _sv_push_str_{{ loop.index }} = _sv_re_sub({% raw %}r'=\{\{(.+?)\}\}'{% endraw %}, _resolve_expr_{{ loop.index }}, _sv_push_str_{{ loop.index }})
        try:
            _sv_push_obj_{{ loop.index }} = _json_lk.loads(_sv_push_str_{{ loop.index }})
        except Exception:
            _sv_push_obj_{{ loop.index }} = _sv_push_str_{{ loop.index }}
        _sv_arr_{{ loop.index }}.append(_sv_push_obj_{{ loop.index }})
        user_data[user_id]["{{ safe_var }}"] = _sv_arr_{{ loop.index }}
        logging.info(f"📝 set_variable [{{ nodeId }}]: json_push «{{ safe_var }}» (длина: {len(_sv_arr_{{ loop.index }})})")
        {%- elif assignment.mode == 'json_format' %}
        # Форматируем массив в строку с опциональной сортировкой
        import json as _json_lk
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_arr_{{ loop.index }} = user_data[user_id].get("{{ safe_var }}", [])
        if isinstance(_sv_arr_{{ loop.index }}, str):
            try:
                _sv_arr_{{ loop.index }} = _json_lk.loads(_sv_arr_{{ loop.index }})
            except Exception:
                _sv_arr_{{ loop.index }} = []
        if not isinstance(_sv_arr_{{ loop.index }}, list):
            _sv_arr_{{ loop.index }} = []
        {%- if assignment.lookupField %}
        # Сортировка по полю {{ assignment.lookupField }} (по убыванию)
        def _sv_sort_key_{{ loop.index }}(x):
            """Безопасный ключ сортировки: невалидные значения уходят в конец."""
            try:
                return float(x.get("{{ assignment.lookupField }}", 0) or 0)
            except (ValueError, TypeError):
                return -1
        try:
            _sv_arr_{{ loop.index }}.sort(key=_sv_sort_key_{{ loop.index }}, reverse=True)
        except Exception:
            pass
        {%- endif %}
        # Форматируем каждый элемент по шаблону (позиции: 🥇🥈🥉, остальные 🔸)
        _sv_tpl_{{ loop.index }} = {{ assignment.value | tojson }}
        _sv_result_{{ loop.index }} = ""
        _sv_pos_{{ loop.index }} = 0
        _sv_medals = ["🥇", "🥈", "🥉"]
        for _sv_item_{{ loop.index }} in _sv_arr_{{ loop.index }}:
            if isinstance(_sv_item_{{ loop.index }}, dict):
                # Пропускаем элементы с нулевым rate (только если поле rate явно задано)
                _sv_rate_val = _sv_item_{{ loop.index }}.get("rate")
                if _sv_rate_val is not None:
                    try:
                        if float(_sv_rate_val) <= 0:
                            continue
                    except (ValueError, TypeError):
                        pass
                # Форматируем числовые поля с разделителем тысяч
                for _nk in ("raw_rate",):
                    _nv = _sv_item_{{ loop.index }}.get(_nk, "")
                    try:
                        _sv_item_{{ loop.index }}[_nk] = f"{int(float(_nv)):,}".replace(",", " ")
                    except (ValueError, TypeError):
                        pass
            _sv_item_vars_{{ loop.index }} = dict(_sv_vars_{{ loop.index }})
            if isinstance(_sv_item_{{ loop.index }}, dict):
                for _ik, _iv in _sv_item_{{ loop.index }}.items():
                    _sv_item_vars_{{ loop.index }}[f"item.{_ik}"] = str(_iv) if _iv is not None else ""
            _sv_line_{{ loop.index }} = replace_variables_in_text(_sv_tpl_{{ loop.index }}, _sv_item_vars_{{ loop.index }})
            # Заменяем 🔸 на позиционный эмодзи
            _sv_medal = _sv_medals[_sv_pos_{{ loop.index }}] if _sv_pos_{{ loop.index }} < 3 else "🔸"
            _sv_line_{{ loop.index }} = _sv_line_{{ loop.index }}.replace("🔸", _sv_medal, 1)
            _sv_pos_{{ loop.index }} += 1
            _sv_result_{{ loop.index }} += _sv_line_{{ loop.index }}
        user_data[user_id]["{{ safe_var }}"] = _sv_result_{{ loop.index }}
        logging.info(f"📝 set_variable [{{ nodeId }}]: json_format «{{ safe_var }}» ({len(_sv_arr_{{ loop.index }})} элементов)")
        {%- elif assignment.mode == 'random' %}
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_min_{{ loop.index }} = int(float(replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})))
        _sv_max_{{ loop.index }} = int(float(replace_variables_in_text({{ assignment.maxValue | tojson }}, _sv_vars_{{ loop.index }})))
        import random as _random_mod
        user_data[user_id]["{{ safe_var }}"] = str(_random_mod.randint(_sv_min_{{ loop.index }}, _sv_max_{{ loop.index }}))
        logging.info(f"📝 set_variable [{{ nodeId }}]: random «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']} (диапазон {_sv_min_{{ loop.index }}}-{_sv_max_{{ loop.index }}})")
        {%- elif assignment.mode == 'random_item' %}
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_list_raw_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_items_{{ loop.index }} = [item.strip() for item in _sv_list_raw_{{ loop.index }}.split(",") if item.strip()]
        import random as _random_mod_ri
        if _sv_items_{{ loop.index }}:
            user_data[user_id]["{{ safe_var }}"] = _random_mod_ri.choice(_sv_items_{{ loop.index }})
        else:
            user_data[user_id]["{{ safe_var }}"] = ""
        logging.info(f"📝 set_variable [{{ nodeId }}]: random_item «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']} (из {len(_sv_items_{{ loop.index }})} элементов)")
        {%- elif assignment.mode == 'array_item' %}
        import json as _json_ai
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_source_raw_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_index_raw_{{ loop.index }} = replace_variables_in_text({{ assignment.maxValue | tojson }}, _sv_vars_{{ loop.index }})
        # Парсим источник (массив или объект)
        _sv_source_{{ loop.index }} = _sv_source_raw_{{ loop.index }}
        if isinstance(_sv_source_{{ loop.index }}, str):
            try:
                _sv_source_{{ loop.index }} = _json_ai.loads(_sv_source_{{ loop.index }})
            except Exception:
                pass
        # Извлекаем элемент по индексу/ключу (поддерживает dot-notation: "data.users.0.name")
        _sv_result_{{ loop.index }} = _sv_source_{{ loop.index }}
        for _seg in str(_sv_index_raw_{{ loop.index }}).split("."):
            if _sv_result_{{ loop.index }} is None:
                break
            if isinstance(_sv_result_{{ loop.index }}, (list, tuple)):
                try:
                    _sv_result_{{ loop.index }} = _sv_result_{{ loop.index }}[int(_seg)]
                except (IndexError, ValueError):
                    _sv_result_{{ loop.index }} = None
            elif isinstance(_sv_result_{{ loop.index }}, dict):
                _sv_result_{{ loop.index }} = _sv_result_{{ loop.index }}.get(_seg)
            else:
                _sv_result_{{ loop.index }} = None
        user_data[user_id]["{{ safe_var }}"] = str(_sv_result_{{ loop.index }}) if _sv_result_{{ loop.index }} is not None else ""
        logging.info(f"📝 set_variable [{{ nodeId }}]: array_item «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']} (индекс/ключ: {_sv_index_raw_{{ loop.index }}})")
        {%- elif assignment.mode == 'format_duration' %}
        # Форматирование секунд в MM:SS или HH:MM:SS
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_old_{{ loop.index }} = user_data[user_id].get("{{ safe_var }}")
        _sv_expr_{{ loop.index }} = {{ assignment.value | tojson }}
        _sv_seconds_{{ loop.index }} = int(float(_eval_expr(_sv_expr_{{ loop.index }}, _sv_vars_{{ loop.index }})))
        if _sv_seconds_{{ loop.index }} < 0:
            _sv_seconds_{{ loop.index }} = 0
        _sv_h_{{ loop.index }} = _sv_seconds_{{ loop.index }} // 3600
        _sv_m_{{ loop.index }} = (_sv_seconds_{{ loop.index }} % 3600) // 60
        _sv_s_{{ loop.index }} = _sv_seconds_{{ loop.index }} % 60
        if _sv_h_{{ loop.index }} > 0:
            user_data[user_id]["{{ safe_var }}"] = f"{_sv_h_{{ loop.index }}:02d}:{_sv_m_{{ loop.index }}:02d}:{_sv_s_{{ loop.index }}:02d}"
        else:
            user_data[user_id]["{{ safe_var }}"] = f"{_sv_m_{{ loop.index }}:02d}:{_sv_s_{{ loop.index }}:02d}"
        logging.info(f"📝 set_variable [{{ nodeId }}]: format_duration «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']} ({_sv_seconds_{{ loop.index }}}s)")
        {%- elif assignment.mode == 'format_number' %}
        # Форматирование числа с разделителями (пробелами): 5000000 → "5 000 000"
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_raw_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        try:
            _sv_num_{{ loop.index }} = int(float(_sv_raw_{{ loop.index }}))
            _sv_formatted_{{ loop.index }} = f"{_sv_num_{{ loop.index }}:,}".replace(",", " ")
        except (ValueError, TypeError):
            _sv_formatted_{{ loop.index }} = _sv_raw_{{ loop.index }}
        user_data[user_id]["{{ safe_var }}"] = _sv_formatted_{{ loop.index }}
        logging.info(f"📝 set_variable [{{ nodeId }}]: format_number «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']}")
        {%- elif assignment.mode == 'timestamp' %}
        import time as _time_mod_sv
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_offset_{{ loop.index }} = int(float(replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }}))) if {{ assignment.value | tojson }}.strip() else 0
        user_data[user_id]["{{ safe_var }}"] = str(int(_time_mod_sv.time()) + _sv_offset_{{ loop.index }})
        logging.info(f"📝 set_variable [{{ nodeId }}]: timestamp «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']} (offset={_sv_offset_{{ loop.index }}}s)")
        {%- elif assignment.mode == 'regex_extract' %}
        # Извлечение по регулярному выражению
        import re as _re_sv_{{ loop.index }}
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_source_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_pattern_{{ loop.index }} = replace_variables_in_text({{ assignment.pattern | default('') | tojson }}, _sv_vars_{{ loop.index }})
        _sv_group_{{ loop.index }} = {{ assignment.regexGroup | default('0') | tojson }}
        try:
            _sv_match_{{ loop.index }} = _re_sv_{{ loop.index }}.search(_sv_pattern_{{ loop.index }}, _sv_source_{{ loop.index }})
            if _sv_match_{{ loop.index }}:
                _sv_grp_idx_{{ loop.index }} = int(_sv_group_{{ loop.index }}) if _sv_group_{{ loop.index }}.isdigit() else 0
                user_data[user_id]["{{ safe_var }}"] = _sv_match_{{ loop.index }}.group(_sv_grp_idx_{{ loop.index }})
            else:
                user_data[user_id]["{{ safe_var }}"] = ""
        except Exception as _re_err_{{ loop.index }}:
            logging.warning(f"⚠️ regex_extract ошибка: {_re_err_{{ loop.index }}}")
            user_data[user_id]["{{ safe_var }}"] = ""
        logging.info(f"📝 set_variable [{{ nodeId }}]: regex_extract «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (pattern: {_sv_pattern_{{ loop.index }}!r})")
        {%- elif assignment.mode == 'extract_number' %}
        # Извлечение первого числа из строки
        import re as _re_en_{{ loop.index }}
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_source_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_match_{{ loop.index }} = _re_en_{{ loop.index }}.search(r'\d+', str(_sv_source_{{ loop.index }}))
        user_data[user_id]["{{ safe_var }}"] = _sv_match_{{ loop.index }}.group() if _sv_match_{{ loop.index }} else "0"
        logging.info(f"📝 set_variable [{{ nodeId }}]: extract_number «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r}")
        {%- elif assignment.mode == 'split_get' %}
        # Разделить строку и взять N-й элемент
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_source_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_sep_{{ loop.index }} = {{ assignment.separator | default(' ') | tojson }}
        _sv_idx_raw_{{ loop.index }} = replace_variables_in_text({{ assignment.maxValue | default('0') | tojson }}, _sv_vars_{{ loop.index }})
        _sv_idx_{{ loop.index }} = int(_sv_idx_raw_{{ loop.index }}) if _sv_idx_raw_{{ loop.index }}.lstrip('-').isdigit() else 0
        _sv_parts_{{ loop.index }} = _sv_source_{{ loop.index }}.split(_sv_sep_{{ loop.index }})
        if abs(_sv_idx_{{ loop.index }}) < len(_sv_parts_{{ loop.index }}):
            user_data[user_id]["{{ safe_var }}"] = _sv_parts_{{ loop.index }}[_sv_idx_{{ loop.index }}].strip()
        else:
            user_data[user_id]["{{ safe_var }}"] = ""
        logging.info(f"📝 set_variable [{{ nodeId }}]: split_get «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (sep={_sv_sep_{{ loop.index }}!r}, idx={_sv_idx_{{ loop.index }}})") 
        {%- elif assignment.mode == 'json_get' %}
        # Извлечение значения из JSON по пути (dot notation)
        import json as _json_jg_{{ loop.index }}
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_source_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_path_{{ loop.index }} = replace_variables_in_text({{ assignment.jsonPath | default('') | tojson }}, _sv_vars_{{ loop.index }})
        try:
            _sv_obj_{{ loop.index }} = _json_jg_{{ loop.index }}.loads(_sv_source_{{ loop.index }}) if isinstance(_sv_source_{{ loop.index }}, str) else _sv_source_{{ loop.index }}
            _sv_val_{{ loop.index }} = _sv_obj_{{ loop.index }}
            for _seg in _sv_path_{{ loop.index }}.split("."):
                if not _seg:
                    continue
                if isinstance(_sv_val_{{ loop.index }}, list) and _seg.isdigit():
                    _sv_val_{{ loop.index }} = _sv_val_{{ loop.index }}[int(_seg)]
                elif isinstance(_sv_val_{{ loop.index }}, dict):
                    _sv_val_{{ loop.index }} = _sv_val_{{ loop.index }}.get(_seg, "")
                else:
                    _sv_val_{{ loop.index }} = ""
                    break
            user_data[user_id]["{{ safe_var }}"] = str(_sv_val_{{ loop.index }}) if _sv_val_{{ loop.index }} is not None else ""
        except Exception:
            user_data[user_id]["{{ safe_var }}"] = ""
        logging.info(f"📝 set_variable [{{ nodeId }}]: json_get «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (path: {_sv_path_{{ loop.index }}})") 
        {%- elif assignment.mode == 'substring' %}
        # Подстрока (start, end)
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_source_{{ loop.index }} = replace_variables_in_text({{ assignment.value | tojson }}, _sv_vars_{{ loop.index }})
        _sv_start_{{ loop.index }} = int(replace_variables_in_text({{ assignment.startIndex | default('0') | tojson }}, _sv_vars_{{ loop.index }})) if {{ assignment.startIndex | default('0') | tojson }}.strip() else 0
        _sv_end_raw_{{ loop.index }} = {{ assignment.endIndex | default('') | tojson }}.strip()
        _sv_end_{{ loop.index }} = int(replace_variables_in_text(_sv_end_raw_{{ loop.index }}, _sv_vars_{{ loop.index }})) if _sv_end_raw_{{ loop.index }} else None
        user_data[user_id]["{{ safe_var }}"] = _sv_source_{{ loop.index }}[_sv_start_{{ loop.index }}:_sv_end_{{ loop.index }}]
        logging.info(f"📝 set_variable [{{ nodeId }}]: substring «{{ safe_var }}» = {user_data[user_id]['{{ safe_var }}']!r} (start={_sv_start_{{ loop.index }}}, end={_sv_end_{{ loop.index }}})") 
        {%- elif assignment.mode == 'conditional' %}
        # Тернарный оператор: если условие → trueValue, иначе → falseValue
        _sv_vars_{{ loop.index }} = await init_all_user_vars(user_id)
        _sv_cond_var_{{ loop.index }} = replace_variables_in_text({{ assignment.conditionVariable | default('') | tojson }}, _sv_vars_{{ loop.index }})
        _sv_cond_val_{{ loop.index }} = replace_variables_in_text({{ assignment.conditionValue | default('') | tojson }}, _sv_vars_{{ loop.index }})
        _sv_op_{{ loop.index }} = {{ assignment.conditionOperator | default('equals') | tojson }}
        _sv_cond_result_{{ loop.index }} = False
        try:
            if _sv_op_{{ loop.index }} == "equals":
                _sv_cond_result_{{ loop.index }} = str(_sv_cond_var_{{ loop.index }}) == str(_sv_cond_val_{{ loop.index }})
            elif _sv_op_{{ loop.index }} == "not_equals":
                _sv_cond_result_{{ loop.index }} = str(_sv_cond_var_{{ loop.index }}) != str(_sv_cond_val_{{ loop.index }})
            elif _sv_op_{{ loop.index }} == "greater_than":
                _sv_cond_result_{{ loop.index }} = float(_sv_cond_var_{{ loop.index }}) > float(_sv_cond_val_{{ loop.index }})
            elif _sv_op_{{ loop.index }} == "less_than":
                _sv_cond_result_{{ loop.index }} = float(_sv_cond_var_{{ loop.index }}) < float(_sv_cond_val_{{ loop.index }})
            elif _sv_op_{{ loop.index }} == "greater_or_equal":
                _sv_cond_result_{{ loop.index }} = float(_sv_cond_var_{{ loop.index }}) >= float(_sv_cond_val_{{ loop.index }})
            elif _sv_op_{{ loop.index }} == "less_or_equal":
