{#
  Шаблон обработчиков синонимов

  @fileoverview Генерирует Python код для обработки синонимов команд и сообщений
  @param {array} synonyms - Массив объектов SynonymEntry:
    - synonym: string          — текст синонима
    - nodeId: string           — ID узла
    - nodeType: string         — тип узла (start|command|message|pin_message|unpin_message|delete_message|...)
    - functionName: string     — имя функции оригинального обработчика (для command/start)
    - originalCommand: string  — оригинальная команда (для command/start)
    - messageText: string      — текст ответа (для content management)
    - disableNotification: bool — отключить уведомление (для pin_message)
#}

# Обработчики синонимов
{% for entry in synonymEntries %}
# @@NODE_START:{{ entry.nodeId }}@@
{% set sanitized_synonym = entry.synonym | replace(' ', '_') | safe_name %}
{% set sanitized_node_id = entry.nodeId | safe_name %}

{# ── COMMAND / START синонимы ── #}
{% if entry.nodeType in ['start', 'command'] %}
{% set fn = entry.functionName if entry.functionName else 'start' %}
{% set cmd = entry.originalCommand if entry.originalCommand else '/start' %}

@dp.message(lambda message: message.text and message.text.lower() == "{{ entry.synonym | lower }}")
async def {{ fn }}_synonym_{{ sanitized_synonym }}_handler(message: types.Message):
    # Синоним для команды {{ cmd }}
    if "{{ fn }}_handler" in globals():
        await {{ fn }}_handler(message)
    else:
        await message.answer("Команда {{ cmd }} временно недоступна")

{# ── MESSAGE синонимы (MockCallback) ── #}
{% elif entry.nodeType == 'message' %}

@dp.message(lambda message: message.text and message.text.lower() == "{{ entry.synonym | lower }}")
async def message_{{ sanitized_node_id }}_synonym_{{ sanitized_synonym }}_handler(message: types.Message):
    # Синоним для сообщения {{ entry.nodeId }}
    user_id = message.from_user.id
    logging.info(f"Пользователь {user_id} написал синоним '{{ entry.synonym }}' для узла {{ entry.nodeId }}")

    class MockCallback:
        def __init__(self, data, user, msg):
            self.data = data
            self.from_user = user
            self.message = msg

        async def answer(self):
            pass

        async def edit_text(self, text, **kwargs):
            try:
                return await self.message.edit_text(text, **kwargs)
            except Exception as e:
                logging.warning(f"Не удалось отредактировать сообщение: {e}")
                return await self.message.answer(text, **kwargs)

    mock_callback = MockCallback("{{ entry.nodeId }}", message.from_user, message)
    await handle_callback_{{ sanitized_node_id }}(mock_callback)

{# ── CONTENT MANAGEMENT синонимы (pin/unpin/delete) ── #}
{% elif entry.nodeType in ['pin_message', 'unpin_message', 'delete_message'] %}
{% set default_text = "✅ Сообщение закреплено" if entry.nodeType == 'pin_message' else ("✅ Сообщение откреплено" if entry.nodeType == 'unpin_message' else "🗑️ Сообщение успешно удалено!") %}
{% set msg_text = entry.messageText if entry.messageText else default_text %}

@dp.message(lambda message: message.text and (message.text.lower() == "{{ entry.synonym | lower }}" or message.text.lower().startswith("{{ entry.synonym | lower }} ")) and message.chat.type in ['group', 'supergroup'])
async def {{ entry.nodeType }}_{{ sanitized_node_id }}_synonym_{{ sanitized_synonym }}_handler(message: types.Message):
    """Обработчик синонима '{{ entry.synonym }}' для {{ entry.nodeType }}"""
    user_id = message.from_user.id
    chat_id = message.chat.id

    target_message_id = None

    if message.reply_to_message:
        target_message_id = message.reply_to_message.message_id
        logging.info(f"Пользователь {user_id} использовал '{{ entry.synonym }}' для сообщения {target_message_id} (через ответ)")
    else:
        text_parts = message.text.split()
        if len(text_parts) > 1 and text_parts[1].isdigit():
            target_message_id = int(text_parts[1])
            logging.info(f"Пользователь {user_id} использовал '{{ entry.synonym }}' для сообщения {target_message_id} (через ID)")
        else:
            await message.answer("❌ Укажите сообщение: ответьте на сообщение или напишите '{{ entry.synonym }} ID_сообщения'")
            return

    try:
{% if entry.nodeType == 'pin_message' %}
        await bot.pin_chat_message(
            chat_id=chat_id,
            message_id=target_message_id,
            disable_notification={{ "True" if entry.disableNotification else "False" }}
        )
        await message.answer("{{ msg_text }}")
        logging.info(f"Сообщение {target_message_id} закреплено пользователем {user_id}")
{% elif entry.nodeType == 'unpin_message' %}
        await bot.unpin_chat_message(chat_id=chat_id, message_id=target_message_id)
        await message.answer("{{ msg_text }}")
        logging.info(f"Сообщение {target_message_id} откреплено пользователем {user_id}")
{% elif entry.nodeType == 'delete_message' %}
        await bot.delete_message(chat_id=chat_id, message_id=target_message_id)
        await message.answer("{{ msg_text }}")
        logging.info(f"Сообщение {target_message_id} удалено пользователем {user_id}")
{% endif %}

    except TelegramBadRequest as e:
        if "message to pin not found" in str(e) or "message not found" in str(e):
            await message.answer("❌ Сообщение не найдено")
        elif "not enough rights" in str(e) or "CHAT_ADMIN_REQUIRED" in str(e):
            await message.answer("❌ Недостаточно прав для выполнения операции")
        else:
            await message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка {{ entry.nodeType }}: {e}")
    except Exception as e:
        await message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка в {{ entry.nodeType }}: {e}")

{% endif %}
# @@NODE_END:{{ entry.nodeId }}@@
{% endfor %}
