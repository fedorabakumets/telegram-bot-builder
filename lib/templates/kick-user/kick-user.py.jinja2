{#
  Шаблон обработчиков действия kick_user.
  Исключает пользователя из чата через unbanChatMember(only_if_banned=False).

  @param {array} entries - Массив KickUserEntry:
    - nodeId: string              — ID узла
    - safeName: string            — безопасное имя функции
    - targetNodeId: string        — ID следующего узла
    - targetNodeType: string      — тип следующего узла
    - userIdSource: string        — 'current_user' | 'reply_user' | 'custom'
    - userIdManual: string        — ID пользователя или {переменная}
    - chatIdSource: string        — 'current_chat' | 'custom'
    - chatIdManual: string        — ID чата или {переменная}
    - ignoreErrors: boolean       — игнорировать ошибки
#}

# Обработчики узлов kick_user
{% for entry in entries -%}
{%- set sanitized_node_id = entry.nodeId | safe_name -%}
{%- set sanitized_target_id = entry.targetNodeId | safe_name -%}

@dp.callback_query(lambda c: c.data == "{{ entry.nodeId }}")
async def handle_callback_{{ sanitized_node_id }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Исключение пользователя из чата"""
    {%- if entry.ignoreErrors %}
    try:
    {%- endif %}

        user_id = callback_query.from_user.id
        logging.info(f"👢 kick_user узел {{ entry.nodeId }} для пользователя {user_id}")

        # Определяем chat_id
        {% if entry.chatIdSource == 'custom' %}
        _all_vars = await init_all_user_vars(user_id)
        {%- set _chat_raw = entry.chatIdManual | trim %}
        {%- if '{' in _chat_raw %}
        _chat_id_raw = replace_variables_in_text({{ _chat_raw | format_python_text }}, _all_vars, {})
        {%- else %}
        _chat_id_raw = {{ _chat_raw | escape_python_string }}
        {%- endif %}
        _chat_id_str = str(_chat_id_raw).strip()
        try:
            _chat_id = int(_chat_id_str)
            if _chat_id > 0 and len(_chat_id_str) >= 10:
                _chat_id = int(f"-100{_chat_id}")
        except (ValueError, TypeError):
            _chat_id = _chat_id_str
        {% else %}
        _chat_id = callback_query.message.chat.id
        {% endif %}

        # Определяем target_user_id
        {% if entry.userIdSource == 'current_user' %}
        _target_user_id = callback_query.from_user.id
        {% elif entry.userIdSource == 'reply_user' %}
        _reply_msg = callback_query.message.reply_to_message if hasattr(callback_query.message, 'reply_to_message') else None
        if _reply_msg and _reply_msg.from_user:
            _target_user_id = _reply_msg.from_user.id
        else:
            logging.warning(f"kick_user {{ entry.nodeId }}: нет reply_to_message, пропускаем")
            {% if entry.targetNodeId %}
            await handle_callback_{{ sanitized_target_id }}(callback_query, state=None)
            {% endif %}
            return
        {% elif entry.userIdSource == 'custom' %}
        {%- if entry.chatIdSource != 'custom' %}
        _all_vars = await init_all_user_vars(user_id)
        {%- endif %}
        {%- set _user_raw = entry.userIdManual | trim %}
        {%- if '{' in _user_raw %}
        _user_id_raw = replace_variables_in_text({{ _user_raw | format_python_text }}, _all_vars, {})
        {%- else %}
        _user_id_raw = {{ _user_raw | escape_python_string }}
        {%- endif %}
        try:
            _target_user_id = int(str(_user_id_raw).strip())
        except (ValueError, TypeError):
            logging.warning(f"kick_user {{ entry.nodeId }}: не удалось получить user_id из '{{ _user_raw }}'")
            {% if entry.targetNodeId %}
            await handle_callback_{{ sanitized_target_id }}(callback_query, state=None)
            {% endif %}
            return
        {% endif %}

        # Исключаем пользователя (unbanChatMember с only_if_banned=False = кик)
        await bot.unban_chat_member(chat_id=_chat_id, user_id=_target_user_id, only_if_banned=False)
        logging.info(f"👢 kick_user {{ entry.nodeId }}: пользователь {_target_user_id} исключён из чата {_chat_id}")

        {% if entry.targetNodeId %}
        await handle_callback_{{ sanitized_target_id }}(callback_query, state=None)
        {% endif %}

    {% if entry.ignoreErrors %}
    except Exception as _e:
        logging.error(f"Ошибка в kick_user {{ entry.nodeId }}: {_e}")
        {% if entry.targetNodeId %}
        await handle_callback_{{ sanitized_target_id }}(callback_query, state=None)
        {% endif %}
    {% endif %}

{% endfor %}
