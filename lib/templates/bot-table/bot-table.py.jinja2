{% elif onConflict == 'merge' %}
                    # onConflict=merge: обновить только пустые поля
                    _existing = _found_row["data"] if isinstance(_found_row["data"], dict) else json.loads(_found_row["data"])
{% for col_name, col_value in row %}
                    _merge_col_id_{{ loop.index }} = _name_to_id.get("{{ col_name }}", "{{ col_name }}")
