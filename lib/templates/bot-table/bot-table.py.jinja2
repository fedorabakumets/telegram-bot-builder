{#
  Шаблон узла bot_table — работа с внутренними таблицами конструктора

  @param {string} nodeId          — ID узла
  @param {string} tableName       — Имя таблицы (поддерживает {переменные})
  @param {string} operation       — Операция: read, insert, update, upsert, delete, count, sum, max, min, avg, distinct, delete_all
  @param {array}  where           — Условия WHERE [{column, value, operator}]
  @param {array}  updates         — Обновления [{column, op, value}]
  @param {object} row             — Данные строки (для insert, upsert)
  @param {string} key             — Ключ для upsert
  @param {string} onConflict      — Поведение при конфликте: ignore, update, merge
  @param {string} saveResultTo    — Переменная для сохранения результата
  @param {string} resultFormat    — Формат результата: first_row, all_rows, scalar, count, random_row
  @param {array}  returnColumns   — Колонки для возврата
  @param {string} orderBy         — Сортировка
  @param {string} orderDirection  — Направление сортировки
  @param {number} limit           — Лимит строк
  @param {number} offset          — Смещение строк (для пагинации)
  @param {string} aggregateColumn — Колонка для агрегации (sum, max, min, avg, distinct)
  @param {boolean} returnInsertedId — Вернуть ID вставленной строки
  @param {string} autoTransitionTo — ID следующего узла
#}
{%- set safe_node_id = nodeId | safe_name -%}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ safe_node_id }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Узел bot_table: операция {{ operation }} с таблицей {{ tableName }}."""
    try:
        user_id = callback_query.from_user.id
        logging.info(f"🗄️ bot_table [{{ nodeId }}]: операция={{ operation }}, таблица={{ tableName }} для пользователя {user_id}")
        if user_id not in user_data:
            user_data[user_id] = {}
        _vars = await init_all_user_vars(user_id)
        _table_name = replace_variables_in_text({{ tableName | tojson }}, _vars)
{% if operation == 'read' %}
        # === Операция READ ===
        if db_pool:
            async with db_pool.acquire() as conn:
                _tbl = await conn.fetchrow("SELECT id FROM bot_tables WHERE project_id = $1 AND name = $2", PROJECT_ID, _table_name)
                if _tbl:
                    _cols = await conn.fetch("SELECT id, name FROM bot_table_columns WHERE table_id = $1 ORDER BY position", _tbl["id"])
                    _col_map = {str(c["id"]): c["name"] for c in _cols}
                    _name_to_id = {c["name"]: str(c["id"]) for c in _cols}
                    _rows = await conn.fetch("SELECT id, data, row_index FROM bot_table_rows WHERE table_id = $1 ORDER BY row_index", _tbl["id"])
                    _results = []
                    for _row in _rows:
                        _data = _row["data"] if isinstance(_row["data"], dict) else json.loads(_row["data"])
                        _named = {_col_map.get(k, k): str(v) if v is not None else "" for k, v in _data.items()}
                        _match = True
{% for cond in where %}
                        _cond_val_{{ loop.index }} = replace_variables_in_text({{ cond.value | tojson }}, _vars)
{% if cond.operator == 'not_equals' %}
                        if str(_named.get("{{ cond.column }}", "")) == str(_cond_val_{{ loop.index }}):
                            _match = False
{% elif cond.operator == 'greater_than' %}
                        try:
                            if not (float(_named.get("{{ cond.column }}", "0") or "0") > float(_cond_val_{{ loop.index }} or "0")):
                                _match = False
                        except (ValueError, TypeError):
                            _match = False
{% elif cond.operator == 'less_than' %}
                        try:
                            if not (float(_named.get("{{ cond.column }}", "0") or "0") < float(_cond_val_{{ loop.index }} or "0")):
                                _match = False
                        except (ValueError, TypeError):
                            _match = False
{% elif cond.operator == 'contains' %}
                        if str(_cond_val_{{ loop.index }}) not in str(_named.get("{{ cond.column }}", "")):
                            _match = False
{% elif cond.operator == 'is_empty' %}
                        if str(_named.get("{{ cond.column }}", "")).strip():
                            _match = False
{% elif cond.operator == 'is_not_empty' %}
                        if not str(_named.get("{{ cond.column }}", "")).strip():
                            _match = False
{% else %}
                        if str(_named.get("{{ cond.column }}", "")) != str(_cond_val_{{ loop.index }}):
                            _match = False
{% endif %}
{% endfor %}
                        if _match:
                            _results.append(_named)
{% if orderBy %}
                    # Сортировка по {{ orderBy }} {{ orderDirection }}
                    try:
                        _results.sort(key=lambda x: float(x.get("{{ orderBy }}", "0") or "0"), reverse={{ 'True' if orderDirection == 'desc' else 'False' }})
                    except (ValueError, TypeError):
                        pass
{% endif %}
{% if offset > 0 %}
                    _results = _results[{{ offset }}:]
{% endif %}
{% if limit > 0 %}
                    _results = _results[:{{ limit }}]
{% endif %}
                    # Сохранение результата
{% if resultFormat == 'first_row' %}
                    if _results:
                        for _k, _v in _results[0].items():
                            user_data[user_id]["{{ saveResultTo }}." + _k] = _v
{% elif resultFormat == 'all_rows' %}
                    user_data[user_id]["{{ saveResultTo }}"] = _results
{% elif resultFormat == 'count' %}
                    user_data[user_id]["{{ saveResultTo }}"] = str(len(_results))
{% elif resultFormat == 'scalar' %}
                    if _results:
                        _first_val = list(_results[0].values())[0] if _results[0] else ""
                        user_data[user_id]["{{ saveResultTo }}"] = _first_val
{% elif resultFormat == 'random_row' %}
