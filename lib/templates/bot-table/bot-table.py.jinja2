{% endfor %}
                _cols = await conn.fetch("SELECT id, name FROM bot_table_columns WHERE table_id = $1", _tbl["id"])
                _col_map = {str(c["id"]): c["name"] for c in _cols}
                _name_to_id = {c["name"]: str(c["id"]) for c in _cols}
