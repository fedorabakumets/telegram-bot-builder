                _key_col_id = _name_to_id.get("{{ key }}", "")
                _key_value = replace_variables_in_text({{ row[key] | default('') | tojson }}, _vars)
                _rows = await conn.fetch("SELECT id, data, row_index FROM bot_table_rows WHERE table_id = $1", _tbl["id"])
                _found_row = None
                for _row in _rows:
