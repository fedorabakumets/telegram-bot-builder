{#
  Шаблон обработчиков триггеров создания управляемого бота.

  Telegram присылает managed_bot_created как сервисное сообщение (types.Message),
  а не как отдельный тип Update. Поэтому обработчик регистрируется через
  @dp.message(lambda m: m.managed_bot_created is not None).

  @param {array} managedBotUpdatedTriggerEntries - Массив ManagedBotUpdatedTriggerEntry:
    - nodeId: string              — ID узла managed_bot_updated_trigger
    - targetNodeId: string        — ID целевого узла
    - targetNodeType: string      — тип целевого узла
    - saveBotIdTo?: string        — переменная для bot.id
    - saveBotUsernameTo?: string  — переменная для bot.username
    - saveBotNameTo?: string      — переменная для bot.first_name
    - saveCreatorIdTo?: string    — переменная для user.id создателя
    - saveCreatorUsernameTo?: string — переменная для user.username создателя
    - filterByUserId?: string     — фильтр по user.id
#}

# Обработчики триггеров создания управляемого бота
{% for entry in managedBotUpdatedTriggerEntries -%}
{%- set sanitized_node_id = entry.nodeId | safe_name -%}
{%- set sanitized_target_id = entry.targetNodeId | safe_name -%}

@dp.message(lambda m: m.managed_bot_created is not None)
async def managed_bot_updated_trigger_{{ sanitized_node_id }}_handler(message: types.Message):
    """Срабатывает когда пользователь создал управляемого бота"""
    try:
        managed_bot = message.managed_bot_created.bot_user
        creator_user = message.from_user
        user_id = creator_user.id if creator_user else None
        if not user_id:
            return

        {% if entry.filterByUserId %}
        if str(user_id) != "{{ entry.filterByUserId }}":
            return
        {% endif %}

        logging.info(f"Управляемый бот создан — триггер узла {{ entry.nodeId }}, user_id={user_id}")
        if user_id not in user_data:
            user_data[user_id] = {}

        {% if entry.saveBotIdTo %}
        user_data[user_id]["{{ entry.saveBotIdTo }}"] = managed_bot.id
        {% endif %}
        {% if entry.saveBotUsernameTo %}
        user_data[user_id]["{{ entry.saveBotUsernameTo }}"] = managed_bot.username or ""
        {% endif %}
        {% if entry.saveBotNameTo %}
        user_data[user_id]["{{ entry.saveBotNameTo }}"] = managed_bot.first_name or ""
        {% endif %}

        {% if entry.saveCreatorIdTo %}
        user_data[user_id]["{{ entry.saveCreatorIdTo }}"] = creator_user.id
        {% endif %}
        {% if entry.saveCreatorUsernameTo %}
        user_data[user_id]["{{ entry.saveCreatorUsernameTo }}"] = creator_user.username or ""
        {% endif %}

        class FakeCallbackQuery:
            """Фейковый объект callback_query для вызова обработчика следующего узла"""
            def __init__(self, user_id_val, msg):
                self.from_user = type('User', (), {
                    'id': user_id_val,
                    'username': user_data.get(user_id_val, {}).get('username', ''),
                    'first_name': user_data.get(user_id_val, {}).get('first_name', ''),
                    'last_name': user_data.get(user_id_val, {}).get('last_name', ''),
                    'language_code': '',
                    'is_premium': False,
                    'is_bot': False,
                })()
                self.message = msg
                self.data = "{{ entry.targetNodeId }}"
                self._is_fake = True

            async def answer(self, *args, **kwargs):
                pass

        fake_cb = FakeCallbackQuery(user_id, message)
        await handle_callback_{{ sanitized_target_id }}(fake_cb, state=None)
    except Exception as e:
        logging.error(f"Ошибка в managed_bot_updated_trigger {{ entry.nodeId }}: {e}")

{% endfor %}
