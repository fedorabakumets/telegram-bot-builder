async def set_user_var(user_id: int, key: str, value) -> None:
    """Сохраняет переменную пользователя в локальное хранилище и БД.

    Запись в память — синхронная (мгновенно), запись в БД — fire-and-forget (фоново).
    Следующий узел прочитает актуальное значение из user_data без ожидания БД.
    Инвалидирует кэш _vars_cache чтобы следующий init_all_user_vars взял свежие данные.

    Args:
        user_id (int): ID пользователя Telegram
        key (str): Имя переменной
        value: Значение переменной
    """
    if user_id not in user_data:
        user_data[user_id] = {}
    user_data[user_id][key] = value
    # Инвалидируем кэш памяти — данные изменились, следующий запрос пойдёт в БД
    _vars_cache.pop(user_id, None)
    # Инвалидируем Redis кэш синхронно — чтобы следующий узел не прочитал устаревшие данные
    if _redis_client is not None:
        try:
            await _redis_client.delete(f"vars_cache:{user_id}")
        except Exception:
            pass
{%- if userDatabaseEnabled %}
    # Fire-and-forget: запись в БД идёт в фоне, не блокируя ответ пользователю
    asyncio.create_task(_persist_user_var(user_id, key, value))
{%- endif %}


