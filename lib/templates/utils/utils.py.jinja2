async def init_all_user_vars(user_id: int) -> dict:
    """Собирает все переменные пользователя из локального хранилища и БД.

    Использует кэш с TTL для снижения нагрузки на БД при быстрой навигации.
    Если Redis доступен — кэш хранится в Redis, иначе в памяти (_vars_cache).
    Память (user_data) всегда имеет приоритет над кэшем.

    Returns:
        dict: Объединённый словарь всех переменных пользователя,
              включая плоские ключи вида "responseVar.field"
    """
    import time as _time
    all_vars = dict(user_data.get(user_id, {}))
    # Добавляем системные переменные бота — доступны в URL и текстах узлов
    all_vars["bot_token"] = BOT_TOKEN or ""
{%- if userDatabaseEnabled %}
    try:
        if db_pool:
            _now = _time.monotonic()
            # Если Redis доступен — используем его как кэш переменных
            if _redis_client is not None:
                import json as _rj
                from datetime import datetime as _dt
                def _json_serial(obj):
                    """Сериализатор для типов не поддерживаемых json.dumps (datetime и др.)"""
                    if isinstance(obj, _dt):
                        return obj.isoformat()
                    return str(obj)
                _cached_raw = await _redis_client.get(f"vars_cache:{user_id}")
                if _cached_raw:
                    try:
                        _db_vars = _rj.loads(_cached_raw.decode() if isinstance(_cached_raw, bytes) else _cached_raw)
                        # Мёрджим: память имеет приоритет над кэшем
                        _merged = dict(_db_vars)
                        _merged.update(all_vars)
                        all_vars = _merged
                    except Exception:
                        pass
                else:
                    # Кэш в Redis пуст — идём в БД и кэшируем результат
                    async with db_pool.acquire() as conn:
                        row = await conn.fetchrow("SELECT * FROM bot_users WHERE user_id = $1 AND project_id = $2 AND token_id = $3", user_id, PROJECT_ID, TOKEN_ID)
                        if row:
                            _db_snapshot = {}
                            for key in row.keys():
                                if row[key] is not None:
                                    all_vars[key] = row[key]
                                    _db_snapshot[key] = row[key]
                            raw_user_data = row.get('user_data')
                            if raw_user_data:
                                import json as _json
                                extra = _json.loads(raw_user_data) if isinstance(raw_user_data, str) else raw_user_data
                                if isinstance(extra, dict):
                                    all_vars.update(extra)
                                    _db_snapshot.update(extra)
                            # Кэшируем снимок БД в Redis с TTL
                            await _redis_client.setex(f"vars_cache:{user_id}", VARS_CACHE_TTL, _rj.dumps(_db_snapshot, ensure_ascii=False, default=_json_serial))
            else:
                # Redis недоступен — используем _vars_cache в памяти
                _cached = _vars_cache.get(user_id)
                if _cached and (_now - _cached[0]) < VARS_CACHE_TTL:
                    # Кэш актуален: мёрджим кэшированные данные БД с актуальной памятью
                    _db_vars = _cached[1]
                    _merged = dict(_db_vars)
                    _merged.update(all_vars)  # память имеет приоритет
                    all_vars = _merged
                else:
                    # Кэш устарел — идём в БД
                    async with db_pool.acquire() as conn:
                        row = await conn.fetchrow("SELECT * FROM bot_users WHERE user_id = $1 AND project_id = $2 AND token_id = $3", user_id, PROJECT_ID, TOKEN_ID)
                        if row:
                            _db_snapshot = {}
                            for key in row.keys():
                                if row[key] is not None:
                                    all_vars[key] = row[key]
                                    _db_snapshot[key] = row[key]
                            raw_user_data = row.get('user_data')
                            if raw_user_data:
                                import json as _json
                                extra = _json.loads(raw_user_data) if isinstance(raw_user_data, str) else raw_user_data
                                if isinstance(extra, dict):
                                    all_vars.update(extra)
                                    _db_snapshot.update(extra)
                            # Сохраняем снимок БД в кэш памяти
                            _vars_cache[user_id] = (_now, _db_snapshot)
    except Exception as e:
        logging.warning(f"⚠️ Не удалось загрузить переменные из БД: {e}")
{%- endif %}
    # Рекурсивно разворачиваем dict-значения в плоские ключи для dot-notation подстановки.
    # Поддерживает произвольную глубину вложенности (до max_depth уровней).
    # Гарантирует что {a.b.c} найдётся через all_vars["a.b.c"] даже при глубокой вложенности.
    def _flatten_dict(_prefix: str, _obj, _result: dict, _depth: int = 0, _max_depth: int = 5) -> None:
        if _depth > _max_depth:
            return
        if isinstance(_obj, dict):
            for _dk, _dv in _obj.items():
                _flatten_dict(f"{_prefix}.{_dk}", _dv, _result, _depth + 1, _max_depth)
        elif isinstance(_obj, (str, int, float, bool)) and _obj is not None:
            _result[_prefix] = str(_obj)
    _flat_keys = {}
    for _k, _v in list(all_vars.items()):
        if isinstance(_v, dict):
            _flatten_dict(_k, _v, _flat_keys)
    all_vars.update(_flat_keys)
    return all_vars


