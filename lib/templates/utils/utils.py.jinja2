def _eval_expr(template: str, user_vars: dict):
    """Вычисляет арифметическое выражение с подстановкой переменных из user_vars.

    Сначала подставляет {переменные} как числа (или 0 если не найдено),
    затем безопасно вычисляет выражение через ast.parse.
    Разрешены только числа и арифметические операторы (+, -, *, /, //, %, **).
    При любой ошибке возвращает исходный шаблон без изменений.

    Args:
        template: Строка-выражение, например "{step} + 1" или "{price} * {qty}"
        user_vars: Словарь переменных пользователя

    Returns:
        Результат вычисления (число) или исходный шаблон при ошибке
    """
    import re as _re_expr, ast as _ast_expr

    def _replacer(match):
        path = match.group(1).split('.')
        val = user_vars
        for key in path:
            if isinstance(val, dict):
                val = val.get(key, 0)
            else:
                return '0'
        return str(val) if val is not None else '0'

    expr = _re_expr.sub(r'\{([^}]+)\}', _replacer, template)
    try:
        tree = _ast_expr.parse(expr, mode='eval')
        _allowed = (
            _ast_expr.Expression, _ast_expr.BinOp, _ast_expr.UnaryOp,
            _ast_expr.Constant,
            _ast_expr.Add, _ast_expr.Sub, _ast_expr.Mult, _ast_expr.Div,
            _ast_expr.FloorDiv, _ast_expr.Mod, _ast_expr.Pow,
            _ast_expr.USub, _ast_expr.UAdd,
        )
        for _node in _ast_expr.walk(tree):
            if not isinstance(_node, _allowed):
                return template
        return eval(compile(tree, '<expr>', 'eval'))
    except Exception:
        return template


def replace_variables_in_text(text: str, variables: dict, filters: dict = None) -> str:
    """Заменяет переменные вида {var_name} и {var.path.nested} в тексте на их значения

    Args:
        text: Исходный текст с переменными
        variables: Словарь переменных для подстановки
        filters: Словарь фильтров форматирования (опционально)

    Returns:
        str: Текст с подставленными значениями
    """
    if not text or not variables:
        return text or ''
    import re as _re
    import json as _json

    def _resolve(var_path: str) -> str | None:
        """Разрешает переменную, поддерживая dot-notation и индексы массивов вида [0]"""
        # Сначала ищем точное совпадение в плоском словаре (включая ключи вида a.b[0].c)
        val = variables.get(var_path)
        if val is not None:
            # dict/list сериализуем как валидный JSON, не Python repr
            if isinstance(val, (dict, list)):
                return _json.dumps(val, ensure_ascii=False)
            return str(val)
        # Если нет точного совпадения — пробуем обойти путь вручную
        # Разбиваем путь на сегменты: "a.b[0][1].c" → ["a", "b", "[0]", "[1]", "c"]
        segments = _re.split(r'\.(?![^\[]*\])', var_path)
        root_key = segments[0]
        root = variables.get(root_key)
        if root is None:
            return None
        # Если корень — строка, пробуем распарсить как JSON
        if isinstance(root, str):
            try:
                root = _json.loads(root)
            except Exception:
                return None
        obj = root
        for seg in segments[1:]:
            # Сегмент может содержать индексы: "photos[0][1]", "photos[-1]" или просто "field"
            parts = _re.split(r'(\[-?\d+\])', seg)
            for part in parts:
                if not part:
                    continue
                idx_match = _re.fullmatch(r'\[(-?\d+)\]', part)
                if idx_match:
                    idx = int(idx_match.group(1))
                    if not isinstance(obj, list):
                        return None
                    try:
                        obj = obj[idx]
                    except IndexError:
                        return None
                else:
                    if not isinstance(obj, dict):
                        return None
                    obj = obj.get(part)
                    if obj is None:
                        return None
        return str(obj) if obj is not None else None

    def _replacer(match):
        var_path = match.group(1)
        resolved = _resolve(var_path)
        return resolved if resolved is not None else match.group(0)

    # Паттерн поддерживает: {var}, {a.b.c}, {a.b[0][1].c}
    # Многопроходная замена: если после подстановки остались {}, делаем ещё проход (макс 3)
    result = text
    for _pass in range(3):
        _new_result = _re.sub(r'\{([\w.\[\]]+)\}', _replacer, result)
        if _new_result == result:
            break
        result = _new_result
    return result


