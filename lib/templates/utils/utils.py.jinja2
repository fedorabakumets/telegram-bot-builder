def _eval_expr(template: str, user_vars: dict):
    """Вычисляет выражение с подстановкой переменных из user_vars.

    Поддерживает арифметику (+, -, *, /, //, %, **), безопасные функции
    (round, abs, int, float, min, max) и строковые методы
    (replace, strip, lower, upper, startswith, endswith, split, join).
    При любой ошибке возвращает исходный шаблон без изменений.

    Args:
        template: Строка-выражение, например "{step} + 1" или "'{text}'.replace('a', 'b')"
        user_vars: Словарь переменных пользователя

    Returns:
        Результат вычисления или исходный шаблон при ошибке
    """
    import re as _re_expr, ast as _ast_expr

    def _replacer(match):
        path = match.group(1).split('.')
        val = user_vars
        for key in path:
            if isinstance(val, dict):
                val = val.get(key, 0)
            else:
                return '0'
        return str(val) if val is not None else '0'

    expr = _re_expr.sub(r'\{([^}]+)\}', _replacer, template)
    try:
        tree = _ast_expr.parse(expr, mode='eval')
        _allowed = (
            _ast_expr.Expression, _ast_expr.BinOp, _ast_expr.UnaryOp,
            _ast_expr.Constant,
            _ast_expr.Add, _ast_expr.Sub, _ast_expr.Mult, _ast_expr.Div,
            _ast_expr.FloorDiv, _ast_expr.Mod, _ast_expr.Pow,
            _ast_expr.USub, _ast_expr.UAdd,
            _ast_expr.Call, _ast_expr.Name, _ast_expr.Load,
            _ast_expr.Attribute, _ast_expr.Subscript, _ast_expr.Index, _ast_expr.Slice,
            _ast_expr.IfExp, _ast_expr.Compare,
            _ast_expr.Gt, _ast_expr.GtE, _ast_expr.Lt, _ast_expr.LtE, _ast_expr.Eq, _ast_expr.NotEq,
        )
        _safe_funcs = {'round': round, 'abs': abs, 'int': int, 'float': float, 'min': min, 'max': max, 'str': str}
        _safe_methods = {'replace', 'strip', 'lstrip', 'rstrip', 'lower', 'upper', 'startswith', 'endswith', 'split', 'join', 'count', 'find'}
        for _node in _ast_expr.walk(tree):
            if not isinstance(_node, _allowed):
                return template
            if isinstance(_node, _ast_expr.Name) and _node.id not in _safe_funcs:
                return template
            if isinstance(_node, _ast_expr.Attribute) and _node.attr not in _safe_methods:
                return template
            if isinstance(_node, _ast_expr.Call):
                if isinstance(_node.func, _ast_expr.Name) and _node.func.id not in _safe_funcs:
                    return template
                if isinstance(_node.func, _ast_expr.Attribute) and _node.func.attr not in _safe_methods:
                    return template
        return eval(compile(tree, '<expr>', 'eval'), {"__builtins__": {}}, _safe_funcs)
    except Exception:
        return template


def replace_variables_in_text(text: str, variables: dict, filters: dict = None) -> str:
    """Заменяет переменные вида {var_name} и {var.path.nested} в тексте на их значения

    Args:
        text: Исходный текст с переменными
        variables: Словарь переменных для подстановки
        filters: Словарь фильтров форматирования (опционально)

    Returns:
        str: Текст с подставленными значениями
    """
    if not text or not variables:
        return text or ''
    import re as _re
    import json as _json

    # ─── Обработка итерации по массиву в тексте ─────────────────────────────
    # Синтаксис в тексте пользователя: {каждый элемент} — см. документацию
    # Внутри блока доступны поля текущего элемента + __index (с 1)
    _each_open = "{" + "#each"  # разбиваем чтобы не конфликтовать с шаблонизатором
    _each_pattern = _re.compile(r'\{' + r'#each\s+([\w.\[\]]+)\}(.*?)\{/each\}', _re.DOTALL)

    def _expand_each(_m):
        _var_path = _m.group(1)
        _tpl = _m.group(2)
        # Убираем ведущий перенос строки после открывающего тега
        if _tpl.startswith('\n'):
            _tpl = _tpl[1:]
        # Убираем завершающий перенос строки перед {/each}
        if _tpl.endswith('\n'):
            _tpl = _tpl[:-1]
        # Получаем массив из переменных
        _items = variables.get(_var_path)
        if _items is None:
            # Пробуем через dot-notation
            _segments = _var_path.split('.')
            _obj = variables
            for _seg in _segments:
                if isinstance(_obj, dict):
                    _obj = _obj.get(_seg)
                else:
                    _obj = None
                    break
            _items = _obj
        if isinstance(_items, str):
            try:
                _items = _json.loads(_items)
            except Exception:
                _items = None
        if not isinstance(_items, list):
            return ''
        _lines = []
        for _i, _item in enumerate(_items):
            _item_vars = dict(variables)  # копируем родительские переменные
            if isinstance(_item, dict):
                _item_vars.update(_item)
            else:
                _item_vars['value'] = str(_item) if _item is not None else ''
            _item_vars['__index'] = str(_i + 1)
            _item_vars['__index0'] = str(_i)
            _line = replace_variables_in_text(_tpl, _item_vars, filters)
            _lines.append(_line)
        return '\n'.join(_lines)

    # Раскрываем все each-блоки (поддержка вложенности через рекурсию)
    _prev = None
    result = text
    while _prev != result:
        _prev = result
        result = _each_pattern.sub(_expand_each, result)

    # ─── Основная замена переменных {var} ─────────────────────────────────────

    def _resolve(var_path: str) -> str | None:
        """Разрешает переменную, поддерживая dot-notation и индексы массивов вида [0]"""
        # Сначала ищем точное совпадение в плоском словаре (включая ключи вида a.b[0].c)
        val = variables.get(var_path)
        if val is not None:
            # dict/list сериализуем как валидный JSON, не Python repr
            if isinstance(val, (dict, list)):
                return _json.dumps(val, ensure_ascii=False)
            return str(val)
        # Если нет точного совпадения — пробуем обойти путь вручную
        # Разбиваем путь на сегменты: "a.b[0][1].c" → ["a", "b", "[0]", "[1]", "c"]
        segments = _re.split(r'\.(?![^\[]*\])', var_path)
        root_key = segments[0]
        root = variables.get(root_key)
        if root is None:
            return None
        # Если корень — строка, пробуем распарсить как JSON
        if isinstance(root, str):
            try:
                root = _json.loads(root)
            except Exception:
                return None
        obj = root
        for seg in segments[1:]:
            # Сегмент может содержать индексы: "photos[0][1]", "photos[-1]" или просто "field"
            parts = _re.split(r'(\[-?\d+\])', seg)
            for part in parts:
                if not part:
                    continue
                idx_match = _re.fullmatch(r'\[(-?\d+)\]', part)
                if idx_match:
                    idx = int(idx_match.group(1))
                    if not isinstance(obj, list):
                        return None
                    try:
                        obj = obj[idx]
                    except IndexError:
                        return None
                else:
                    if not isinstance(obj, dict):
                        return None
                    obj = obj.get(part)
                    if obj is None:
                        return None
        return str(obj) if obj is not None else None

    def _replacer(match):
        var_path = match.group(1)
        resolved = _resolve(var_path)
        return resolved if resolved is not None else match.group(0)

    # Паттерн поддерживает: {var}, {a.b.c}, {a.b[0][1].c}
    # Многопроходная замена: если после подстановки остались {}, делаем ещё проход (макс 3)
    for _pass in range(3):
        _new_result = _re.sub(r'\{([\w.\[\]]+)\}', _replacer, result)
        if _new_result == result:
            break
        result = _new_result
    return result


