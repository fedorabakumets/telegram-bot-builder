{#
  Шаблон генерации обработчика callback для командной кнопки

  @fileoverview Генерирует Python код для обработки командных callback кнопок
  @param {string} callbackData - Callback data для идентификации кнопки
  @param {object} button - Объект кнопки (action, id, target, text)
  @param {string} indentLevel - Уровень отступа (по умолчанию '')
  @param {string} commandNode - Тип узла команды (start, command, или null)
  @param {string} command - Имя команды (без cmd_)

  @example
  ```jinja2
  {% include 'handlers/command-callback-handler/command-callback-handler.py.jinja2' %}
  ```
#}

{% set indent = indentLevel or '' %}
{% set command = button.target | replace('/', '') %}

{{ indent }}@dp.callback_query(lambda c: c.data == "{{ callbackData }}")
{{ indent }}async def handle_callback_{{ safeFunctionName }}(callback_query: types.CallbackQuery):
{{ indent }}    await callback_query.answer()
{{ indent }}    logging.info(f"Обработка кнопки команды: {{ callbackData }} -> /{{ command }} (пользователь {callback_query.from_user.id})")
{{ indent }}    # Симулируем выполнение команды /{{ command }}
{{ indent }}    
{{ indent }}    # Создаем fake message object для команды
{{ indent }}    from types import SimpleNamespace
{{ indent }}    fake_message = SimpleNamespace()
{{ indent }}    fake_message.from_user = callback_query.from_user
{{ indent }}    fake_message.chat = callback_query.message.chat
{{ indent }}    fake_message.date = callback_query.message.date
{{ indent }}    fake_message.answer = callback_query.message.answer
{{ indent }}    fake_message.edit_text = callback_query.message.edit_text
{{ indent }}    
{{ indent }}    {% if commandNode == 'start' %}# Вызываем start handler через edit_text
{{ indent }}    # Создаем специальный объект для редактирования сообщения
{{ indent }}    class FakeCallbackQuery:
{{ indent }}        def __init__(self, callback_query):
{{ indent }}            self.from_user = callback_query.from_user
{{ indent }}            self.chat = callback_query.message.chat
{{ indent }}            self.date = callback_query.message.date
{{ indent }}            self.message_id = callback_query.message.message_id
{{ indent }}            self.data = callback_query.data  # callback_data для навигации
{{ indent }}            self.message = callback_query.message
{{ indent }}            self._callback_query = callback_query
{{ indent }}        
{{ indent }}        async def answer(self, *args, **kwargs):
{{ indent }}            pass  # Игнорируем answer для fake callback
{{ indent }}        
{{ indent }}        async def edit_text(self, text, parse_mode=None, reply_markup=None):
{{ indent }}            await self._callback_query.message.edit_text(text, parse_mode=parse_mode, reply_markup=reply_markup)
{{ indent }}    
{{ indent }}    fake_callback = FakeCallbackQuery(callback_query)
{{ indent }}    await start_handler(fake_callback)
{{ indent }}    {% elif commandNode == 'command' %}# Вызываем {{ command }} handler
{{ indent }}    await {{ command }}_handler(fake_message)
{{ indent }}    {% else %}await callback_query.message.edit_text("Команда /{{ command }} выполнена")
{{ indent }}    {% endif %}
{{ indent }}    logging.info(f"Команда /{{ command }} выполнена через callback кнопку (пользователь {callback_query.from_user.id})")
{{ indent }}
