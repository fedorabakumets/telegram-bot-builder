{#
  Шаблон отправки медиафайлов

  @param {string}  imageUrl    — URL изображения (опционально)
  @param {string}  videoUrl    — URL видео (опционально)
  @param {string}  audioUrl    — URL аудио (опционально)
  @param {string}  documentUrl — URL документа (опционально)
  @param {string}  nodeId      — ID узла
  @param {string}  indentLevel — базовый отступ (по умолчанию '                ')
#}
{% set ind = indentLevel or '                ' %}
{% if imageUrl %}
{% if imageUrl.startswith('/uploads/') %}
{{ ind }}if "{{ imageUrl }}".startswith('/uploads/'):
{{ ind }}    photo_path = get_upload_file_path("{{ imageUrl }}")
{{ ind }}    image_url = FSInputFile(photo_path)
{{ ind }}await bot.send_photo(message.chat.id, image_url, caption=text, parse_mode=parse_mode)
{% else %}
{{ ind }}await bot.send_photo(message.chat.id, "{{ imageUrl }}", caption=text, parse_mode=parse_mode)
{% endif %}
{% elif videoUrl %}
{% if videoUrl.startswith('/uploads/') %}
{{ ind }}if "{{ videoUrl }}".startswith('/uploads/'):
{{ ind }}    video_path = get_upload_file_path("{{ videoUrl }}")
{{ ind }}    video_url = FSInputFile(video_path)
{{ ind }}await bot.send_video(message.chat.id, video_url, caption=text, parse_mode=parse_mode)
{% else %}
{{ ind }}await bot.send_video(message.chat.id, "{{ videoUrl }}", caption=text, parse_mode=parse_mode)
{% endif %}
{% elif audioUrl %}
{% if audioUrl.startswith('/uploads/') %}
{{ ind }}if "{{ audioUrl }}".startswith('/uploads/'):
{{ ind }}    audio_path = get_upload_file_path("{{ audioUrl }}")
{{ ind }}    audio_url = FSInputFile(audio_path)
{{ ind }}await bot.send_audio(message.chat.id, audio_url, caption=text, parse_mode=parse_mode)
{% else %}
{{ ind }}await bot.send_audio(message.chat.id, "{{ audioUrl }}", caption=text, parse_mode=parse_mode)
{% endif %}
{% elif documentUrl %}
{% if documentUrl.startswith('/uploads/') %}
{{ ind }}if "{{ documentUrl }}".startswith('/uploads/'):
{{ ind }}    document_path = get_upload_file_path("{{ documentUrl }}")
{{ ind }}    document_url = FSInputFile(document_path)
{{ ind }}await bot.send_document(message.chat.id, document_url, caption=text, parse_mode=parse_mode)
{% else %}
{{ ind }}await bot.send_document(message.chat.id, "{{ documentUrl }}", caption=text, parse_mode=parse_mode)
{% endif %}
{% endif %}
