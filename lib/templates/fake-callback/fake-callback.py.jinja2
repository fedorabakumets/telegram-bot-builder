{#
  Шаблон создания fake_callback для автоперехода

  @param {string} targetNodeId    — ID целевого узла
  @param {string} sourceNodeId    — ID исходного узла
  @param {string} safeFunctionName — безопасное имя функции (без спецсимволов)
  @param {string} indentLevel     — базовый отступ (по умолчанию '    ')
#}
{% set ind = indentLevel or '    ' %}
{{ ind }}
{{ ind }}# ⚡ Автопереход к узлу {{ targetNodeId }}
{{ ind }}logging.info(f"⚡ Автопереход от узла {{ sourceNodeId }} к узлу {{ targetNodeId }}")
{{ ind }}async def noop(*args, **kwargs):
{{ ind }}    return None
{{ ind }}fake_message = SimpleNamespace(
{{ ind }}    chat=SimpleNamespace(id=message.from_user.id),
{{ ind }}    message_id=message.message_id,
{{ ind }}    delete=noop,
{{ ind }}    edit_text=noop,
{{ ind }}    answer=lambda text, **kwargs: bot.send_message(message.from_user.id, text, **kwargs)
{{ ind }})
{{ ind }}fake_callback = SimpleNamespace(
{{ ind }}    id="auto_transition",
{{ ind }}    from_user=message.from_user,
{{ ind }}    chat_instance="",
{{ ind }}    data="{{ targetNodeId }}",
{{ ind }}    message=fake_message,
{{ ind }}    answer=noop
{{ ind }})
{{ ind }}await handle_callback_{{ safeFunctionName }}(fake_callback)
