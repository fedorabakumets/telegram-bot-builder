# Middleware для фильтрации устаревших апдейтов
# Игнорирует сообщения старше MAX_UPDATE_AGE_SECONDS секунд (накопились пока бот был остановлен)
MAX_UPDATE_AGE_SECONDS = int(os.getenv("MAX_UPDATE_AGE_SECONDS", "300"))

async def stale_update_filter_middleware(handler, event: types.Message, data: dict):
    """Пропускает сообщения старше MAX_UPDATE_AGE_SECONDS секунд."""
    import time
    try:
        if event.date and (time.time() - event.date.timestamp()) > MAX_UPDATE_AGE_SECONDS:
            logging.info(
                f"⏭️ Пропущен устаревший апдейт от {event.from_user.id if event.from_user else '?'} "
                f"(возраст {int(time.time() - event.date.timestamp())}с > {MAX_UPDATE_AGE_SECONDS}с)"
            )
            return  # не передаём дальше
    except Exception:
        pass
    return await handler(event, data)

{% if autoRegisterUsers %}
# Middleware для автоматической регистрации пользователей
async def register_user_middleware(handler, event: types.Message, data: dict):
    """Автоматически инициализирует user_data при первом обращении пользователя"""
    try:
        user = event.from_user
        if user:
            user_id = user.id
            if user_id not in user_data:
                user_data[user_id] = {
                    'username': user.username or '',
                    'first_name': user.first_name or '',
                    'last_name': user.last_name or '',
                    'user_name': user.username or user.first_name or str(user_id),
                    'user_id': user_id,
                    'language_code': user.language_code or '',
                    'is_premium': user.is_premium or False,
                    'is_bot': user.is_bot or False,
                }
                logging.info(f"Новый пользователь зарегистрирован: {user_id}")
    except Exception as e:
        logging.error(f"Ошибка в register_user_middleware: {e}")

    return await handler(event, data)

{% endif %}

