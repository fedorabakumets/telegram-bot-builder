{#
  Функция сохранения сообщений в базу данных напрямую через asyncpg
#}

# Функция для сохранения сообщений в базу данных напрямую (без API)
async def save_message_to_api(user_id: str, message_type: str, message_text: str = None, node_id: str = None, message_data: dict = None):
    """Сохраняет сообщение в базу данных напрямую через asyncpg"""
    if not db_pool:
        return None
    try:
        async with db_pool.acquire() as conn:
            message_data_json = json.dumps(message_data or {}, ensure_ascii=False)
            result = await conn.fetchrow(
                """
                INSERT INTO bot_messages (project_id, user_id, message_type, message_text, node_id, message_data, created_at)
                VALUES ($1, $2, $3, $4, $5, $6, NOW())
                RETURNING id, user_id, message_type, created_at
                """,
                PROJECT_ID,
                str(user_id),
                message_type,
                message_text,
                node_id,
                message_data_json
            )
            tg_message_id = (message_data or {}).get("message_id")
            tg_mid_str = f", tg_message_id={tg_message_id}" if tg_message_id else ""
            logging.info(f"✅ Сообщение сохранено в БД: {message_type} от {user_id} (id={result['id']}{tg_mid_str})")
            return {"id": result['id'], "user_id": result['user_id'], "message_type": result['message_type'], "created_at": result['created_at']}
    except Exception as e:
        logging.error(f"❌ Ошибка сохранения сообщения в БД: {e}")
    return None


def _fire_save_message(user_id: str, message_type: str, message_text: str = None, node_id: str = None, message_data: dict = None):
    """Запускает save_message_to_api в фоне (fire-and-forget).
    Не блокирует выполнение — сообщение сохраняется асинхронно.

    @param user_id - Идентификатор пользователя
    @param message_type - Тип сообщения: "user" или "bot"
    @param message_text - Текст сообщения (опционально)
    @param node_id - Идентификатор узла сценария (опционально)
    @param message_data - Дополнительные данные сообщения (опционально)
    """
    try:
        asyncio.create_task(save_message_to_api(
            user_id=user_id,
            message_type=message_type,
            message_text=message_text,
            node_id=node_id,
            message_data=message_data,
        ))
    except Exception as e:
        logging.warning(f"⚠️ _fire_save_message: не удалось создать задачу: {e}")
