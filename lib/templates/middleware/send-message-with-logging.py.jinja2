{#
  Обёртка для bot.send_message с автоматическим логированием
  Использует closure вместо глобального monkey-patching
#}

def _wrap_bot_send_message(bot_instance):
    """Оборачивает bot.send_message для логирования — вызывается один раз при старте"""
    original_send_message = bot_instance.send_message

    async def send_message_with_logging(chat_id, text, *args, node_id=None, **kwargs):
        """Обёртка для bot.send_message с автоматическим сохранением и логированием"""
        result = await original_send_message(chat_id, text, *args, **kwargs)
        message_data_obj = {"message_id": result.message_id if result else None}
        if "reply_markup" in kwargs:
            try:
                reply_markup = kwargs["reply_markup"]
                buttons_data = []
                if hasattr(reply_markup, "inline_keyboard"):
                    for row in reply_markup.inline_keyboard:
                        for btn in row:
                            button_info = {"text": btn.text}
                            if hasattr(btn, "url") and btn.url:
                                button_info["url"] = btn.url
                            if hasattr(btn, "callback_data") and btn.callback_data:
                                button_info["callback_data"] = btn.callback_data
                            buttons_data.append(button_info)
                    if buttons_data:
                        message_data_obj["buttons"] = buttons_data
                        message_data_obj["keyboard_type"] = "inline"
                elif hasattr(reply_markup, "keyboard"):
                    for row in reply_markup.keyboard:
                        for btn in row:
                            button_info = {"text": btn.text}
                            if hasattr(btn, "request_contact") and btn.request_contact:
                                button_info["request_contact"] = True
                            if hasattr(btn, "request_location") and btn.request_location:
                                button_info["request_location"] = True
                            buttons_data.append(button_info)
                    if buttons_data:
                        message_data_obj["buttons"] = buttons_data
                        message_data_obj["keyboard_type"] = "reply"
            except Exception as e:
                logging.warning(f"Не удалось извлечь кнопки: {e}")
        # Сохраняем исходящее сообщение бота асинхронно (fire-and-forget)
        _fire_save_message(
            user_id=str(chat_id),
            message_type="bot",
            message_text=text,
            node_id=node_id,
            message_data=message_data_obj,
        )
        # Вызываем обработчики триггеров исходящих сообщений
        try:
            _omt_handlers = globals().get('_outgoing_message_trigger_handlers', [])
            if _omt_handlers:
                _omt_user_id = int(str(chat_id)) if str(chat_id).lstrip('-').isdigit() else 0
                if _omt_user_id > 0:
                    for _omt_handler in _omt_handlers:
                        try:
                            await _omt_handler(_omt_user_id, result.message_id if result else None, text, chat_id=_omt_user_id)
                        except Exception as _omt_e:
                            logging.warning(f"Ошибка в outgoing_message_trigger handler: {_omt_e}")
        except Exception as _omt_outer_e:
            logging.warning(f"Ошибка при вызове outgoing_message_trigger handlers: {_omt_outer_e}")
        return result

    bot_instance.send_message = send_message_with_logging



