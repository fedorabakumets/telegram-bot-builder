def _wrap_bot_send_media_group(bot_instance):
    """Оборачивает bot.send_media_group для вызова outgoing_message_trigger handlers"""
    original_send_media_group = bot_instance.send_media_group

    async def send_media_group_with_logging(chat_id, media, *args, node_id=None, **kwargs):
        """Обёртка для bot.send_media_group с поддержкой outgoing_message_trigger"""
        result = await original_send_media_group(chat_id, media, *args, **kwargs)
        # Вызываем обработчики триггеров исходящих сообщений
        # result — список сообщений, берём message_id первого
        try:
            _omt_handlers = globals().get('_outgoing_message_trigger_handlers', [])
            if _omt_handlers:
                _omt_user_id = int(str(chat_id)) if str(chat_id).lstrip('-').isdigit() else 0
                if _omt_user_id > 0:
                    _first_msg_id = result[0].message_id if result and len(result) > 0 else None
                    for _omt_handler in _omt_handlers:
                        try:
                            await _omt_handler(_omt_user_id, _first_msg_id, "[Медиагруппа]", chat_id=_omt_user_id)
                        except Exception as _omt_e:
                            logging.warning(f"Ошибка в outgoing_message_trigger handler: {_omt_e}")
        except Exception as _omt_outer_e:
            logging.warning(f"Ошибка при вызове outgoing_message_trigger handlers: {_omt_outer_e}")
        return result

    bot_instance.send_media_group = send_media_group_with_logging
