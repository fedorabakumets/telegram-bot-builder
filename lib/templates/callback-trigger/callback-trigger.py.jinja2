{#
  Шаблон обработчиков триггеров inline-кнопок

  @param {array} callbackTriggerEntries - Массив CallbackTriggerEntry:
    - nodeId: string          — ID узла callback_trigger
    - callbackData: string    — значение callback_data для перехвата
    - matchType: string       — режим совпадения: "exact" или "startswith"
    - targetNodeId: string    — ID целевого узла
    - targetNodeType: string  — тип целевого узла
    - adminOnly: bool         — только администраторы
    - requiresAuth: bool      — требуется авторизация
    - buttonText: string      — текст кнопки, найденный по callbackData
#}

# Обработчики триггеров inline-кнопок
{% for entry in callbackTriggerEntries -%}
{%- set sanitized_node_id = entry.nodeId | safe_name -%}
{%- set sanitized_target_id = entry.targetNodeId | safe_name -%}

{% if entry.matchType == 'startswith' -%}
@dp.callback_query(lambda c: c.data and c.data.startswith("{{ entry.callbackData }}"))
{%- else -%}
@dp.callback_query(lambda c: c.data == "{{ entry.callbackData }}")
{%- endif %}
async def callback_trigger_{{ sanitized_node_id }}_handler(callback_query: types.CallbackQuery):
    user_id = callback_query.from_user.id
    logging.info(f"Пользователь {user_id} нажал кнопку '{{ entry.callbackData }}' — триггер узла {{ entry.nodeId }}")
    {%- if entry.adminOnly %}
    if not await is_admin(user_id):
        await callback_query.answer("❌ У вас нет прав для выполнения этого действия")
        return
    {%- endif %}
    {%- if entry.requiresAuth %}
    if not await check_auth(user_id):
        await callback_query.answer("❌ Сначала запустите бота: /start")
        return
    {%- endif %}

    class MockCallback:
        def __init__(self, data, user, msg):
            self.data = data
            self._is_fake = True
            self.from_user = user
            self.message = msg

        async def answer(self, *args, **kwargs):
            pass

        async def edit_text(self, text, **kwargs):
            try:
                return await self.message.edit_text(text, **kwargs)
            except Exception as e:
                logging.warning(f"Не удалось отредактировать сообщение: {e}")
                return await self.message.answer(text, **kwargs)

    # Сохраняем данные нажатой кнопки для использования в переменных {callback_data} и {button_text}
    if user_id not in user_data:
        user_data[user_id] = {}
    user_data[user_id]["callback_data"] = callback_query.data or "{{ entry.callbackData }}"
    # Читаем текст кнопки из reply_markup сообщения — Telegram хранит его там
    _cb_btn_text = ""
    try:
        _cb_data = callback_query.data or "{{ entry.callbackData }}"
        if callback_query.message and hasattr(callback_query.message, "reply_markup"):
            _rm = callback_query.message.reply_markup
            if _rm and hasattr(_rm, "inline_keyboard"):
                for _row in _rm.inline_keyboard:
                    for _btn in _row:
                        if getattr(_btn, "callback_data", None) == _cb_data:
                            _cb_btn_text = _btn.text or ""
                            break
                    if _cb_btn_text:
                        break
    except Exception:
        pass
    # Fallback: используем статичный текст кнопки из проекта если не нашли в reply_markup
    user_data[user_id]["button_text"] = _cb_btn_text or "{{ entry.buttonText or entry.callbackData }}"

    mock_callback = MockCallback("{{ entry.targetNodeId }}", callback_query.from_user, callback_query.message)
    await handle_callback_{{ sanitized_target_id }}(mock_callback)

{% endfor %}
