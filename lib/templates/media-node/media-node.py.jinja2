{#
  Шаблон обработчика медиа-ноды

  @fileoverview Генерирует Python-код для отправки медиафайлов из массива attachedMedia.
  Поддерживает одиночную отправку и медиагруппы, FSInputFile для /uploads/ путей,
  автопереход и логирование.

  @param {string}   nodeId               - уникальный идентификатор узла
  @param {array}    attachedMedia        - массив URL медиафайлов
  @param {boolean}  enableAutoTransition - включить автопереход
  @param {string}   autoTransitionTo     - ID целевого узла автоперехода
#}

{#- Макрос: определяет тип медиа по расширению URL -#}
{%- macro get_media_type(url) -%}
{%- set u = url | lower -%}
{%- if '.jpg' in u or '.jpeg' in u or '.png' in u or '.gif' in u or '.webp' in u -%}photo
{%- elif '.mp4' in u or '.avi' in u or '.mov' in u -%}video
{%- elif '.mp3' in u or '.wav' in u or '.ogg' in u -%}audio
{%- else -%}document
{%- endif -%}
{%- endmacro -%}

{#- Макрос: определяет класс InputMedia по расширению URL -#}
{%- macro get_input_media_class(url) -%}
{%- set u = url | lower -%}
{%- if '.jpg' in u or '.jpeg' in u or '.png' in u or '.gif' in u or '.webp' in u -%}InputMediaPhoto
{%- elif '.mp4' in u or '.avi' in u or '.mov' in u -%}InputMediaVideo
{%- elif '.mp3' in u or '.wav' in u or '.ogg' in u -%}InputMediaAudio
{%- else -%}InputMediaDocument
{%- endif -%}
{%- endmacro -%}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ nodeId|safe_name }}(callback_query: types.CallbackQuery):
    """Обработчик медиа-ноды для узла {{ nodeId }}"""
    is_fake_callback = getattr(callback_query, '_is_fake', False)
    logging.info(f"Медиа-нода {{ nodeId }}: отправка медиафайлов")

{%- if attachedMedia and attachedMedia | length == 1 %}
{%- set url = attachedMedia[0] %}
{%- if '{' in url and '}' in url %}
    # Отправка медиа из пользовательской переменной
    user_id = callback_query.from_user.id
    all_user_vars = await init_all_user_vars(user_id)
    _raw_media_ref = "{{ url|e }}"
    _resolved_media = _raw_media_ref
    _resolved_media_type = "document"
    _has_resolved_media = False

    if _raw_media_ref.startswith("{") and _raw_media_ref.endswith("}"):
        _media_var_name = _raw_media_ref[1:-1]
        _media_value = all_user_vars.get(_media_var_name)
        if isinstance(_media_value, dict):
            _resolved_media_type = _media_value.get("type", "document")
            _resolved_media = (
                _media_value.get("photoUrl")
                or _media_value.get("videoUrl")
                or _media_value.get("audioUrl")
                or _media_value.get("documentUrl")
                or _media_value.get("value")
                or _raw_media_ref
            )
            _has_resolved_media = _resolved_media != _raw_media_ref
        elif _media_value:
            _resolved_media = _media_value
            _media_name = _media_var_name.lower()
            if "photo" in _media_name:
                _resolved_media_type = "photo"
            elif "video" in _media_name:
                _resolved_media_type = "video"
            elif "audio" in _media_name or "voice" in _media_name:
                _resolved_media_type = "audio"
            _has_resolved_media = True
    else:
        _has_resolved_media = True

    if not _has_resolved_media:
        logging.warning(f"Медиа-переменная {_raw_media_ref} не заполнена для узла {{ nodeId }}")
        return

    if _resolved_media_type == "photo":
        await callback_query.message.answer_photo(_resolved_media)
    elif _resolved_media_type == "video":
        await callback_query.message.answer_video(_resolved_media)
    elif _resolved_media_type == "audio":
        await callback_query.message.answer_audio(_resolved_media)
    else:
        await callback_query.message.answer_document(_resolved_media)
{%- else %}
{%- set mtype = get_media_type(url) | trim %}
    # Отправка одиночного медиафайла
{%- if '/uploads/' in url %}
    _file_path = get_upload_file_path("{{ url }}")
    _media_file = FSInputFile(_file_path)
    await callback_query.message.answer_{{ mtype }}(_media_file)
{%- else %}
    await callback_query.message.answer_{{ mtype }}("{{ url|e }}")
{%- endif %}
{%- endif %}

{%- elif attachedMedia and attachedMedia | length > 1 %}
    # Отправка медиагруппы
    _media_group = [
{%- for url in attachedMedia %}
{%- set cls = get_input_media_class(url) | trim %}
{%- if '/uploads/' in url %}
        {{ cls }}(media=FSInputFile(get_upload_file_path("{{ url }}"))),
{%- else %}
        {{ cls }}(media="{{ url|e }}"),
{%- endif %}
{%- endfor %}
    ]
    await callback_query.message.answer_media_group(_media_group)

{%- else %}
    # Нет медиафайлов для отправки
    pass

{%- endif %}

{%- if enableAutoTransition and autoTransitionTo %}
    # Автопереход к следующему узлу
    logging.info(f"Автопереход от узла {{ nodeId }} к узлу {{ autoTransitionTo }}")
    fake_cb = FakeCallbackQuery(callback_query.message, "{{ autoTransitionTo }}")
    await handle_callback_{{ autoTransitionTo|safe_name }}(fake_cb)
{%- endif %}
