{#
  Шаблон обработчиков действия edit_message.
  Редактирует текст или клавиатуру уже отправленного сообщения.

  @param {array} entries - Массив EditMessageEntry:
    - nodeId: string              — ID узла
    - targetNodeId: string        — ID следующего узла
    - editMode: string            — 'text' | 'markup' | 'both'
    - editMessageText: string     — новый текст (поддерживает {var})
    - editFormatMode: string      — 'html' | 'markdown' | 'none'
    - editMessageIdSource: string — 'last_bot_message' | 'custom'
    - editMessageIdManual: string — ID или {переменная}
    - editKeyboardMode: string    — 'keep' | 'remove' | 'node'
    - editKeyboardNodeId: string  — ID keyboard-узла
#}

# Обработчики узлов edit_message
{% for entry in entries -%}
{%- set sanitized_node_id = entry.nodeId | safe_name -%}
{%- set sanitized_target_id = entry.targetNodeId | safe_name -%}

@dp.callback_query(lambda c: c.data == "{{ entry.nodeId }}")
async def handle_callback_{{ sanitized_node_id }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Редактирование сообщения"""
    try:
        user_id = callback_query.from_user.id
        logging.info(f"✏️ edit_message узел {{ entry.nodeId }} для пользователя {user_id}")

        {% if entry.editMessageIdSource == 'last_bot_message' %}
        _msg_id = user_data.get(user_id, {}).get('last_bot_message_id')
        {% else %}
        _all_vars = await init_all_user_vars(user_id)
        {%- set _raw = entry.editMessageIdManual | trim %}
        {%- if _raw | int(-1) != -1 %}
        _msg_id = {{ _raw | int }}
        {%- elif '{' in _raw %}
        _msg_id_raw = {{ _raw | format_python_text }}
        _msg_id_str = replace_variables_in_text(_msg_id_raw, _all_vars, {})
        try:
            _msg_id = int(_msg_id_str)
        except (ValueError, TypeError):
            _msg_id = _msg_id_str
        {%- else %}
        _msg_id_str = str(_all_vars.get("{{ _raw }}", ""))
        try:
            _msg_id = int(_msg_id_str)
        except (ValueError, TypeError):
            _msg_id = None
            logging.warning(f"edit_message: не удалось получить message_id из переменной '{{ _raw }}' для пользователя {user_id}")
        {%- endif %}
        {% endif %}

        _chat_id = callback_query.message.chat.id

        {% if entry.editMode in ['text', 'both'] %}
        _all_vars = await init_all_user_vars(user_id)
        _new_text = replace_variables_in_text({{ entry.editMessageText | format_python_text }}, _all_vars, {})
        {% if entry.editFormatMode == 'html' %}
        await bot.edit_message_text(chat_id=_chat_id, message_id=_msg_id, text=_new_text, parse_mode="HTML")
        {% elif entry.editFormatMode == 'markdown' %}
        await bot.edit_message_text(chat_id=_chat_id, message_id=_msg_id, text=_new_text, parse_mode="Markdown")
        {% else %}
        await bot.edit_message_text(chat_id=_chat_id, message_id=_msg_id, text=_new_text)
        {% endif %}
        {% endif %}

        {% if entry.editMode in ['markup', 'both'] %}
        {% if entry.editKeyboardMode == 'remove' %}
        await bot.edit_message_reply_markup(chat_id=_chat_id, message_id=_msg_id, reply_markup=None)
        {% elif entry.editKeyboardMode == 'node' %}
        # Строим клавиатуру из keyboard-узла {{ entry.editKeyboardNodeId }}
        _all_vars = await init_all_user_vars(user_id)
        _edit_builder = InlineKeyboardBuilder()
        {% if entry.keyboardEnableDynamicButtons and entry.keyboardDynamicButtons %}
        import json as _json_edit
        _edit_source = _all_vars.get("{{ entry.keyboardDynamicButtons.sourceVariable }}")
        if isinstance(_edit_source, str):
            try:
                _edit_source = _json_edit.loads(_edit_source)
            except Exception:
                _edit_source = None
        _edit_items = []
        if isinstance(_edit_source, dict):
            _edit_items = _edit_source.get("{{ entry.keyboardDynamicButtons.arrayPath }}", []) if "{{ entry.keyboardDynamicButtons.arrayPath }}" else _edit_source
        elif isinstance(_edit_source, list):
            _edit_items = _edit_source
        for _edit_item in _edit_items:
            if not isinstance(_edit_item, dict):
                continue
            _edit_text = replace_variables_in_text("{{ entry.keyboardDynamicButtons.textTemplate }}", _edit_item, {})
            _edit_cb = replace_variables_in_text("{{ entry.keyboardDynamicButtons.callbackTemplate }}", _edit_item, {})
            if _edit_text and _edit_cb:
                _edit_builder.add(InlineKeyboardButton(text=_edit_text, callback_data=_edit_cb[:64]))
        _edit_builder.adjust({{ entry.keyboardDynamicButtons.columns }})
        {% endif %}
        {% for btn in entry.keyboardButtons %}
        {% if btn.action == 'url' %}
        _edit_builder.add(InlineKeyboardButton(text=replace_variables_in_text({{ btn.text | format_python_text }}, _all_vars, {}), url="{{ btn.url or '#' }}"{% if btn.style %}, style="{{ btn.style }}"{% endif %}))
        {% elif btn.action == 'goto' or btn.action == 'complete' %}
        _edit_builder.add(InlineKeyboardButton(text=replace_variables_in_text({{ btn.text | format_python_text }}, _all_vars, {}), callback_data={% if btn.customCallbackData and '{' in btn.customCallbackData %}replace_variables_in_text("{{ btn.customCallbackData }}", _all_vars, {}){% else %}"{{ btn.customCallbackData or btn.target or btn.id or 'btn' }}"{% endif %}{% if btn.style %}, style="{{ btn.style }}"{% endif %}))
        {% else %}
        _edit_builder.add(InlineKeyboardButton(text=replace_variables_in_text({{ btn.text | format_python_text }}, _all_vars, {}), callback_data="{{ btn.id or 'btn' }}"{% if btn.style %}, style="{{ btn.style }}"{% endif %}))
        {% endif %}
        {% endfor %}
        _edit_keyboard = _edit_builder.as_markup()
        await bot.edit_message_reply_markup(chat_id=_chat_id, message_id=_msg_id, reply_markup=_edit_keyboard)
        {% else %}
        await bot.edit_message_reply_markup(chat_id=_chat_id, message_id=_msg_id, reply_markup=None)
        {% endif %}
        {% endif %}

        {% if entry.targetNodeId %}
        await handle_callback_{{ sanitized_target_id }}(callback_query, state=None)
        {% endif %}
    except Exception as e:
        logging.error(f"Ошибка в edit_message {{ entry.nodeId }}: {e}")

{% endfor %}
