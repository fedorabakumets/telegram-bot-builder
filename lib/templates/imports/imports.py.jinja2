{#
  Шаблон импортов для Python бота

  @fileoverview Генерирует все необходимые импорты для aiogram бота
  @param {boolean} userDatabaseEnabled - Включена ли база данных пользователей (asyncpg, json)
  @param {boolean} hasInlineButtons - Есть ли inline кнопки (нужен TelegramBadRequest)
  @param {boolean} hasAutoTransitions - Есть ли автопереходы (нужен TelegramBadRequest)
  @param {boolean} hasMediaNodes - Есть ли узлы с медиа (нужен aiohttp)
  @param {boolean} hasUploadImages - Есть ли ссылки на /uploads/ (нужен aiohttp)
  @param {boolean} hasParseModeNodes - Есть ли узлы с HTML/Markdown форматированием (нужен ParseMode)
  @param {boolean} hasMediaGroups - Есть ли узлы с группами медиа (нужны InputMedia*)
  @param {boolean} hasUrlImages - Есть ли узлы с URL изображениями (нужен URLInputFile)
  @param {boolean} hasDatetimeNodes - Есть ли узлы требующие datetime
  @param {boolean} hasTimezoneNodes - Есть ли узлы требующие timezone
#}

import asyncio
import logging
import signal

from aiogram import Bot, Dispatcher, types, F
from aiogram.types import (
    KeyboardButton,
    InlineKeyboardButton,
    InlineKeyboardMarkup,
    BotCommand,
    ReplyKeyboardRemove,
    FSInputFile
)
from aiogram.utils.keyboard import ReplyKeyboardBuilder, InlineKeyboardBuilder
from typing import Optional

from dotenv import load_dotenv
from aiogram.filters import CommandStart, Command

{%- if userDatabaseEnabled %}

import asyncpg
import json
{%- endif %}

{%- if hasInlineButtons or hasAutoTransitions %}
from aiogram.exceptions import TelegramBadRequest
{%- endif %}

{%- if hasMediaNodes or hasUploadImages %}
import aiohttp
from aiohttp import TCPConnector
{%- endif %}

{%- if hasParseModeNodes %}
from aiogram.enums import ParseMode
{%- endif %}

{%- if hasMediaGroups %}
from aiogram.types import InputMediaPhoto, InputMediaVideo, InputMediaAudio, InputMediaDocument
{%- endif %}

{%- if hasUrlImages %}
from aiogram.types import URLInputFile
{%- endif %}

{%- if hasDatetimeNodes or userDatabaseEnabled %}
from datetime import datetime{%- if hasTimezoneNodes %}, timezone{%- endif %}
{%- endif %}

import re
from types import SimpleNamespace
