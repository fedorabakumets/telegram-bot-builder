{#
  Шаблон обработчика узла userbot_message

  @fileoverview Генерирует Python код для отправки сообщения через Telethon userbot.
  Использует get_content для горячей перезагрузки текста из таблицы _content.
  Поддерживает: текст, медиа (локальные файлы и URL), переменные, автопереход.

  @param {string} nodeId - ID узла
  @param {string} messageText - Текст сообщения
  @param {string} formatMode - Режим форматирования: 'html', 'markdown', 'none'
  @param {boolean} disableLinkPreview - Отключить превью ссылок
  @param {string} userbotEntity - Entity получателя
  @param {array} attachedMedia - Прикреплённые медиафайлы
  @param {string} saveMessageIdTo - Переменная для сохранения ID сообщения
  @param {string} autoTransitionTo - ID узла для автоперехода
  @param {number|null} projectId - ID проекта (для get_content)
#}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ nodeId|replace('-', '_') }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Обработчик узла {{ nodeId }} — отправка через userbot"""
    user_id = callback_query.from_user.id
    logging.info(f"🟣 Userbot-сообщение: узел {{ nodeId }} для пользователя {user_id}")

    # Отвечаем на callback
    try:
        await callback_query.answer()
    except Exception:
        pass

    # Инициализируем переменные пользователя
    if user_id not in user_data:
        user_data[user_id] = {}

    # Текст сообщения с поддержкой get_content
{%- if projectId %}
    text = get_content("{{ nodeId }}", {{ messageText|format_python_text }})
{%- else %}
    text = {{ messageText|format_python_text }}
{%- endif %}

    # Подстановка переменных
    all_user_vars = await init_all_user_vars(user_id)
    if state is not None:
        try:
            _fsm_d = await state.get_data()
            if _fsm_d:
                all_user_vars.update(_fsm_d)
        except Exception:
            pass
    text = replace_variables_in_text(text, all_user_vars, {})

    # Резолвим entity получателя
{%- if userbotRecipients and userbotRecipients|length > 0 %}
    _recipients = [
{%- for r in userbotRecipients %}
        replace_variables_in_text({% if projectId %}get_content("{{ nodeId }}.entity.{{ loop.index0 }}", {{ r|format_python_text }}){% else %}{{ r|format_python_text }}{% endif %}, all_user_vars, {}),
{%- endfor %}
    ]
    _recipients = [r for r in _recipients if r]
{%- else %}
{%- if projectId %}
    _entity_raw = get_content("{{ nodeId }}.entity", {{ userbotEntity|format_python_text }})
{%- else %}
    _entity_raw = {{ userbotEntity|format_python_text }}
{%- endif %}
    _recipients = [replace_variables_in_text(_entity_raw, all_user_vars, {})]
    _recipients = [r for r in _recipients if r]
{%- endif %}

    if not _recipients:
        logging.error(f"❌ Узел {{ nodeId }}: нет получателей")
        return

    # Определяем parse_mode
{%- if formatMode == 'html' %}
    _parse_mode = 'html'
{%- elif formatMode == 'markdown' %}
    _parse_mode = 'md'
{%- else %}
    _parse_mode = None
{%- endif %}

    # Отправка сообщения через userbot
    sent = None
    for _entity in _recipients:
      try:
        # Резолвим entity (число или строка)
        _target = int(_entity) if _entity.lstrip('-').isdigit() else _entity

{%- if attachedMedia and attachedMedia|length > 0 %}
{%- if attachedMedia|length == 1 %}
{%- set mediaItem = attachedMedia[0] %}
{%- if '{' in mediaItem and '}' in mediaItem %}
        # Медиа из переменной
        _media_val = replace_variables_in_text("{{ mediaItem }}", all_user_vars, {})
        if _media_val and _media_val != "{{ mediaItem }}":
{%- if '/uploads/' in mediaItem %}
            _media_path = get_upload_file_path(_media_val)
            if os.path.exists(_media_path):
                sent = await userbot_client.send_file(_target, _media_path, caption=text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
            else:
                logging.error(f"❌ Файл не найден: {_media_path}")
                sent = await userbot_client.send_message(_target, text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- else %}
            sent = await userbot_client.send_file(_target, _media_val, caption=text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- endif %}
        else:
            sent = await userbot_client.send_message(_target, text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- elif '/uploads/' in mediaItem %}
        # Локальный файл
        _media_path = get_upload_file_path("{{ mediaItem }}")
        if os.path.exists(_media_path):
            sent = await userbot_client.send_file(_target, _media_path, caption=text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
        else:
            logging.error(f"❌ Файл не найден: {_media_path}")
            sent = await userbot_client.send_message(_target, text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- elif 'http' in mediaItem %}
        # URL медиа
        sent = await userbot_client.send_file(_target, "{{ mediaItem }}", caption=text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- else %}
        sent = await userbot_client.send_message(_target, text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- endif %}
{%- else %}
        # Альбом (несколько файлов)
        _album_files = []
{%- for mediaItem in attachedMedia %}
{%- if '/uploads/' in mediaItem %}
        _fp_{{ loop.index }} = get_upload_file_path("{{ mediaItem }}")
        if os.path.exists(_fp_{{ loop.index }}):
            _album_files.append(_fp_{{ loop.index }})
{%- elif 'http' in mediaItem %}
        _album_files.append("{{ mediaItem }}")
{%- endif %}
{%- endfor %}
        if _album_files:
            sent_list = await userbot_client.send_file(_target, _album_files, caption=text, parse_mode=_parse_mode)
            sent = sent_list[0] if isinstance(sent_list, list) and sent_list else sent_list
        else:
            sent = await userbot_client.send_message(_target, text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- endif %}
{%- else %}
        # Только текст
        sent = await userbot_client.send_message(_target, text, parse_mode=_parse_mode, link_preview={{ 'False' if disableLinkPreview else 'True' }})
{%- endif %}

        logging.info(f"✅ Userbot отправил сообщение в {_entity} (узел {{ nodeId }})")

      except Exception as _ub_err:
        logging.error(f"❌ Ошибка отправки через userbot (узел {{ nodeId }}) → {_entity}: {_ub_err}")
        # FloodWait — ждём и пробуем снова
        if "FloodWaitError" in type(_ub_err).__name__ or "flood" in str(_ub_err).lower():
            _wait = getattr(_ub_err, 'seconds', 30)
            logging.warning(f"⏳ FloodWait: ждём {_wait} секунд")
            await asyncio.sleep(_wait)
            try:
                sent = await userbot_client.send_message(_target, text, parse_mode=_parse_mode)
            except Exception as _retry_err:
                logging.error(f"❌ Повторная ошибка: {_retry_err}")

      # Пауза между получателями (защита от FloodWait)
      if len(_recipients) > 1:
          await asyncio.sleep(2)

{%- if saveMessageIdTo %}
    # Сохраняем ID отправленного сообщения
    if sent and hasattr(sent, 'id'):
        user_data[user_id]["{{ saveMessageIdTo }}"] = sent.id
        await set_user_var(user_id, "{{ saveMessageIdTo }}", sent.id)
        logging.info(f"💾 ID сообщения сохранён: {{ saveMessageIdTo }} = {sent.id}")
{%- endif %}

{%- if saveResponseIdTo %}
    # Ждём ответ от получателя через event listener
    logging.info(f"⏳ [{{ nodeId }}] Ожидание ответа: {{ responseWaitSeconds | default(3) }} сек, стратегия: {{ responseStrategy | default('longest') }}")
    _resp_target = _recipients[0] if _recipients else _target
    _resp_entity = int(_resp_target) if str(_resp_target).lstrip('-').isdigit() else _resp_target
    _resp_msg = None
    _my_id = (await userbot_client.get_me()).id
    _sent_id = sent.id if sent and hasattr(sent, 'id') else 0
    _floor_id = _sent_id
{%- if responseFloorMessageIdVar %}
    try:
        _floor_raw = all_user_vars.get("{{ responseFloorMessageIdVar }}")
        if _floor_raw is None:
            _floor_raw = user_data.get(user_id, {}).get("{{ responseFloorMessageIdVar }}")
        if _floor_raw is not None and str(_floor_raw).strip().lstrip('-').isdigit():
            _floor_candidate = int(_floor_raw)
            if _floor_candidate > 0:
                _floor_id = min(_sent_id, _floor_candidate)
    except Exception:
        _floor_id = _sent_id
{%- endif %}

{%- if responseStrategy == 'regex_match' and responseFilterRegex %}
    # regex_match: события + Future (как longest), сразу история после send (гонка с быстрым ответом)
    import re as _re_resp
    import time as _time_resp
    _resp_re = {{ responseFilterRegex | tojson }}
    _resp_collected = {}
    _resp_wait_sec = {{ responseWaitSeconds | default(3) }}
    _resp_future = asyncio.get_event_loop().create_future()
    _resp_best_len = 0

    def _resp_accept_{{ nodeId | replace('-', '_') }}(msg):
        """Проверяет, подходит ли сообщение: новое после send или edit в диапазоне floor..sent."""
        if not msg:
            return False
        _mid = msg.id
        if _mid > _sent_id:
            return True
        if _floor_id <= _mid <= _sent_id:
            _txt = msg.text or ''
            return bool(_txt and _re_resp.search(_resp_re, _txt))
        return False

    def _resp_track_{{ nodeId | replace('-', '_') }}(msg):
        """Новое сообщение после send или edit меню в диапазоне floor..sent."""
        if not msg or getattr(msg, 'sender_id', None) == _my_id:
            return
        if _resp_accept_{{ nodeId | replace('-', '_') }}(msg):
            _resp_collected[msg.id] = msg

    async def _resp_pull_history_{{ nodeId | replace('-', '_') }}():
        """Подтягивает свежие сообщения бота из истории чата."""
        try:
            _resp_msgs = await userbot_client.get_messages(_resp_entity, limit=8)
            _resp_list = _resp_msgs if isinstance(_resp_msgs, list) else [_resp_msgs]
            for _bm in _resp_list:
                if not _bm or not hasattr(_bm, 'sender_id') or _bm.sender_id == _my_id:
                    continue
                if _resp_accept_{{ nodeId | replace('-', '_') }}(_bm):
                    _resp_collected[_bm.id] = _bm
        except Exception as _hist_err:
            logging.warning(f"⚠️ [{{ nodeId }}] История ответов: {_hist_err}")
        for _rid in list(_resp_collected.keys()):
            try:
                _rf = await userbot_client.get_messages(_resp_entity, ids=_rid)
                _rfm = _rf[0] if isinstance(_rf, list) and _rf else _rf
                if _rfm:
                    _resp_collected[_rid] = _rfm
            except Exception:
                pass

    def _resp_pick_{{ nodeId | replace('-', '_') }}():
        """Выбирает лучшее сообщение: приоритет свежим (id > sent), затем edit; среди regex — самое новое."""
        _pick_msg = None
        _pick_len = 0
        _resp_sorted = sorted(_resp_collected.values(), key=lambda m: m.id)
        _fresh = [m for m in _resp_sorted if m.id > _sent_id]
        _edit_pool = [m for m in _resp_sorted if _floor_id <= m.id <= _sent_id]
        _pool = _fresh if _fresh else _edit_pool
        for _bm in _pool:
            _txt = _bm.text or ''
            if _txt and 'Информация по заявке' in _txt:
                return _bm, len(_txt)
        _best_id = -1
        for _bm in _pool:
            _txt = _bm.text or ''
            if _txt and _re_resp.search(_resp_re, _txt):
                if _bm.id > _best_id or (_bm.id == _best_id and len(_txt) > _pick_len):
                    _best_id = _bm.id
                    _pick_len = len(_txt)
                    _pick_msg = _bm
        if _pick_msg:
            return _pick_msg, _pick_len
        # Inline-кнопка: текст кнопки совпадает с regex (GIF/медиа без подписи)
        _btn_best_id = -1
        for _bm in _pool:
            if not getattr(_bm, 'reply_markup', None):
                continue
            for _row in _bm.reply_markup.rows:
                for _btn in _row.buttons:
                    _bl = getattr(_btn, 'text', '') or ''
                    if _bl and _re_resp.search(_resp_re, _bl):
                        if _bm.id > _btn_best_id:
                            _btn_best_id = _bm.id
                            _pick_msg = _bm
                            _pick_len = len(_bl)
        if _pick_msg:
            return _pick_msg, _pick_len
        if len(_pool) >= 2:
            _cand = _pool[-2]
            return _cand, len(_cand.text or '')
        return _pick_msg, _pick_len

    def _resp_try_finish_{{ nodeId | replace('-', '_') }}():
        """Завершает ожидание, если в буфере есть подходящее сообщение."""
        nonlocal _resp_best_len
        _pick_msg, _pick_len = _resp_pick_{{ nodeId | replace('-', '_') }}()
        if _pick_msg and not _resp_future.done():
            _resp_best_len = _pick_len
            _resp_future.set_result(_pick_msg)

    @userbot_client.on(events.NewMessage(chats=_resp_entity))
    async def _on_resp_{{ nodeId | replace('-', '_') }}(event):
        _resp_track_{{ nodeId | replace('-', '_') }}(event.message)
        _resp_try_finish_{{ nodeId | replace('-', '_') }}()

    @userbot_client.on(events.MessageEdited(chats=_resp_entity))
    async def _on_resp_edit_{{ nodeId | replace('-', '_') }}(event):
        _resp_track_{{ nodeId | replace('-', '_') }}(event.message)
        _resp_try_finish_{{ nodeId | replace('-', '_') }}()

    try:
        _resp_t0 = _time_resp.monotonic()
        # Ответ мог прийти до подключения handlers — сразу читаем историю
        await _resp_pull_history_{{ nodeId | replace('-', '_') }}()
        _resp_try_finish_{{ nodeId | replace('-', '_') }}()
        if not _resp_future.done():
            try:
                _resp_msg = await asyncio.wait_for(_resp_future, timeout=_resp_wait_sec)
                logging.info(
                    f"📨 [{{ nodeId }}] regex_match (event) за {_time_resp.monotonic() - _resp_t0:.1f} сек, "
                    f"собрано {len(_resp_collected)}"
                )
            except asyncio.TimeoutError:
                await _resp_pull_history_{{ nodeId | replace('-', '_') }}()
                _resp_msg, _resp_best_len = _resp_pick_{{ nodeId | replace('-', '_') }}()
                logging.info(
                    f"📨 [{{ nodeId }}] regex_match (fallback) за {_time_resp.monotonic() - _resp_t0:.1f} сек: "
                    f"{len(_resp_collected)}"
                )
        else:
            _resp_msg = _resp_future.result()
        if _resp_msg:
            logging.info(f"📨 [{{ nodeId }}] Выбран ответ regex_match id={_resp_msg.id} len={_resp_best_len}")
        else:
            logging.warning(f"⚠️ [{{ nodeId }}] Нет ответа по regex {_resp_re!r}")
    finally:
        userbot_client.remove_event_handler(_on_resp_{{ nodeId | replace('-', '_') }})
        userbot_client.remove_event_handler(_on_resp_edit_{{ nodeId | replace('-', '_') }})
{%- elif responseStrategy == 'last' %}
    # last: собираем все сообщения за responseWaitSeconds, берём последнее по ID
    _resp_collected_msgs = []

    @userbot_client.on(events.NewMessage(chats=_resp_entity))
    async def _on_resp_{{ nodeId | replace('-', '_') }}(event):
        if event.message.id > _sent_id and event.sender_id != _my_id:
            _resp_collected_msgs.append(event.message)
            logging.info(f"📨 [{{ nodeId }}] event NewMessage id={event.message.id} text={(event.message.text or '')[:80]!r}")

    try:
        await asyncio.sleep({{ responseWaitSeconds | default(3) }})
        _resp_msg = _resp_collected_msgs[-1] if _resp_collected_msgs else None
        if not _resp_msg:
            # Fallback: читаем историю
            _resp_msgs = await userbot_client.get_messages(_resp_entity, limit=5)
            _resp_list = _resp_msgs if isinstance(_resp_msgs, list) else [_resp_msgs]
            _bot_msgs = [m for m in _resp_list if m and hasattr(m, 'sender_id') and m.sender_id != _my_id and m.id > _sent_id]
            _resp_msg = _bot_msgs[-1] if _bot_msgs else None
            logging.info(f"📨 [{{ nodeId }}] last fallback: {len(_bot_msgs)} msgs, выбрано id={_resp_msg.id if _resp_msg else None}")
        else:
            logging.info(f"📨 [{{ nodeId }}] last: собрано {len(_resp_collected_msgs)} за {{ responseWaitSeconds | default(3) }}с, выбрано id={_resp_msg.id}")
    finally:
        userbot_client.remove_event_handler(_on_resp_{{ nodeId | replace('-', '_') }})
{%- else %}
    # Event listener для нового сообщения (first/longest)
    _resp_future = asyncio.get_event_loop().create_future()

    @userbot_client.on(events.NewMessage(chats=_resp_entity))
    async def _on_resp_{{ nodeId | replace('-', '_') }}(event):
        if event.message.id > _sent_id and event.sender_id != _my_id and not _resp_future.done():
            logging.info(f"📨 [{{ nodeId }}] event NewMessage id={event.message.id} text={( event.message.text or '')[:80]!r}")
            _resp_future.set_result(event.message)

    try:
        _resp_msg = await asyncio.wait_for(_resp_future, timeout={{ responseWaitSeconds | default(3) }})
        logging.info(f"📨 [{{ nodeId }}] Получен ответ через event за <{{ responseWaitSeconds | default(3) }} сек, id={_resp_msg.id}")
    except asyncio.TimeoutError:
        logging.info(f"📨 [{{ nodeId }}] Таймаут event listener, читаем историю")
        # Fallback: читаем последние сообщения
        try:
            _resp_msgs = await userbot_client.get_messages(_resp_entity, limit=5)
            _resp_list = _resp_msgs if isinstance(_resp_msgs, list) else [_resp_msgs]
            _bot_msgs = [m for m in _resp_list if m and hasattr(m, 'sender_id') and m.sender_id != _my_id and m.id > _sent_id]
            logging.info(f"📨 [{{ nodeId }}] fallback: {len(_bot_msgs)} сообщений бота после id={_sent_id}, стратегия={{ responseStrategy | default('longest') }}")
            for _dbg_m in _bot_msgs[:5]:
                logging.info(f"📨 [{{ nodeId }}] fallback msg id={_dbg_m.id} text={(_dbg_m.text or '')[:60]!r} has_markup={bool(getattr(_dbg_m, 'reply_markup', None))}")
{%- if responseStrategy == 'first' %}
            _resp_msg = _bot_msgs[0] if _bot_msgs else None
{%- else %}
            # longest (по умолчанию)
            _resp_msg = None
            _max_len = 0
            for _bm in _bot_msgs:
                if _bm and _bm.text and len(_bm.text) > _max_len:
                    _max_len = len(_bm.text)
                    _resp_msg = _bm
            if not _resp_msg:
                _resp_msg = _bot_msgs[0] if _bot_msgs else None
{%- endif %}
            logging.info(f"📨 [{{ nodeId }}] fallback выбрано: id={_resp_msg.id if _resp_msg else None}")
        except Exception as _resp_err:
            logging.warning(f"⚠️ [{{ nodeId }}] Не удалось получить ответ: {_resp_err}")
    finally:
        userbot_client.remove_event_handler(_on_resp_{{ nodeId | replace('-', '_') }})
{%- endif %}

    if _resp_msg and hasattr(_resp_msg, 'id'):
        user_data[user_id]["{{ saveResponseIdTo }}"] = _resp_msg.id
        await set_user_var(user_id, "{{ saveResponseIdTo }}", _resp_msg.id)
        logging.info(f"💾 ID ответа сохранён: {{ saveResponseIdTo }} = {_resp_msg.id}")
        # [TEMP DEBUG] Кнопки бота в ответе — по одной строке (WorkerPool режет stdout ~200 симв.)
        _temp_resp_btn_count = 0
        if getattr(_resp_msg, 'reply_markup', None):
            for _temp_ri, _temp_row in enumerate(_resp_msg.reply_markup.rows):
                for _temp_ci, _temp_btn in enumerate(_temp_row.buttons):
                    _temp_lbl = getattr(_temp_btn, 'text', '') or ''
                    logging.info(
                        f"🔘 [TEMP {{ nodeId }}] Ответ бота msg={_resp_msg.id} "
                        f"btn[{_temp_resp_btn_count}] r{_temp_ri}c{_temp_ci}={_temp_lbl!r}"
                    )
                    _temp_resp_btn_count += 1
        if _temp_resp_btn_count == 0:
            logging.info(f"🔘 [TEMP {{ nodeId }}] Ответ бота msg={_resp_msg.id}: (нет кнопок)")
        else:
            logging.info(
                f"🔘 [TEMP {{ nodeId }}] Ответ бота msg={_resp_msg.id}: всего {_temp_resp_btn_count} кнопок"
            )
{%- if saveResponseTextTo %}
        _resp_text = (_resp_msg.text or '') if _resp_msg else ''
        user_data[user_id]["{{ saveResponseTextTo }}"] = _resp_text
        await set_user_var(user_id, "{{ saveResponseTextTo }}", _resp_text)
        logging.info(f"💾 Текст ответа сохранён: {{ saveResponseTextTo }} = {_resp_text[:80]!r}")
{%- endif %}
{%- if saveButtonsTo %}
        # Сохраняем кнопки ответа как JSON (ищем в других сообщениях, если longest выбрал только текст)
        _btns_src_msg = _resp_msg
        if not (_resp_msg and _resp_msg.reply_markup):
            try:
                _btns_recent = await userbot_client.get_messages(_resp_entity, limit=5)
                _btns_recent_list = _btns_recent if isinstance(_btns_recent, list) else [_btns_recent]
                for _btns_cand in _btns_recent_list:
                    if (
                        _btns_cand
                        and hasattr(_btns_cand, 'sender_id')
                        and _btns_cand.sender_id != _my_id
                        and _btns_cand.id > _sent_id
                        and _btns_cand.reply_markup
                    ):
                        _btns_src_msg = _btns_cand
                        logging.info(f"💾 [{{ nodeId }}] Кнопки взяты из сообщения id={_btns_cand.id} (не из основного ответа)")
                        break
            except Exception as _btns_err:
                logging.warning(f"⚠️ [{{ nodeId }}] Не удалось найти сообщение с кнопками: {_btns_err}")
        _btns_list = []
        if _btns_src_msg and _btns_src_msg.reply_markup:
            for _row in _btns_src_msg.reply_markup.rows:
                for _btn in _row.buttons:
                    _btn_entry = {"text": _btn.text}
                    _btn_type = type(_btn).__name__
                    if hasattr(_btn, 'data') and _btn.data:
                        _btn_entry["data"] = _btn.data.decode('utf-8', errors='replace')
                        _btn_entry["type"] = "callback"
                    elif hasattr(_btn, 'url') and _btn.url:
                        _btn_entry["url"] = _btn.url
                        _btn_entry["type"] = "url"
                    elif _btn_type == 'KeyboardButtonSwitchInline':
                        _btn_entry["query"] = getattr(_btn, 'query', '')
                        _btn_entry["type"] = "switch_inline"
                    elif _btn_type == 'KeyboardButtonWebView':
                        _btn_entry["url"] = getattr(_btn, 'url', '')
                        _btn_entry["type"] = "web_app"
                    else:
                        _btn_entry["type"] = "text"
                    _btns_list.append(_btn_entry)
        import json as _json_btns
        _btns_json = _json_btns.dumps(_btns_list, ensure_ascii=False)
        user_data[user_id]["{{ saveButtonsTo }}"] = _btns_json
        await set_user_var(user_id, "{{ saveButtonsTo }}", _btns_json)
        logging.info(f"💾 Кнопки ответа сохранены: {{ saveButtonsTo }} ({len(_btns_list)} кнопок)")
{%- endif %}
{%- endif %}

