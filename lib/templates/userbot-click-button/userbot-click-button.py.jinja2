{#
  Шаблон обработчика узла userbot_click_button

  @fileoverview Генерирует Python код для нажатия inline-кнопки через Telethon userbot.
  Поддерживает поиск по тексту, callback_data или индексу.
  Сохраняет alert, текст, кнопки, медиа в переменные.

  @param {string} nodeId - ID узла
  @param {string} userbotEntity - Entity чата
  @param {string} messageId - ID сообщения
  @param {string} clickMode - Способ поиска: 'text', 'data', 'index'
  @param {string} clickValue - Значение для поиска
  @param {string} saveAlertTo - Переменная для alert
  @param {string} saveResultTo - Переменная для текста
  @param {string} saveButtonsTo - Переменная для кнопок
  @param {string} saveHasMediaTo - Переменная для флага медиа
  @param {string} saveMediaTo - Переменная для медиа-объекта
  @param {string} clickDelivery - fire_and_forget | await
  @param {number} responseWaitSeconds - Таймаут ожидания edit (сек)
  @param {string} responseFilterRegex - Regex текста edit (как scrape poll_need)
  @param {string} autoTransitionTo - ID узла для автоперехода
  @param {number|null} projectId - ID проекта (для get_content)
#}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ nodeId|replace('-', '_') }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Обработчик узла {{ nodeId }} — нажатие кнопки через userbot"""
    user_id = callback_query.from_user.id
    logging.info(f"🟣 Userbot click_button: узел {{ nodeId }} для пользователя {user_id}")

    # Отвечаем на callback
    try:
        await callback_query.answer()
    except Exception:
        pass

    if user_id not in user_data:
        user_data[user_id] = {}

    # Подстановка переменных
    all_user_vars = await init_all_user_vars(user_id)
    if state is not None:
        try:
            _fsm_d = await state.get_data()
            if _fsm_d:
                all_user_vars.update(_fsm_d)
        except Exception:
            pass

    # Резолвим entity
{%- if projectId %}
    _entity_raw = get_content("{{ nodeId }}.entity", {{ userbotEntity|format_python_text }})
{%- else %}
    _entity_raw = {{ userbotEntity|format_python_text }}
{%- endif %}
    _entity = replace_variables_in_text(_entity_raw, all_user_vars, {})

    # Резолвим message ID
{%- if projectId %}
    _msg_id_raw = get_content("{{ nodeId }}.msg_id", {{ messageId|format_python_text }})
{%- else %}
    _msg_id_raw = {{ messageId|format_python_text }}
{%- endif %}
    _msg_id_str = replace_variables_in_text(_msg_id_raw, all_user_vars, {})

    # Резолвим значение для поиска кнопки
{%- if projectId %}
    _click_val_raw = get_content("{{ nodeId }}.click_val", {{ clickValue|format_python_text }})
{%- else %}
    _click_val_raw = {{ clickValue|format_python_text }}
{%- endif %}
    _click_val = replace_variables_in_text(_click_val_raw, all_user_vars, {})

{%- if messageIdSource != 'last' %}
    if not _entity or not _msg_id_str:
        logging.error(f"❌ Узел {{ nodeId }}: entity или message_id пустой")
        return
{%- else %}
    if not _entity:
        logging.error(f"❌ Узел {{ nodeId }}: entity пустой")
        return
{%- endif %}

    _updated = None
    try:
        _target = int(_entity) if _entity.lstrip('-').isdigit() else _entity
{%- if messageIdSource == 'last' %}
        # Режим: последнее сообщение бота с inline-кнопками (не исходящее userbot)
        _msgs = await userbot_client.get_messages(_target, limit=12)
        _msg_list = _msgs if isinstance(_msgs, list) else [_msgs]
        _my_id_last = (await userbot_client.get_me()).id
        _msg = None
        _best_btn_id = 0
        for _cand in _msg_list:
            if (
                _cand
                and getattr(_cand, 'sender_id', None) != _my_id_last
                and _cand.reply_markup
                and _cand.id > _best_btn_id
            ):
                _best_btn_id = _cand.id
                _msg = _cand
        if not _msg:
            logging.error(f"❌ Узел {{ nodeId }}: нет сообщений бота с кнопками в {_entity}")
            raise Exception(f"Нет сообщений бота с кнопками в {_entity}")
        _msg_id = _msg.id
{%- else %}
        if not _msg_id_str or not str(_msg_id_str).strip().lstrip('-').isdigit():
            # Переменная msg_id пуста — fallback на самое новое сообщение бота с кнопками
            _msgs_fb = await userbot_client.get_messages(_target, limit=12)
            _msg_list_fb = _msgs_fb if isinstance(_msgs_fb, list) else [_msgs_fb]
            _my_id_fb = (await userbot_client.get_me()).id
            _msg = None
            _best_fb_id = 0
            for _cand_fb in _msg_list_fb:
                if (
                    _cand_fb
                    and getattr(_cand_fb, 'sender_id', None) != _my_id_fb
                    and _cand_fb.reply_markup
                    and _cand_fb.id > _best_fb_id
                ):
                    _best_fb_id = _cand_fb.id
                    _msg = _cand_fb
            if not _msg:
                logging.error(f"❌ Узел {{ nodeId }}: messageId пуст и нет сообщений с кнопками в {_entity}")
                raise Exception(f"messageId пуст для {_entity}")
            _msg_id = _msg.id
        else:
            _msg_id = int(_msg_id_str)
            # Получаем сообщение с кнопками
            _msg = await userbot_client.get_messages(_target, ids=_msg_id)
        if not _msg:
            logging.error(f"❌ Узел {{ nodeId }}: сообщение {_msg_id} не найдено в {_entity}")
            raise Exception(f"Сообщение {_msg_id} не найдено в {_entity}")
{%- endif %}

        # [TEMP DEBUG] Кнопки бота до клика — по одной строке (WorkerPool режет stdout ~200 симв.)
        _temp_btn_count_before = 0
        if _msg and getattr(_msg, 'reply_markup', None):
            for _temp_ri, _temp_row in enumerate(_msg.reply_markup.rows):
                for _temp_ci, _temp_btn in enumerate(_temp_row.buttons):
                    _temp_lbl = getattr(_temp_btn, 'text', '') or ''
                    logging.info(
                        f"🔘 [TEMP {{ nodeId }}] До клика msg={_msg.id} "
                        f"btn[{_temp_btn_count_before}] r{_temp_ri}c{_temp_ci}={_temp_lbl!r}"
                    )
                    _temp_btn_count_before += 1
        if _temp_btn_count_before == 0:
            logging.info(f"🔘 [TEMP {{ nodeId }}] До клика msg={_msg.id if _msg else None}: (нет кнопок)")
        else:
            logging.info(f"🔘 [TEMP {{ nodeId }}] До клика msg={_msg.id}: всего {_temp_btn_count_before} кнопок")

        # Нажимаем кнопку (fire-and-forget — не ждём answerCallbackQuery)
        from telethon.tl.functions.messages import GetBotCallbackAnswerRequest

        _click_btn = None
{%- if clickMode == 'text' %}
        # Поиск кнопки по тексту
        if _msg.reply_markup:
            for _row in _msg.reply_markup.rows:
                for _btn in _row.buttons:
                    if hasattr(_btn, 'text') and _click_val in _btn.text:
                        _click_btn = _btn
                        break
                if _click_btn:
                    break
{%- elif clickMode == 'data' %}
        # Поиск кнопки по callback_data
        if _msg.reply_markup:
            for _row in _msg.reply_markup.rows:
                for _btn in _row.buttons:
                    if hasattr(_btn, 'data') and _btn.data and _click_val.encode('utf-8') in _btn.data:
                        _click_btn = _btn
                        break
                if _click_btn:
                    break
{%- elif clickMode == 'index' %}
        # Поиск кнопки по индексу
        _idx_parts = [int(x.strip()) for x in _click_val.split(',') if x.strip().isdigit()]
        if _msg.reply_markup:
            _all_btns = [btn for row in _msg.reply_markup.rows for btn in row.buttons]
            if len(_idx_parts) >= 2:
                # row, col
                _r, _c = _idx_parts[0], _idx_parts[1]
                if _r < len(_msg.reply_markup.rows) and _c < len(_msg.reply_markup.rows[_r].buttons):
                    _click_btn = _msg.reply_markup.rows[_r].buttons[_c]
            elif len(_idx_parts) == 1 and _idx_parts[0] < len(_all_btns):
                _click_btn = _all_btns[_idx_parts[0]]
{%- else %}
        # Поиск по тексту (default)
        if _msg.reply_markup:
            for _row in _msg.reply_markup.rows:
                for _btn in _row.buttons:
                    if hasattr(_btn, 'text') and _click_val in _btn.text:
                        _click_btn = _btn
                        break
                if _click_btn:
                    break
{%- endif %}

        # Telethon click(text=) — только точное совпадение; click_val часто подстрока («Купить» в «💎 Купить 💎»)
        _btn_click_data = getattr(_click_btn, 'data', None) if _click_btn else None
        _btn_click_text = (getattr(_click_btn, 'text', '') or _click_val) if _click_btn else _click_val

{%- if saveAlertTo %}
        # Переменная для alert (при fire-and-forget alert недоступен)
        user_data[user_id]["{{ saveAlertTo }}"] = ''
        await set_user_var(user_id, "{{ saveAlertTo }}", '')
{%- endif %}

{%- if responseStrategy == 'new_message' %}
        # Регистрируем event handler ДО нажатия кнопки (чтобы не пропустить быстрый ответ)
        _updated = None
        _new_msg_future = asyncio.get_event_loop().create_future()
{%- if responseFilterRegex %}
        import re as _re_new_{{ nodeId | replace('-', '_') }}
        _new_resp_re = {{ responseFilterRegex | tojson }}
{%- endif %}

        @userbot_client.on(events.NewMessage(chats=_target))
        async def _on_new_msg_{{ nodeId | replace('-', '_') }}(event):
            if event.message.id <= _msg_id or _new_msg_future.done():
                return
{%- if responseFilterRegex %}
            _new_txt = event.message.text or ''
            if not _re_new_{{ nodeId | replace('-', '_') }}.search(_new_resp_re, _new_txt, _re_new_{{ nodeId | replace('-', '_') }}.I):
{%- if nodeId == 'bot-ub-lucky-buy' %}
                # #region agent log
                _dbg_lucky_buy("H5", "new_msg rejected by regex", {"id": event.message.id, "text": _new_txt[:120]})
                # #endregion
{%- endif %}
                return
{%- endif %}
{%- if nodeId == 'bot-ub-lucky-buy' %}
            # #region agent log
            _dbg_lucky_buy("H4", "new_msg accepted", {"id": event.message.id, "text": (event.message.text or '')[:120]})
            # #endregion
{%- endif %}
            _new_msg_future.set_result(event.message)

{%- if nodeId == 'bot-ub-lucky-buy' %}
        @userbot_client.on(events.MessageEdited(chats=_target))
        async def _on_edit_dbg_bot_ub_lucky_buy(event):
            if event.message.id == _msg_id:
                # #region agent log
                _dbg_lucky_buy("H4", "message edited same id", {"id": event.message.id, "text": (event.message.text or '')[:120]})
                # #endregion
{%- endif %}
{%- else %}
        # Регистрируем event handler ДО нажатия кнопки (чтобы не пропустить быстрый ответ)
        _updated = None
        _edit_future = asyncio.get_event_loop().create_future()
{%- if responseFilterRegex %}
        import re as _re_edit_{{ nodeId | replace('-', '_') }}

        def _re_text_ok_{{ nodeId | replace('-', '_') }}(msg):
            if not msg:
                return False
            return bool(_re_edit_{{ nodeId | replace('-', '_') }}.search({{ responseFilterRegex | tojson }}, msg.text or '', _re_edit_{{ nodeId | replace('-', '_') }}.I))

        def _re_edit_ok_{{ nodeId | replace('-', '_') }}(msg):
            if not msg or msg.id != _msg_id:
                return False
            return _re_text_ok_{{ nodeId | replace('-', '_') }}(msg)

        # Доп. future на НОВОЕ сообщение (Vortex может отвечать new, а не edit)
        _new_resp_future_{{ nodeId | replace('-', '_') }} = asyncio.get_event_loop().create_future()

        @userbot_client.on(events.NewMessage(chats=_target))
        async def _on_new_resp_{{ nodeId | replace('-', '_') }}(event):
            if (
                event.message.id > _msg_id
                and not _new_resp_future_{{ nodeId | replace('-', '_') }}.done()
                and _re_text_ok_{{ nodeId | replace('-', '_') }}(event.message)
            ):
                _new_resp_future_{{ nodeId | replace('-', '_') }}.set_result(event.message)
{%- endif %}

        @userbot_client.on(events.MessageEdited(chats=_target))
        async def _on_edit_{{ nodeId | replace('-', '_') }}(event):
{%- if responseFilterRegex %}
            if (
                event.message.id == _msg_id
                and not _edit_future.done()
                and _re_edit_ok_{{ nodeId | replace('-', '_') }}(event.message)
            ):
                _edit_future.set_result(event.message)
{%- else %}
            if event.message.id == _msg_id and not _edit_future.done():
                _edit_future.set_result(event.message)
{%- endif %}
{%- endif %}

        async def _dispatch_callback_click_{{ nodeId | replace('-', '_') }}():
            """Отправляет callback-клик; ждём answer до 2с, но не отменяем запрос при таймауте."""
            _cb_task_{{ nodeId | replace('-', '_') }} = asyncio.create_task(
                userbot_client(GetBotCallbackAnswerRequest(
                    peer=_target,
                    msg_id=_msg.id,
                    data=_click_btn.data
                ))
            )
            try:
                await asyncio.wait_for(
                    asyncio.shield(_cb_task_{{ nodeId | replace('-', '_') }}),
                    timeout=2.0
                )
            except asyncio.TimeoutError:
                logging.info(f"ℹ️ [{{ nodeId }}] callback answer timeout 2с (клик уходит в фоне, ждём edit/new)")
            except Exception as _click_err:
                if "TimeoutError" not in type(_click_err).__name__:
                    logging.warning(f"⚠️ [{{ nodeId }}] callback click error: {_click_err}")

{%- if clickDelivery == 'await' %}
        # await: Telethon msg.click (как scrape_lucky.py; надёжнее GetBotCallbackAnswerRequest)
        if _click_btn:
            try:
{%- if nodeId == 'bot-ub-lucky-buy' %}
                # #region agent log
                _dbg_lucky_buy("H3", "await_click start", {
                    "msg_id": _msg.id if _msg else None,
                    "via": "data" if _btn_click_data else "text",
                    "click_text": (_btn_click_text or '')[:40],
                })
                # #endregion
{%- endif %}
{%- if clickMode == 'index' %}
                _idx_click = [int(x.strip()) for x in _click_val.split(',') if x.strip().isdigit()]
                if len(_idx_click) >= 2:
                    await asyncio.wait_for(_msg.click(_idx_click[0], _idx_click[1]), timeout=5.0)
                elif len(_idx_click) == 1:
                    await asyncio.wait_for(_msg.click(i=_idx_click[0]), timeout=5.0)
                else:
                    await asyncio.wait_for(_msg.click(i=0), timeout=5.0)
{%- elif clickMode == 'data' %}
                await asyncio.wait_for(_msg.click(data=_click_btn.data), timeout=5.0)
{%- else %}
                if _btn_click_data:
                    await asyncio.wait_for(_msg.click(data=_btn_click_data), timeout=5.0)
                else:
                    await asyncio.wait_for(_msg.click(text=_btn_click_text), timeout=5.0)
{%- endif %}
            except asyncio.TimeoutError:
                logging.info(f"ℹ️ [{{ nodeId }}] click timeout 5с (ждём edit/new)")
            except Exception as _click_err:
                if "TimeoutError" not in type(_click_err).__name__:
                    logging.warning(f"⚠️ [{{ nodeId }}] await click error: {_click_err}")
{%- if nodeId == 'bot-ub-lucky-buy' %}
            # #region agent log
            _dbg_lucky_buy("H3", "await_click done", {"msg_id": _msg.id if _msg else None})
            # #endregion
{%- endif %}
            logging.info(f"✅ Userbot нажал кнопку в {_entity} msg={_msg_id} (узел {{ nodeId }}) [await]")
        else:
            logging.warning(f"⚠️ Узел {{ nodeId }}: кнопка не найдена (mode={{ clickMode }}, value={_click_val!r})")
{%- else %}
        # fire-and-forget: msg.click в фоне (как scrape), не блокируем на answerCallbackQuery
        async def _fire_click_{{ nodeId | replace('-', '_') }}():
            """Фоновый клик через Telethon msg.click."""
            try:
{%- if nodeId == 'bot-ub-lucky-buy' %}
                # #region agent log
                _dbg_lucky_buy("H3", "fire_click start", {
                    "msg_id": _msg.id if _msg else None,
                    "via": "data" if _btn_click_data else "text",
                    "click_text": (_btn_click_text or '')[:40],
                })
                # #endregion
{%- endif %}
{%- if clickMode == 'index' %}
                _idx_fire = [int(x.strip()) for x in _click_val.split(',') if x.strip().isdigit()]
                if len(_idx_fire) >= 2:
                    await _msg.click(_idx_fire[0], _idx_fire[1])
                elif len(_idx_fire) == 1:
                    await _msg.click(i=_idx_fire[0])
                else:
                    await _msg.click(i=0)
{%- elif clickMode == 'data' %}
                if _click_btn and getattr(_click_btn, 'data', None):
                    await _msg.click(data=_click_btn.data)
{%- else %}
                if _btn_click_data:
                    await _msg.click(data=_btn_click_data)
                else:
                    await _msg.click(text=_btn_click_text)
{%- endif %}
{%- if nodeId == 'bot-ub-lucky-buy' %}
                # #region agent log
                _dbg_lucky_buy("H3", "fire_click done", {"msg_id": _msg.id if _msg else None})
                # #endregion
{%- endif %}
            except Exception as _fire_err:
                if "TimeoutError" not in type(_fire_err).__name__:
                    logging.warning(f"⚠️ [{{ nodeId }}] fire click error: {_fire_err}")
{%- if nodeId == 'bot-ub-lucky-buy' %}
                # #region agent log
                _dbg_lucky_buy("H3", "fire_click error", {"err": type(_fire_err).__name__, "detail": str(_fire_err)[:200]})
                # #endregion
{%- endif %}

        if _click_btn:
            asyncio.create_task(_fire_click_{{ nodeId | replace('-', '_') }}())
            logging.info(f"✅ Userbot нажал кнопку в {_entity} msg={_msg_id} (узел {{ nodeId }}) [fire-and-forget]")
        else:
            logging.warning(f"⚠️ Узел {{ nodeId }}: кнопка не найдена (mode={{ clickMode }}, value={_click_val!r})")
{%- endif %}

{%- if responseStrategy == 'new_message' %}
        # Ждём НОВОЕ сообщение от бота (не edit)
        try:
            _updated = await asyncio.wait_for(
                _new_msg_future, timeout={{ responseWaitSeconds | default(14) }}
            )
            logging.info(f"📖 [{{ nodeId }}] Получено новое сообщение id={_updated.id}")
        except asyncio.TimeoutError:
            logging.info(f"📖 [{{ nodeId }}] Таймаут ожидания нового сообщения, читаем историю")
            # Fallback: читаем последние сообщения и ищем новое (id > _msg_id)
            await asyncio.sleep(1)
            _fresh_msgs = await userbot_client.get_messages(_target, limit=8)
            _fresh_list = _fresh_msgs if isinstance(_fresh_msgs, list) else [_fresh_msgs]
            _my_id_cb = (await userbot_client.get_me()).id
            _bot_new = [
                m for m in _fresh_list
                if m and hasattr(m, 'sender_id') and m.sender_id != _my_id_cb and m.id > _msg_id
            ]
{%- if responseFilterRegex %}
            _bot_new = [
                m for m in _bot_new
                if _re_new_{{ nodeId | replace('-', '_') }}.search(
                    _new_resp_re, m.text or '', _re_new_{{ nodeId | replace('-', '_') }}.I
                )
            ]
{%- endif %}
            _updated = _bot_new[0] if _bot_new else None
{%- if nodeId == 'bot-ub-lucky-buy' %}
            # #region agent log
            _hist_dbg = []
            for _hm in _fresh_list:
                if _hm and not getattr(_hm, 'out', False):
                    _hist_dbg.append({"id": _hm.id, "text": (_hm.text or '')[:80]})
            _dbg_lucky_buy("H6", "timeout fallback history", {"msg_id": _msg_id, "matched": len(_bot_new), "history": _hist_dbg[:8]})
            # #endregion
{%- endif %}
        finally:
            userbot_client.remove_event_handler(_on_new_msg_{{ nodeId | replace('-', '_') }})
{%- if nodeId == 'bot-ub-lucky-buy' %}
            try:
                userbot_client.remove_event_handler(_on_edit_dbg_bot_ub_lucky_buy)
            except Exception:
                pass
{%- endif %}
{%- else %}
        # Ждём edit того же msg (как scrape poll_need same_id)
{%- if responseFilterRegex %}
        import time as _time_edit_{{ nodeId | replace('-', '_') }}
        try:
            # Гонка: edit того же msg ИЛИ новое сообщение, прошедшее regex (как scrape watch new+edit)
            _wait_tasks_{{ nodeId | replace('-', '_') }} = [
                asyncio.ensure_future(_edit_future),
                asyncio.ensure_future(_new_resp_future_{{ nodeId | replace('-', '_') }}),
            ]
            _done_{{ nodeId | replace('-', '_') }}, _pending_{{ nodeId | replace('-', '_') }} = await asyncio.wait(
                _wait_tasks_{{ nodeId | replace('-', '_') }},
                timeout={{ responseWaitSeconds | default(14) }},
                return_when=asyncio.FIRST_COMPLETED,
            )
            for _t_{{ nodeId | replace('-', '_') }} in _pending_{{ nodeId | replace('-', '_') }}:
                _t_{{ nodeId | replace('-', '_') }}.cancel()
            _updated = None
            for _t_{{ nodeId | replace('-', '_') }} in _done_{{ nodeId | replace('-', '_') }}:
                try:
                    _updated = _t_{{ nodeId | replace('-', '_') }}.result()
                    break
                except Exception:
                    pass
            if _updated is not None:
                logging.info(f"📖 [{{ nodeId }}] Получен ответ msg={_updated.id} (edit/new по regex)")
            else:
                raise asyncio.TimeoutError()
        except asyncio.TimeoutError:
            logging.info(f"📖 [{{ nodeId }}] Таймаут ожидания ответа msg={_msg_id}, читаем историю")
            # [TEMP DEBUG] Дамп последних сообщений — понять edit это или new
            try:
                _dump_msgs_{{ nodeId | replace('-', '_') }} = await userbot_client.get_messages(_target, limit=6)
                _dump_list_{{ nodeId | replace('-', '_') }} = _dump_msgs_{{ nodeId | replace('-', '_') }} if isinstance(_dump_msgs_{{ nodeId | replace('-', '_') }}, list) else [_dump_msgs_{{ nodeId | replace('-', '_') }}]
                for _dm_{{ nodeId | replace('-', '_') }} in _dump_list_{{ nodeId | replace('-', '_') }}:
                    if _dm_{{ nodeId | replace('-', '_') }}:
                        logging.info(
                            f"🔎 [TEMP {{ nodeId }}] hist id={_dm_{{ nodeId | replace('-', '_') }}.id} "
                            f"out={getattr(_dm_{{ nodeId | replace('-', '_') }}, 'out', None)} "
                            f"text={(_dm_{{ nodeId | replace('-', '_') }}.text or '')[:70]!r}"
                        )
            except Exception as _dump_err_{{ nodeId | replace('-', '_') }}:
                logging.info(f"🔎 [TEMP {{ nodeId }}] dump error: {_dump_err_{{ nodeId | replace('-', '_') }}}")
            # Поллинг: и edit того же msg, и любое новое сообщение, прошедшее regex
            _edit_poll_t0 = _time_edit_{{ nodeId | replace('-', '_') }}.monotonic()
            _updated = None
            while _time_edit_{{ nodeId | replace('-', '_') }}.monotonic() - _edit_poll_t0 < 3.0:
                try:
                    _hm_{{ nodeId | replace('-', '_') }} = await userbot_client.get_messages(_target, limit=6)
                    _hm_list_{{ nodeId | replace('-', '_') }} = _hm_{{ nodeId | replace('-', '_') }} if isinstance(_hm_{{ nodeId | replace('-', '_') }}, list) else [_hm_{{ nodeId | replace('-', '_') }}]
                    for _cm_{{ nodeId | replace('-', '_') }} in _hm_list_{{ nodeId | replace('-', '_') }}:
                        if not _cm_{{ nodeId | replace('-', '_') }} or getattr(_cm_{{ nodeId | replace('-', '_') }}, 'out', False):
                            continue
                        _is_edit_{{ nodeId | replace('-', '_') }} = _cm_{{ nodeId | replace('-', '_') }}.id == _msg_id
                        _is_new_{{ nodeId | replace('-', '_') }} = _cm_{{ nodeId | replace('-', '_') }}.id > _msg_id
                        if (_is_edit_{{ nodeId | replace('-', '_') }} or _is_new_{{ nodeId | replace('-', '_') }}) and _re_text_ok_{{ nodeId | replace('-', '_') }}(_cm_{{ nodeId | replace('-', '_') }}):
                            _updated = _cm_{{ nodeId | replace('-', '_') }}
                            logging.info(f"📖 [{{ nodeId }}] poll ok msg={_updated.id} ({'edit' if _is_edit_{{ nodeId | replace('-', '_') }} else 'new'})")
                            break
                    if _updated is not None:
                        break
                except Exception:
                    pass
                await asyncio.sleep(0.25)
        finally:
            userbot_client.remove_event_handler(_on_edit_{{ nodeId | replace('-', '_') }})
            userbot_client.remove_event_handler(_on_new_resp_{{ nodeId | replace('-', '_') }})
{%- else %}
        try:
            _updated = await asyncio.wait_for(_edit_future, timeout=5)
            logging.info(f"📖 [{{ nodeId }}] Получено событие редактирования msg={_msg_id}")
        except asyncio.TimeoutError:
            logging.info(f"📖 [{{ nodeId }}] Таймаут ожидания редактирования msg={_msg_id}, читаем историю")
            _fresh_msgs = await userbot_client.get_messages(_target, limit=5)
            _fresh_list = _fresh_msgs if isinstance(_fresh_msgs, list) else [_fresh_msgs]
            _my_id_cb = (await userbot_client.get_me()).id
            _bot_fallback = [m for m in _fresh_list if m and hasattr(m, 'sender_id') and m.sender_id != _my_id_cb]
            _updated = _bot_fallback[0] if _bot_fallback else None
        finally:
            userbot_client.remove_event_handler(_on_edit_{{ nodeId | replace('-', '_') }})
{%- endif %}
{%- endif %}

        logging.info(f"📖 [{{ nodeId }}] Результат: text={((_updated.text or '') if _updated else 'None')[:80]!r}")

        # [TEMP DEBUG] Кнопки бота после ответа — по одной строке
        _temp_btn_count_after = 0
        if _updated and getattr(_updated, 'reply_markup', None):
            for _temp_ri, _temp_row in enumerate(_updated.reply_markup.rows):
                for _temp_ci, _temp_btn in enumerate(_temp_row.buttons):
                    _temp_lbl = getattr(_temp_btn, 'text', '') or ''
                    logging.info(
                        f"🔘 [TEMP {{ nodeId }}] После ответа msg={_updated.id} "
                        f"btn[{_temp_btn_count_after}] r{_temp_ri}c{_temp_ci}={_temp_lbl!r}"
                    )
                    _temp_btn_count_after += 1
        if _temp_btn_count_after == 0:
            logging.info(
                f"🔘 [TEMP {{ nodeId }}] После ответа msg={_updated.id if _updated else None}: (нет кнопок)"
            )
        else:
            logging.info(
                f"🔘 [TEMP {{ nodeId }}] После ответа msg={_updated.id}: всего {_temp_btn_count_after} кнопок"
            )

{%- if saveResultTo %}
        # Сохраняем текст обновлённого сообщения
        _new_text = _updated.text if _updated else ''
        user_data[user_id]["{{ saveResultTo }}"] = _new_text or ''
        await set_user_var(user_id, "{{ saveResultTo }}", _new_text or '')
        logging.info(f"💾 [{{ nodeId }}] saveResultTo: {{ saveResultTo }} = {(_new_text or '')[:80]!r}")
{%- endif %}

{%- if saveButtonsTo %}
        # Сохраняем кнопки как JSON с типами
        _btns_list = []
        if _updated and _updated.reply_markup:
            for _row in _updated.reply_markup.rows:
                for _btn in _row.buttons:
                    _btn_entry = {"text": _btn.text}
                    _btn_type = type(_btn).__name__
                    if hasattr(_btn, 'data') and _btn.data:
                        _btn_entry["data"] = _btn.data.decode('utf-8', errors='replace')
                        _btn_entry["type"] = "callback"
                    elif hasattr(_btn, 'url') and _btn.url:
                        _btn_entry["url"] = _btn.url
                        _btn_entry["type"] = "url"
                    elif _btn_type == 'KeyboardButtonSwitchInline':
                        _btn_entry["query"] = getattr(_btn, 'query', '')
                        _btn_entry["type"] = "switch_inline"
                    elif _btn_type == 'KeyboardButtonWebView':
                        _btn_entry["url"] = getattr(_btn, 'url', '')
                        _btn_entry["type"] = "web_app"
                    elif _btn_type == 'KeyboardButtonRequestPhone':
                        _btn_entry["type"] = "request_phone"
                    elif _btn_type == 'KeyboardButtonRequestGeoLocation':
                        _btn_entry["type"] = "request_location"
                    elif _btn_type == 'KeyboardButtonBuy':
                        _btn_entry["type"] = "buy"
                    elif _btn_type == 'KeyboardButtonGame':
                        _btn_entry["type"] = "game"
                    else:
                        _btn_entry["type"] = "text"
                    _btns_list.append(_btn_entry)
        import json as _json
        _btns_json = _json.dumps(_btns_list, ensure_ascii=False)
        user_data[user_id]["{{ saveButtonsTo }}"] = _btns_json
        await set_user_var(user_id, "{{ saveButtonsTo }}", _btns_json)
{%- endif %}

{%- if saveHasMediaTo %}
        # Сохраняем флаг наличия медиа
        _has_media = "true" if (_updated and _updated.media) else "false"
        user_data[user_id]["{{ saveHasMediaTo }}"] = _has_media
        await set_user_var(user_id, "{{ saveHasMediaTo }}", _has_media)
{%- endif %}

{%- if saveMediaTo %}
        # Сохраняем медиа-объект (для пересылки через userbot)
        if _updated and _updated.media:
            user_data[user_id]["{{ saveMediaTo }}"] = _updated.media
{%- endif %}

    except Exception as _ub_err:
        logging.error(f"❌ Ошибка нажатия кнопки через userbot (узел {{ nodeId }}): {_ub_err}")
        if "FloodWaitError" in type(_ub_err).__name__ or "flood" in str(_ub_err).lower():
            _wait = getattr(_ub_err, 'seconds', 30)
            logging.warning(f"⏳ FloodWait: ждём {_wait} секунд")
            await asyncio.sleep(_wait)

{%- if autoTransitionTo %}
    # Автопереход только если получен ответ бота (иначе не шлём текст на неверный экран)
{%- if responseStrategy == 'new_message' or responseStrategy == 'edit' %}
    if _updated is not None:
        logging.info(f"⚡ Автопереход: {{ nodeId }} → {{ autoTransitionTo }}")
        class FakeCallbackQuery:
            def __init__(self, from_user, message, target_node_id):
                self.from_user = from_user
                self.message = message
                self.data = target_node_id
                self._is_fake = True
            async def answer(self, *args, **kwargs):
                pass

        _fake_cb = FakeCallbackQuery(callback_query.from_user, callback_query.message, "{{ autoTransitionTo }}")
        try:
            await handle_callback_{{ autoTransitionTo|replace('-', '_') }}(_fake_cb, state=state)
        except Exception as _at_err:
            logging.error(f"❌ Ошибка автоперехода {{ nodeId }} → {{ autoTransitionTo }}: {_at_err}")
    else:
        logging.warning(f"⚠️ [{{ nodeId }}] Нет ответа бота — автопереход → {{ autoTransitionTo }} отменён")
{%- else %}
    logging.info(f"⚡ Автопереход: {{ nodeId }} → {{ autoTransitionTo }}")
    class FakeCallbackQuery:
        def __init__(self, from_user, message, target_node_id):
            self.from_user = from_user
            self.message = message
            self.data = target_node_id
            self._is_fake = True
        async def answer(self, *args, **kwargs):
            pass

    _fake_cb = FakeCallbackQuery(callback_query.from_user, callback_query.message, "{{ autoTransitionTo }}")
    try:
        await handle_callback_{{ autoTransitionTo|replace('-', '_') }}(_fake_cb, state=state)
    except Exception as _at_err:
        logging.error(f"❌ Ошибка автоперехода {{ nodeId }} → {{ autoTransitionTo }}: {_at_err}")
{%- endif %}
{%- endif %}
