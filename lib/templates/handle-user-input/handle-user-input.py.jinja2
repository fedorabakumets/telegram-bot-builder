{#
  Шаблон универсального обработчика пользовательского ввода

  @param {string}  indentLevel  - базовый отступ (по умолчанию '    ')
  @param {array}   nodes        - все узлы [{id, safeName, type, data}]
  @param {array}   allNodeIds   - все ID узлов
  @param {boolean} hasUrlButtons - есть ли URL кнопки в проекте
  @param {array}   commandNodes - узлы с командами (start/command)
#}

{% set ind = indentLevel or '    ' %}
{% set ind2 = ind ~ '    ' %}
{% set ind3 = ind2 ~ '    ' %}
{% set ind4 = ind3 ~ '    ' %}
{% set ind5 = ind4 ~ '    ' %}
{% set ind6 = ind5 ~ '    ' %}

{# ═══════════════════════════════════════════════════════════════
   Проверяем button_response_config (reply клавиатура)
   ═══════════════════════════════════════════════════════════════ #}
{{ ind }}# Проверяем, ожидаем ли мы кнопочный ответ через reply клавиатуру
{{ ind }}if user_id in user_data and "button_response_config" in user_data[user_id]:
{{ ind2 }}config = user_data[user_id]["button_response_config"]
{{ ind2 }}user_text = message.text
{{ ind2 }}
{{ ind2 }}# Ищем выбранный вариант среди доступных опций
{{ ind2 }}selected_option = None
{{ ind2 }}for option in config.get("options", []):
{{ ind3 }}if option["text"] == user_text:
{{ ind4 }}selected_option = option
{{ ind4 }}break
{{ ind2 }}
{{ ind2 }}if selected_option:
{{ ind3 }}selected_value = selected_option["value"]
{{ ind3 }}selected_text = selected_option["text"]
{{ ind3 }}
{{ ind3 }}# Сохраняем ответ пользователя
{{ ind3 }}variable_name = config.get("variable", "button_response")
{{ ind3 }}timestamp = get_moscow_time()
{{ ind3 }}node_id = config.get("node_id", "unknown")
{{ ind3 }}
{{ ind3 }}response_data = {
{{ ind4 }}"value": selected_value,
{{ ind4 }}"text": selected_text,
{{ ind4 }}"type": "button_response",
{{ ind4 }}"timestamp": timestamp,
{{ ind4 }}"nodeId": node_id,
{{ ind4 }}"variable": variable_name
{{ ind3 }}}
{{ ind3 }}
{{ ind3 }}# Сохраняем в пользовательские данные
{{ ind3 }}user_data[user_id][variable_name] = response_data
{{ ind3 }}
{{ ind3 }}# Сохраняем в базу данных если включено
{{ ind3 }}if config.get("save_to_database"):
{{ ind4 }}await update_user_data_in_db(user_id, variable_name, response_data)
{{ ind4 }}logging.info(f"✅ Кнопочный ответ сохранен в БД: {variable_name} = {selected_text} (пользователь {user_id})")
{{ ind3 }}
{{ ind3 }}# Отправляем сообщение об успехе
{{ ind3 }}success_message = config.get("success_message", "Спасибо за ваш выбор!")
{{ ind3 }}await message.answer(f"{success_message}\n\n✅ Ваш выбор: {selected_text}", reply_markup=ReplyKeyboardRemove())
{{ ind3 }}
{{ ind3 }}# Очищаем состояние
{{ ind3 }}del user_data[user_id]["button_response_config"]
{{ ind3 }}
{{ ind3 }}logging.info(f"Получен кнопочный ответ через reply клавиатуру: {variable_name} = {selected_text}")
{{ ind3 }}
{{ ind3 }}# Навигация на основе действия кнопки
{{ ind3 }}option_action = selected_option.get("action", "goto")
{{ ind3 }}option_target = selected_option.get("target", "")
{{ ind3 }}option_url = selected_option.get("url", "")
{{ ind3 }}
{% if hasUrlButtons %}
{{ ind3 }}if option_action == "url" and option_url:
{{ ind4 }}# Открытие ссылки
{{ ind4 }}url = option_url
{{ ind4 }}keyboard = InlineKeyboardMarkup(inline_keyboard=[
{{ ind5 }}[InlineKeyboardButton(text="🔗 Открыть ссылку", url=url)]
{{ ind4 }}])
{{ ind4 }}await message.answer("Нажмите кнопку ниже, чтобы открыть ссылку:", reply_markup=keyboard)
{{ ind3 }}elif option_action == "command" and option_target:
{% else %}
{{ ind3 }}if option_action == "command" and option_target:
{% endif %}
{{ ind4 }}# Выполнение команды
{{ ind4 }}command = option_target
{{ ind4 }}# Создаем фиктивное сообщение для выполнения команды
{{ ind4 }}fake_message = SimpleNamespace(
{{ ind5 }}from_user=message.from_user,
{{ ind5 }}chat=message.chat,
{{ ind5 }}text=command,
{{ ind5 }}message_id=message.message_id
{{ ind4 }})
{{ ind4 }}
{% for cmdNode in commandNodes %}
{{ ind4 }}{% if loop.first %}if{% else %}elif{% endif %} command == "{{ cmdNode.data.command }}":
{{ ind5 }}try:
{{ ind6 }}await {% if cmdNode.type == 'start' %}start_handler{% else %}{{ cmdNode.data.command | replace('/', '') | replace('-', '_') }}_handler{% endif %}(fake_message)
{{ ind5 }}except Exception as e:
{{ ind6 }}logging.error(f"Ошибка при выполнении команды {{ cmdNode.data.command }}: {e}")
{% endfor %}
{{ ind3 }}elif option_action == "goto" and option_target:
{{ ind4 }}# Переход к узлу
{{ ind4 }}target_node_id = option_target
{{ ind4 }}try:
{{ ind5 }}# Вызываем обработчик для целевого узла
{% for node in nodes %}
{{ ind5 }}{% if loop.first %}if{% else %}elif{% endif %} target_node_id == "{{ node.id }}":
{{ ind6 }}await handle_callback_{{ node.safeName }}(types.CallbackQuery(id="reply_nav", from_user=message.from_user, chat_instance="", data=target_node_id, message=message))
{% endfor %}
{% if nodes | length > 0 %}
{{ ind5 }}else:
{{ ind6 }}logging.warning(f"Неизвестный целевой узел: {target_node_id}")
{% endif %}
{{ ind4 }}except Exception as e:
{{ ind5 }}logging.error(f"Ошибка при переходе к узлу {target_node_id}: {e}")
{{ ind3 }}else:
{{ ind4 }}# Fallback к старой системе next_node_id если нет action
{{ ind4 }}next_node_id = config.get("next_node_id")
{{ ind4 }}if next_node_id:
{{ ind5 }}try:
{{ ind6 }}# Вызываем обработчик для следующего узла
{% for node in nodes %}
{{ ind6 }}{% if loop.first %}if{% else %}elif{% endif %} next_node_id == "{{ node.id }}":
{{ ind6 }}    await handle_callback_{{ node.safeName }}(types.CallbackQuery(id="reply_nav", from_user=message.from_user, chat_instance="", data=next_node_id, message=message))
{% endfor %}
{% if nodes | length > 0 %}
{{ ind6 }}else:
{{ ind6 }}    logging.warning(f"Неизвестный следующий узел: {next_node_id}")
{% endif %}
{{ ind5 }}except Exception as e:
{{ ind6 }}logging.error(f"Ошибка при переходе к следующему узлу {next_node_id}: {e}")
{{ ind3 }}return
{{ ind2 }}else:
{{ ind3 }}# Неверный выбор - показываем доступные варианты
{{ ind3 }}available_options = [option["text"] for option in config.get("options", [])]
{{ ind3 }}options_text = "\n".join([f"• {opt}" for opt in available_options])
{{ ind3 }}await message.answer(f"❌ Неверный выбор. Пожалуйста, выберите один из предложенных вариантов:\n\n{options_text}")
{{ ind3 }}return
{{ ind }}
