{#
  Шаблон обработчика команды

  @fileoverview Генерирует Python код для обработки команд Telegram бота
  @param {string} nodeId - Уникальный идентификатор узла
  @param {string} command - Команда (например, "/help")
  @param {string} messageText - Текст сообщения
  @param {boolean} isPrivateOnly - Только приватные чаты
  @param {boolean} adminOnly - Только администраторы
  @param {boolean} requiresAuth - Требуется авторизация
  @param {boolean} userDatabaseEnabled - База данных пользователей включена
  @param {array} synonyms - Синонимы команды
  @param {boolean} enableConditionalMessages - Условные сообщения включены
  @param {array} conditionalMessages - Условные сообщения
  @param {string} fallbackMessage - Запасное сообщение
  @param {string} keyboardType - Тип клавиатуры: 'inline', 'reply', 'none'
  @param {array} buttons - Кнопки
  @param {string} formatMode - Режим форматирования: 'html', 'markdown', 'none'
  @param {string} imageUrl - URL изображения
  @param {string} documentUrl - URL документа
  @param {string} videoUrl - URL видео
  @param {string} audioUrl - URL аудио
  @param {array} attachedMedia - Прикреплённые медиа переменные

  @note Шаблон генерирует ДВА обработчика:
    1. @dp.message(Command("...")) — для текстовой команды
    2. @dp.callback_query(lambda c: c.data == "{{ nodeId }}") — для кнопок
       с action="goto" и target="{{ nodeId }}" (переход на узел команды)
  @note isPrivateOnly применяется к обоим обработчикам: message и callback
#}

{# Генерация основной команды #}
@dp.message(Command("{{ command|replace('/start', 'start')|replace('/help', 'help')|replace('/', '') }}"))
async def {{ command|replace('/start', 'start')|replace('/help', 'help')|replace('/', '')|safe_name }}_handler(message: types.Message):
    """Обработчик команды {{ command }}"""
    logging.info(f"Команда {{ command }} вызвана пользователем {message.from_user.id}")

    {# Проверки безопасности #}
    {%- if isPrivateOnly %}
    if not await is_private_chat(message):
        await message.answer("❌ Эта команда доступна только в приватных чатах")
        return
    {%- endif %}
    {%- if adminOnly %}
    if not await is_admin(message.from_user.id):
        await message.answer("❌ У вас нет прав для выполнения этой команды")
        return
    {%- endif %}
    {%- if requiresAuth %}
    if not await check_auth(message.from_user.id):
        await message.answer("❌ Сначала запустите бота: /start")
        return
    {%- endif %}

    {# Сохранение информации о пользователе #}
    user_id = message.from_user.id
    username = message.from_user.username
    first_name = message.from_user.first_name
    last_name = message.from_user.last_name

    {%- if userDatabaseEnabled %}
    # Сохраняем пользователя в базу данных
    saved_to_db = await save_user_to_db(user_id, username, first_name, last_name)

    # Инициализируем базовые переменные пользователя
    user_name = await init_user_variables(user_id, message.from_user)
    await update_user_data_in_db(user_id, "user_name", user_name)
    await update_user_data_in_db(user_id, "first_name", first_name)
    await update_user_data_in_db(user_id, "last_name", last_name)
    await update_user_data_in_db(user_id, "username", username)

    # Обновляем статистику команд в БД
    if saved_to_db:
        await update_user_data_in_db(user_id, "command_{{ command|replace('/', '') }}", datetime.now().isoformat())
    {%- endif %}

    # Сохранение в локальное хранилище
    # Инициализируем базовые переменные пользователя в локальном хранилище
    await init_user_variables(user_id, message.from_user)

    if "commands_used" not in user_data[user_id]:
        user_data[user_id]["commands_used"] = {}
    user_data[user_id]["commands_used"]["{{ command }}"] = user_data[user_id]["commands_used"].get("{{ command }}", 0) + 1

    {# Сохранение медиа-переменных #}
    {%- if imageUrl and imageUrl != 'undefined' %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["image_url_{{ nodeId }}"] = "{{ imageUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "image_url_{{ nodeId }}", "{{ imageUrl }}")
    {%- endif %}
    {%- endif %}

    {%- if documentUrl %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["document_url_{{ nodeId }}"] = "{{ documentUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "document_url_{{ nodeId }}", "{{ documentUrl }}")
    {%- endif %}
    {%- endif %}

    {%- if videoUrl %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["video_url_{{ nodeId }}"] = "{{ videoUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "video_url_{{ nodeId }}", "{{ videoUrl }}")
    {%- endif %}
    {%- endif %}

    {%- if audioUrl %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["audio_url_{{ nodeId }}"] = "{{ audioUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "audio_url_{{ nodeId }}", "{{ audioUrl }}")
    {%- endif %}
    {%- endif %}

    {# Обработка сообщений #}
    {%- if enableConditionalMessages and conditionalMessages|length > 0 %}
    # Проверяем условные сообщения
    text = {{ messageText|format_python_text }}  # Инициализируем текст по умолчанию

    # Получаем данные пользователя для проверки условий
    {%- if userDatabaseEnabled %}
    user_record = await get_user_from_db(user_id)
    if not user_record:
        user_record = user_data.get(user_id, {})
    {%- else %}
    user_record = user_data.get(user_id, {})
    {%- endif %}

    # Безопасно извлекаем user_data
    if isinstance(user_record, dict):
        if "user_data" in user_record and isinstance(user_record["user_data"], dict):
            user_data_dict = user_record["user_data"]
        else:
            user_data_dict = user_record
    else:
        user_data_dict = {}

    {# Логика условных сообщений #}
    {%- if enableConditionalMessages and conditionalMessages|length > 0 %}
    # Условные сообщения будут обработаны отдельно
    # TODO: Интеграция с generateConditionalMessageLogic
    {%- endif %}

    {# Основное сообщение #}
    {%- if fallbackMessage and enableConditionalMessages %}
    text = {{ fallbackMessage|format_python_text }}
    logging.info("Используется запасное сообщение")
    {%- else %}
    text = {{ messageText|format_python_text }}
    logging.info("Используется основное сообщение узла")
    {%- endif %}

    # Универсальная замена переменных
    # Инициализация all_user_vars
    all_user_vars = await init_all_user_vars(user_id)

    # Добавляем переменные из таблиц БД
    {%- if hasUserIdsVariable %}
    user_ids_record = await get_user_ids_from_db(user_id)
    if user_ids_record:
        all_user_vars["user_ids"] = user_ids_record.get("user_ids", [])
        all_user_vars["user_ids_count"] = user_ids_record.get("count", 0)
    {%- endif %}

    # Заменяем переменные в тексте
    text = replace_variables_in_text(text, all_user_vars, {})

    {# Клавиатура #}
    {%- filter indent(4) %}{% include 'keyboard/keyboard.py.jinja2' %}{% endfilter %}

    {# Отправка медиафайлов или обычного сообщения #}
    {%- if (attachedMedia and attachedMedia|length > 0) or (imageUrl and imageUrl != 'undefined') or videoUrl or audioUrl or documentUrl %}
{%- filter indent(4) %}{% include 'attached-media/attached-media.py.jinja2' %}{% endfilter %}
    {%- else %}
    {%- if formatMode == 'html' %}
    {%- if userDatabaseEnabled %}
    await bot.send_message(message.chat.id, text, node_id="{{ nodeId }}", reply_markup=keyboard, parse_mode="HTML")
    {%- else %}
    await message.answer(text, reply_markup=keyboard, parse_mode="HTML")
    {%- endif %}
    {%- elif formatMode == 'markdown' %}
    {%- if userDatabaseEnabled %}
    await bot.send_message(message.chat.id, text, node_id="{{ nodeId }}", reply_markup=keyboard, parse_mode="Markdown")
    {%- else %}
    await message.answer(text, reply_markup=keyboard, parse_mode="Markdown")
    {%- endif %}
    {%- else %}
    {%- if userDatabaseEnabled %}
    await bot.send_message(message.chat.id, text, node_id="{{ nodeId }}", reply_markup=keyboard)
    {%- else %}
    await message.answer(text, reply_markup=keyboard)
    {%- endif %}
    {%- endif %}
    {%- endif %}

    {%- else %}
    {# Стандартная обработка без условных сообщений #}
    {%- if messageText %}
    text = {{ messageText|format_python_text }}
    {%- else %}
    text = ""
    {%- endif %}

    # Универсальная замена переменных
    # Инициализация all_user_vars
    all_user_vars = await init_all_user_vars(user_id)

    # Добавляем переменные из таблиц БД
    {%- if hasUserIdsVariable %}
    user_ids_record = await get_user_ids_from_db(user_id)
    if user_ids_record:
        all_user_vars["user_ids"] = user_ids_record.get("user_ids", [])
        all_user_vars["user_ids_count"] = user_ids_record.get("count", 0)
    {%- endif %}

    # Заменяем переменные в тексте
    text = replace_variables_in_text(text, all_user_vars, {})

    {# Клавиатура #}
    {%- filter indent(4) %}{% include 'keyboard/keyboard.py.jinja2' %}{% endfilter %}

    {# Отправка медиафайлов или обычного сообщения #}
    {%- if (attachedMedia and attachedMedia|length > 0) or (imageUrl and imageUrl != 'undefined') or videoUrl or audioUrl or documentUrl %}
{%- filter indent(4) %}{% include 'attached-media/attached-media.py.jinja2' %}{% endfilter %}
    {%- else %}
    {%- if formatMode == 'html' %}
    {%- if userDatabaseEnabled %}
    await bot.send_message(message.chat.id, text, node_id="{{ nodeId }}", reply_markup=keyboard, parse_mode="HTML")
    {%- else %}
    await message.answer(text, reply_markup=keyboard, parse_mode="HTML")
    {%- endif %}
    {%- elif formatMode == 'markdown' %}
    {%- if userDatabaseEnabled %}
    await bot.send_message(message.chat.id, text, node_id="{{ nodeId }}", reply_markup=keyboard, parse_mode="Markdown")
    {%- else %}
    await message.answer(text, reply_markup=keyboard, parse_mode="Markdown")
    {%- endif %}
    {%- else %}
    {%- if userDatabaseEnabled %}
    await bot.send_message(message.chat.id, text, node_id="{{ nodeId }}", reply_markup=keyboard)
    {%- else %}
    await message.answer(text, reply_markup=keyboard)
    {%- endif %}
    {%- endif %}
    {%- endif %}

    {# Автопереход #}
    {%- if enableAutoTransition and autoTransitionTo %}
    # ⚡ АВТОПЕРЕХОД к {{ autoTransitionTo }}
    logging.info(f"⚡ Автопереход от узла {{ nodeId }} к узлу {{ autoTransitionTo }}")
    class FakeCallbackQuery:
        def __init__(self, message, target_node_id):
            self.from_user = message.from_user
            self.chat = message.chat
            self.date = message.date
            self.message_id = message.message_id
            self.data = target_node_id
            self.message = message
            self._is_fake = True

        async def answer(self, *args, **kwargs):
            pass

    fake_callback = FakeCallbackQuery(message, "{{ autoTransitionTo }}")
    try:
        await handle_callback_{{ autoTransitionTo|replace('-', '_') }}(fake_callback)
        logging.info(f"✅ Автопереход выполнен: {{ nodeId }} -> {{ autoTransitionTo }}")
    except Exception as e:
        logging.error(f"Ошибка при автопереходе к узлу {{ autoTransitionTo }}: {e}")
        await message.answer("Переход завершен")
    return
    {%- endif %}
    {%- endif %}

{# Обработчики синонимов #}
{%- if synonymEntries and synonymEntries|length > 0 %}
{% include 'synonyms/synonyms.py.jinja2' %}
{%- endif %}

{# Callback-обработчик для кнопок с goto → nodeId команды #}
@dp.callback_query(lambda c: c.data == "{{ nodeId }}" or c.data.startswith("{{ nodeId }}_btn_"))
async def handle_callback_{{ nodeId|replace('-', '_') }}(callback_query: types.CallbackQuery):
    """Обработчик callback перехода к команде {{ command }} (узел {{ nodeId }})"""
    try:
        await callback_query.answer()
    except Exception:
        pass

    {%- if isPrivateOnly %}
    if callback_query.message.chat.type != 'private':
        await callback_query.answer("❌ Эта команда доступна только в приватных чатах", show_alert=True)
        return
    {%- endif %}

    user_id = callback_query.from_user.id
    logging.info(f"🔵 Callback переход к команде {{ command }} (узел {{ nodeId }}) для пользователя {user_id}")

    # Создаём fake message для вызова основного обработчика команды
    from types import SimpleNamespace
    fake_message = SimpleNamespace()
    fake_message.from_user = callback_query.from_user
    fake_message.chat = callback_query.message.chat
    fake_message.date = callback_query.message.date
    fake_message.answer = callback_query.message.answer

    await {{ command|replace('/start', 'start')|replace('/help', 'help')|replace('/', '')|safe_name }}_handler(fake_message)
