{#
  Шаблон генерации кода для обработки флага hideAfterClick для reply кнопок
  @param {array} nodes - Все узлы для поиска кнопок с флагом hideAfterClick
  @param {string} indentLevel - Уровень отступа (по умолчанию '    ')
#}
{%- set indent = indentLevel or '    ' -%}
{%- set allHideAfterClickButtons = [] -%}
{%- for node in nodes -%}
{%- if node.data and node.data.buttons -%}
{%- for button in node.data.buttons -%}
{%- if button.hideAfterClick == true and (button.text or button.id) -%}
{%- set _ = allHideAfterClickButtons.push(button.text or button.id) -%}
{%- endif -%}
{%- endfor -%}
{%- endif -%}
{%- endfor -%}
{%- if allHideAfterClickButtons.length > 0 %}
{{ indent }}# Проверяем, является ли сообщение нажатием на reply-кнопку с флагом hideAfterClick
{{ indent }}message_text_lower = message.text.lower() if message.text else ""
{{ indent }}hide_after_click_texts = [{% for t in allHideAfterClickButtons %}"{{ t | lower }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{{ indent }}if message_text_lower in hide_after_click_texts:
{{ indent }}    try:
{{ indent }}        await bot.delete_message(chat_id=message.chat.id, message_id=message.message_id)
{{ indent }}        logging.info(f"🗑️ Сообщение пользователя удалено после нажатия reply-кнопки с флагом hideAfterClick: {message.text}")
{{ indent }}    except Exception as e:
{{ indent }}        logging.warning(f"⚠️ Не удалось удалить сообщение пользователя с reply-кнопкой hideAfterClick: {e}")
{{ indent }}    return
{%- endif -%}
