{#
  Шаблон обработчика анимации (GIF)

  @fileoverview Генерирует Python-код полноценного обработчика анимации (GIF).

  @param {string} animationUrl — URL анимации (GIF)
  @param {string} nodeId       — ID узла
#}
@dp.message(F.animation)
async def handle_animation_{{ nodeId|safe_name }}(message: types.Message):
    """Обработчик анимации для узла {{ nodeId }}"""
    user_id = message.from_user.id
    text = ""
    parse_mode = None
{%- if animationUrl %}
    try:
{%- if animationUrl and animationUrl.startswith('/uploads/') %}
        animation_path = get_upload_file_path("{{ animationUrl }}")
        animation_file = FSInputFile(animation_path)
        await bot.send_animation(message.chat.id, animation_file, caption=text, parse_mode=parse_mode)
{%- else %}
        await bot.send_animation(message.chat.id, "{{ animationUrl }}", caption=text, parse_mode=parse_mode)
{%- endif %}
        await save_message_to_api(
            user_id=str(user_id),
            message_type="bot",
            message_text="[Анимация]",
            node_id="{{ nodeId }}"
        )
    except Exception as e:
        logging.error(f"Ошибка отправки анимации: {e}")
        await message.answer("Произошла ошибка при отправке анимации")
{%- else %}
    await message.answer("Анимация не настроена")
{%- endif %}
