{#
  @fileoverview Шаблон HTTP запроса к внешнему API.
  Генерирует callback-обработчик, который выполняет HTTP запрос через aiohttp
  и сохраняет ответ в переменную пользователя.
#}

# Обработчик HTTP запроса: {{ nodeId }}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ safeName }}(callback_query: types.CallbackQuery):
    """Выполняет HTTP запрос и сохраняет ответ в переменную."""
    user_id = callback_query.from_user.id
    await init_user_variables(user_id, callback_query.from_user)
    _all_vars = await init_all_user_vars(user_id)

    # Подставляем переменные в URL
    _url = "{{ url }}"
    _url = replace_variables_in_text(_url, _all_vars, {})

    {% if queryParams %}
    # Query параметры
    try:
        import json as _json_mod
        _qp_raw = """{{ queryParams }}"""
        for _k, _v in _all_vars.items():
            _qp_raw = _qp_raw.replace("{" + _k + "}", str(_v))
        _qp_list = _json_mod.loads(_qp_raw)
        if _qp_list:
            from urllib.parse import urlencode as _urlencode
            _qp_dict = {p['key']: p['value'] for p in _qp_list if p.get('key')}
            if _qp_dict:
                _sep = '&' if '?' in _url else '?'
                _url = _url + _sep + _urlencode(_qp_dict)
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга query params: {_e}")
    {% endif %}

    # Заголовки
    _headers = {}
    {% if headers %}
    try:
        import json as _json_mod
        _headers_raw = """{{ headers }}"""
        for _k, _v in _all_vars.items():
            _headers_raw = _headers_raw.replace("{" + _k + "}", str(_v))
        _headers = _json_mod.loads(_headers_raw)
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга заголовков: {_e}")
    {% endif %}

    # Аутентификация
    {% if authType == 'bearer' and authBearerToken %}
    _headers['Authorization'] = 'Bearer {{ authBearerToken }}'
    {% elif authType == 'basic' and authBasicUsername %}
    import base64 as _base64
    _basic_creds = _base64.b64encode(f'{{ authBasicUsername }}:{{ authBasicPassword }}'.encode()).decode()
    _headers['Authorization'] = f'Basic {_basic_creds}'
    {% elif authType == 'header' and authHeaderName %}
    _headers['{{ authHeaderName }}'] = '{{ authHeaderValue }}'
    {% elif authType == 'query' and authQueryName %}
    _sep = '&' if '?' in _url else '?'
    _url = _url + _sep + '{{ authQueryName }}={{ authQueryValue }}'
    {% endif %}

    # Тело запроса
    _body = None
    _body_form = None
    _body_raw = None
    {% if body and method in ['POST', 'PUT', 'PATCH'] %}
    try:
        import json as _json_mod
        _body_raw_str = """{{ body }}"""
        _body_raw_str = replace_variables_in_text(_body_raw_str, _all_vars, {})
        {% if bodyFormat == 'json' %}
        _body = _json_mod.loads(_body_raw_str)
        {% elif bodyFormat == 'form-urlencoded' %}
        _body_form = _body_raw_str
        _headers['Content-Type'] = 'application/x-www-form-urlencoded'
        {% else %}
        _body_raw = _body_raw_str
        {% endif %}
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга тела: {_e}")
    {% endif %}

    logging.info(f"🌐 http_request [{{ nodeId }}]: {{ method }} {_url} | user_id={user_id}")

    _response_data = None
    _status_code = 0
    try:
        import aiohttp as _aiohttp
        _connector = _aiohttp.TCPConnector(ssl={{ 'False' if ignoreSsl else 'True' }})
        async with _aiohttp.ClientSession(connector=_connector) as _session:
            async with _session.{{ method | lower }}(
                _url,
                headers=_headers or None,
                {% if bodyFormat == 'json' %}json=_body,{% endif %}
                {% if bodyFormat == 'form-urlencoded' %}data=_body_form,{% endif %}
                {% if bodyFormat == 'raw' %}data=_body_raw,{% endif %}
                timeout=_aiohttp.ClientTimeout(total={{ timeout }}),
                allow_redirects={{ 'True' if followRedirects else 'False' }}
            ) as _resp:
                _status_code = _resp.status
                {% if responseFormat == 'json' %}
                _response_data = await _resp.json(content_type=None)
                {% elif responseFormat == 'text' %}
                _response_data = await _resp.text()
                {% else %}
                try:
                    _response_data = await _resp.json(content_type=None)
                except Exception:
                    _response_data = await _resp.text()
                {% endif %}
                {% if ignoreHttpErrors %}
                # Ошибки HTTP 4xx/5xx игнорируются
                {% endif %}
                logging.info(
                    f"✅ http_request [{{ nodeId }}]: статус={_status_code} | user_id={user_id}"
                )
    except Exception as _e:
        logging.error(f"❌ http_request [{{ nodeId }}]: ошибка запроса: {_e} | user_id={user_id}")

    # Сохраняем ответ
    await set_user_var(user_id, "{{ responseVariable }}", _response_data)
    {% if statusVariable %}
    await set_user_var(user_id, "{{ statusVariable }}", str(_status_code))
    {% endif %}

    try:
        await callback_query.answer()
    except Exception:
        pass

    {% if autoTransitionTo %}
    {% if autoTransitionTargetExists %}
    await handle_callback_{{ autoTransitionTo | replace('-', '_') | replace('.', '_') }}(callback_query)
    {% else %}
    logging.warning(f"⚠️ http_request [{{ nodeId }}]: узел автоперехода не найден: {{ autoTransitionTo }}")
    {% endif %}
    {% endif %}
