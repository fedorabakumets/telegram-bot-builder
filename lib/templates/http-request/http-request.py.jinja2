{#
  @fileoverview Шаблон HTTP запроса к внешнему API.
  Генерирует callback-обработчик, который выполняет HTTP запрос через aiohttp,
  сохраняет ответ в переменную пользователя и автоматически сохраняет
  скалярные поля словаря-ответа как плоские переменные вида responseVariable.field.
  Это позволяет использовать {response_var.field} в URL и текстах последующих узлов.

  @fsm Принимает опциональный state: FSMContext = None.
       Читает FSM-данные поверх user_data (FSM имеет приоритет).
       Передаёт state при автопереходе.
#}

# Обработчик HTTP запроса: {{ nodeId }}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ safeName }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Выполняет HTTP запрос и сохраняет ответ в переменную."""
    user_id = callback_query.from_user.id
    await init_user_variables(user_id, callback_query.from_user)

    # Сразу убираем анимацию загрузки — не ждём завершения HTTP-запроса
    try:
        await callback_query.answer()
    except Exception:
        pass

    _all_vars = await init_all_user_vars(user_id)
    # Читаем данные из FSM если доступен — они имеют приоритет над user_data
    if state is not None:
        try:
            _fsm_data = await state.get_data()
            if _fsm_data:
                _all_vars.update(_fsm_data)
        except Exception:
            pass

    {% if enableBatch %}
    # === BATCH MODE: параллельные запросы по массиву ===
    import json as _json_batch
    _batch_items = _all_vars.get("{{ batchSource }}", [])
    if isinstance(_batch_items, str):
        try:
            _batch_items = _json_batch.loads(_batch_items)
        except Exception:
            _batch_items = []
    if not isinstance(_batch_items, list):
        _batch_items = []

    async def _batch_fetch_one(_b_item, _b_all_vars):
        _local_vars = dict(_b_all_vars)
        if isinstance(_b_item, dict):
            for _bk, _bv in _b_item.items():
                _local_vars[f"{{ batchItemVar }}.{_bk}"] = str(_bv) if _bv is not None else ""
        _local_vars["{{ batchItemVar }}"] = _b_item if isinstance(_b_item, dict) else str(_b_item)

        _b_url = replace_variables_in_text("{{ url }}", _local_vars, {})

        {% if queryParams %}
        try:
            _qp_raw = """{{ queryParams }}"""
            for _k, _v in _local_vars.items():
                _qp_raw = _qp_raw.replace("{" + _k + "}", str(_v))
            _qp_list = _json_batch.loads(_qp_raw)
            if _qp_list:
                from urllib.parse import urlencode as _urlencode
                _qp_dict = {p['key']: p['value'] for p in _qp_list if p.get('key')}
                if _qp_dict:
                    _sep = '&' if '?' in _b_url else '?'
                    _b_url = _b_url + _sep + _urlencode(_qp_dict)
        except Exception:
            pass
        {% endif %}

        _b_headers = {}
        {% if headers %}
        try:
            _h_raw = """{{ headers }}"""
            for _k, _v in _local_vars.items():
                _h_raw = _h_raw.replace("{" + _k + "}", str(_v))
            _b_headers = _json_batch.loads(_h_raw)
        except Exception:
            pass
        {% endif %}

        _b_extracted = None
        _b_status = 0
        try:
            import aiohttp as _aiohttp_b
            _b_connector = _aiohttp_b.TCPConnector(ssl={{ 'False' if ignoreSsl else 'True' }})
            async with _aiohttp_b.ClientSession(connector=_b_connector) as _b_session:
                async with _b_session.{{ method | lower }}(
                    _b_url,
                    headers=_b_headers or None,
                    timeout=_aiohttp_b.ClientTimeout(total={{ timeout }}),
                    allow_redirects={{ 'True' if followRedirects else 'False' }}
                ) as _b_resp:
                    _b_status = _b_resp.status
                    try:
                        _b_data = await _b_resp.json(content_type=None)
                    except Exception:
                        _b_text = await _b_resp.text()
                        _b_ct = _b_resp.headers.get('Content-Type', '')
                        if 'xml' in _b_ct or _b_text.strip().startswith('<?xml') or _b_text.strip().startswith('<'):
                            try:
                                import xml.etree.ElementTree as _ET_b
                                _xml_root_b = _ET_b.fromstring(_b_text)
                                def _xml_to_dict_b(el):
                                    children = list(el)
                                    if not children:
                                        return el.text.strip() if el.text and el.text.strip() else ""
                                    _groups = {}
                                    for child in children:
                                        tag = child.tag
                                        if tag not in _groups:
                                            _groups[tag] = []
                                        _groups[tag].append(_xml_to_dict_b(child))
                                    _result = {}
                                    for tag, items in _groups.items():
                                        _result[tag] = items[0] if len(items) == 1 else items
                                    return _result
                                _b_data = _xml_to_dict_b(_xml_root_b)
                            except Exception:
                                _b_data = _b_text
                        else:
                            _b_data = _b_text

                    {% if responseJsonPath %}
                    _b_json_path = replace_variables_in_text("{{ responseJsonPath }}", _local_vars, {})
                    _b_extracted_val = _b_data
                    for _seg in _b_json_path.split('.'):
                        if _seg and _b_extracted_val is not None:
                            if _seg.startswith('?') and isinstance(_b_extracted_val, list):
                                _f_str = _seg[1:]
                                _f_conds = {}
                                for _fc in _f_str.split('&'):
                                    if '=' in _fc:
                                        _fk, _fv = _fc.split('=', 1)
                                        _f_conds[_fk] = _fv
                                _found = None
                                for _fi in _b_extracted_val:
                                    if isinstance(_fi, dict) and all(str(_fi.get(_ck, '')) == _cv for _ck, _cv in _f_conds.items()):
                                        _found = _fi
                                        break
                                _b_extracted_val = _found
                            elif isinstance(_b_extracted_val, dict):
                                _b_extracted_val = _b_extracted_val.get(_seg)
                            elif isinstance(_b_extracted_val, list) and _seg.isdigit():
                                _b_extracted_val = _b_extracted_val[int(_seg)]
                            else:
                                _b_extracted_val = None
                                break
                    _b_extracted = str(_b_extracted_val) if _b_extracted_val is not None else ""
                    {% else %}
                    _b_extracted = str(_b_data) if _b_data is not None else ""
                    {% endif %}
        except Exception as _b_err:
            logging.warning(f"batch http_request [{{ nodeId }}]: error for {_b_url}: {_b_err}")
            _b_extracted = ""

        _b_result = {}
        {% for field in batchResultFields %}
        {% if field.value == '__extracted__' %}
        _b_result["{{ field.key }}"] = _b_extracted
        {% elif field.value == '__extracted_int__' %}
        try:
            _b_result["{{ field.key }}"] = str(int(float(_b_extracted))) if _b_extracted else "0"
        except (ValueError, TypeError):
            _b_result["{{ field.key }}"] = "0"
        {% elif field.value == '__extracted_float__' %}
        _b_result["{{ field.key }}"] = _b_extracted if _b_extracted else "0"
        {% elif "={{" in field.value %}
        # Вычисляем выражение в значении поля
        _b_expr_vars = dict(_local_vars)
        _b_expr_vars["__extracted__"] = _b_extracted or "0"
        _b_field_tpl = {{ field.value | tojson }}
        _b_field_str = replace_variables_in_text(_b_field_tpl, _b_expr_vars, {})
        _b_re_sub = getattr(__import__('re'), 'sub')
        def _b_resolve(_m):
            try:
                return str(_eval_expr(_m.group(1), _b_expr_vars))
            except Exception:
                return "0"
        _b_result["{{ field.key }}"] = _b_re_sub({% raw %}r'=\{\{(.+?)\}\}'{% endraw %}, _b_resolve, _b_field_str)
        {% else %}
        _b_result["{{ field.key }}"] = replace_variables_in_text("{{ field.value }}", _local_vars, {})
        {% endif %}
        {% endfor %}
        return _b_result

    _batch_results = await asyncio.gather(*[_batch_fetch_one(_bi, _all_vars) for _bi in _batch_items])
    _batch_results = [r for r in _batch_results if r is not None]
    await set_user_var(user_id, "{{ batchResultVariable }}", list(_batch_results))
    logging.info(f"batch http_request [{{ nodeId }}]: {len(_batch_results)} results saved to {{ batchResultVariable }}")

    {% if autoTransitionTo and autoTransitionTargetExists %}
    class _FakeCb:
        def __init__(self, data, user, msg):
            self.data = data
            self.from_user = user
            self.message = msg
        async def answer(self, *a, **kw):
            pass
    _fake_cb = _FakeCb("{{ autoTransitionTo }}", callback_query.from_user, callback_query.message)
    await handle_callback_{{ autoTransitionTo | replace('-', '_') | replace('.', '_') }}(_fake_cb, state=state)
    {% endif %}
    return
    {% endif %}

    {% if enablePagination and paginationMode == 'interactive' and paginationOffsetVar %}
    # Инициализируем переменную offset если не задана или не является числом (первый вход в список)
    _pag_offset_raw = str(_all_vars.get("{{ paginationOffsetVar }}", "") or "")
    if not _pag_offset_raw.strip().lstrip('-').isdigit():
        _all_vars["{{ paginationOffsetVar }}"] = "0"
        await set_user_var(user_id, "{{ paginationOffsetVar }}", "0")
    {% endif %}

    # Подставляем переменные в URL
    _url = "{{ url }}"
    _url = replace_variables_in_text(_url, _all_vars, {})

    {% if queryParams %}
    # Query параметры
    try:
        import json as _json_mod
        _qp_raw = """{{ queryParams }}"""
        for _k, _v in _all_vars.items():
            _qp_raw = _qp_raw.replace("{" + _k + "}", str(_v))
        _qp_list = _json_mod.loads(_qp_raw)
        if _qp_list:
            from urllib.parse import urlencode as _urlencode
            _qp_dict = {p['key']: p['value'] for p in _qp_list if p.get('key')}
            if _qp_dict:
                _sep = '&' if '?' in _url else '?'
                _url = _url + _sep + _urlencode(_qp_dict)
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга query params: {_e}")
    {% endif %}

    # Заголовки
    _headers = {}
    {% if headers %}
    try:
        import json as _json_mod
        _headers_raw = """{{ headers }}"""
        for _k, _v in _all_vars.items():
            _headers_raw = _headers_raw.replace("{" + _k + "}", str(_v))
        _headers = _json_mod.loads(_headers_raw)
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга заголовков: {_e}")
    {% endif %}

    # Аутентификация
    {% if authType == 'bearer' and authBearerToken %}
    _headers['Authorization'] = 'Bearer {{ authBearerToken }}'
    {% elif authType == 'basic' and authBasicUsername %}
    import base64 as _base64
    _basic_creds = _base64.b64encode(f'{{ authBasicUsername }}:{{ authBasicPassword }}'.encode()).decode()
    _headers['Authorization'] = f'Basic {_basic_creds}'
    {% elif authType == 'header' and authHeaderName %}
    _headers['{{ authHeaderName }}'] = '{{ authHeaderValue }}'
    {% elif authType == 'query' and authQueryName %}
    _sep = '&' if '?' in _url else '?'
    _url = _url + _sep + '{{ authQueryName }}={{ authQueryValue }}'
    {% endif %}

    # Тело запроса
    _body = None
    _body_form = None
    _body_raw = None
    {% if body and method in ['POST', 'PUT', 'PATCH'] %}
    try:
        import json as _json_mod
        _body_raw_str = """{{ body }}"""
        _body_raw_str = replace_variables_in_text(_body_raw_str, _all_vars, {})
        {% if bodyFormat == 'json' %}
        _body = _json_mod.loads(_body_raw_str)
        {% elif bodyFormat == 'form-urlencoded' %}
        _body_form = _body_raw_str
        _headers['Content-Type'] = 'application/x-www-form-urlencoded'
        {% else %}
        _body_raw = _body_raw_str
        {% endif %}
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга тела: {_e}")
    {% endif %}

    logging.info(f"🌐 http_request [{{ nodeId }}]: {{ method }} {_url} | user_id={user_id}")

    _response_data = None
    _status_code = 0
    try:
        import aiohttp as _aiohttp
        _connector = _aiohttp.TCPConnector(ssl={{ 'False' if ignoreSsl else 'True' }})
        async with _aiohttp.ClientSession(connector=_connector) as _session:
            async with _session.{{ method | lower }}(
                _url,
                headers=_headers or None,
                {% if bodyFormat == 'json' %}json=_body,{% endif %}
                {% if bodyFormat == 'form-urlencoded' %}data=_body_form,{% endif %}
                {% if bodyFormat == 'raw' %}data=_body_raw,{% endif %}
                timeout=_aiohttp.ClientTimeout(total={{ timeout }}),
                allow_redirects={{ 'True' if followRedirects else 'False' }}
            ) as _resp:
                _status_code = _resp.status
                {% if responseFormat == 'file' %}
                # Читаем ответ как JSON-объект типа file {type, data, mimeType, fileName}
                # Апишник уже возвращает base64 в поле data — не перекодируем
                try:
                    _response_data = await _resp.json(content_type=None)
                except Exception:
                    # Fallback: если ответ бинарный — кодируем сами
                    _resp_bytes = await _resp.read()
                    import base64 as _b64
                    _resp_content_type = _resp.headers.get('Content-Type', 'application/octet-stream').split(';')[0].strip()
                    _resp_filename = ""
                    _cd = _resp.headers.get('Content-Disposition', '')
                    if 'filename=' in _cd:
                        _resp_filename = _cd.split('filename=')[-1].strip().strip('"\'')
                    if not _resp_filename:
                        _resp_filename = _url.split('/')[-1].split('?')[0] or "file"
                    _response_data = {
                        "type": "file",
                        "data": _b64.b64encode(_resp_bytes).decode('utf-8'),
                        "mimeType": _resp_content_type,
                        "fileName": _resp_filename,
                    }
                {% elif responseFormat == 'xml' %}
                # Парсим XML-ответ в словарь
                _xml_text = await _resp.text()
                try:
                    import xml.etree.ElementTree as _ET
                    _xml_root = _ET.fromstring(_xml_text)
                    def _xml_to_dict(el):
                        """Рекурсивно конвертирует XML-элемент в dict/list."""
                        children = list(el)
                        if not children:
                            return el.text.strip() if el.text and el.text.strip() else ""
                        # Группируем дочерние элементы по тегу
                        _groups = {}
                        for child in children:
                            tag = child.tag
                            if tag not in _groups:
                                _groups[tag] = []
                            _groups[tag].append(_xml_to_dict(child))
                        # Если тег повторяется — оставляем как список, иначе разворачиваем
                        _result = {}
                        for tag, items in _groups.items():
                            if len(items) == 1:
                                _result[tag] = items[0]
                            else:
                                _result[tag] = items
                        return _result
                    _response_data = _xml_to_dict(_xml_root)
                except Exception as _xml_err:
                    logging.warning(f"⚠️ http_request [{{ nodeId }}]: ошибка парсинга XML: {_xml_err}")
                    _response_data = _xml_text
                {% elif responseFormat == 'json' %}
                _response_data = await _resp.json(content_type=None)
                {% elif responseFormat == 'text' %}
                _response_data = await _resp.text()
                {% else %}
                try:
                    _response_data = await _resp.json(content_type=None)
                except Exception:
                    _resp_text = await _resp.text()
                    _ct = _resp.headers.get('Content-Type', '')
                    if 'xml' in _ct or _resp_text.strip().startswith('<?xml') or _resp_text.strip().startswith('<'):
                        try:
                            import xml.etree.ElementTree as _ET
                            _xml_root = _ET.fromstring(_resp_text)
                            def _xml_to_dict_auto(el):
                                children = list(el)
                                if not children:
                                    return el.text.strip() if el.text and el.text.strip() else ""
                                _groups = {}
                                for child in children:
                                    tag = child.tag
                                    if tag not in _groups:
                                        _groups[tag] = []
                                    _groups[tag].append(_xml_to_dict_auto(child))
                                _result = {}
                                for tag, items in _groups.items():
                                    _result[tag] = items if len(items) > 1 else items[0]
                                return _result
                            _response_data = _xml_to_dict_auto(_xml_root)
                        except Exception:
                            _response_data = _resp_text
                    else:
                        _response_data = _resp_text
                {% endif %}
                {% if ignoreHttpErrors %}
                # Ошибки HTTP 4xx/5xx игнорируются
                {% endif %}
                logging.info(
                    f"✅ http_request [{{ nodeId }}]: статус={_status_code} | user_id={user_id}"
                )
    except Exception as _e:
        logging.error(f"❌ http_request [{{ nodeId }}]: ошибка запроса: {_e} | user_id={user_id}")

    # Сбрасываем старые значения response-переменных перед новым запросом
    if user_id in user_data:
        user_data[user_id].pop("{{ responseVariable }}", None)
        {% if statusVariable %}
        user_data[user_id].pop("{{ statusVariable }}", None)
        {% endif %}

    # Сохраняем ответ
    await set_user_var(user_id, "{{ responseVariable }}", _response_data)
    # Автоматически сохраняем скалярные поля ответа как плоские переменные.
    # Позволяет использовать {responseVariable.field} в URL и текстах узлов.
    if isinstance(_response_data, dict):
        for _fk, _fv in _response_data.items():
            if isinstance(_fv, (str, int, float, bool)) and _fv is not None:
                await set_user_var(user_id, "{{ responseVariable }}." + _fk, str(_fv))
    {% if statusVariable %}
    await set_user_var(user_id, "{{ statusVariable }}", str(_status_code))
    {% endif %}

    {% if responseJsonPath and responseExtractTo %}
    # Извлечение значения по JSON-пути (поддерживает фильтрацию массива: ?field=value&field2=value2)
    try:
        _json_path_raw = "{{ responseJsonPath }}"
        _json_path_resolved = replace_variables_in_text(_json_path_raw, await init_all_user_vars(user_id), {})
        _extracted = _response_data
        for _path_seg in _json_path_resolved.split('.'):
            if _path_seg and _extracted is not None:
                if _path_seg.startswith('?') and isinstance(_extracted, list):
                    # Фильтрация массива: ?field=value&field2=value2
                    _filter_str = _path_seg[1:]
                    _filter_conds = {}
                    for _fc in _filter_str.split('&'):
                        if '=' in _fc:
                            _fk_f, _fv_f = _fc.split('=', 1)
                            _filter_conds[_fk_f] = _fv_f
                    _found_item = None
                    for _item in _extracted:
                        if isinstance(_item, dict) and all(str(_item.get(_ck, '')) == _cv for _ck, _cv in _filter_conds.items()):
                            _found_item = _item
                            break
                    _extracted = _found_item
                elif isinstance(_extracted, dict):
                    _extracted = _extracted.get(_path_seg)
                elif isinstance(_extracted, list) and _path_seg.isdigit():
                    _extracted = _extracted[int(_path_seg)]
                else:
                    _extracted = None
                    break
        _extract_val = str(_extracted) if _extracted is not None else ""
        await set_user_var(user_id, "{{ responseExtractTo }}", _extract_val)
        logging.info(f"📎 http_request [{{ nodeId }}]: извлечено {{ responseExtractTo }}={_extract_val!r} по пути {_json_path_resolved}")
    except Exception as _extract_err:
        logging.warning(f"⚠️ http_request [{{ nodeId }}]: ошибка извлечения по пути: {_extract_err}")
        await set_user_var(user_id, "{{ responseExtractTo }}", "")
    {% endif %}

    {% if enablePagination and paginationMode == 'interactive' %}
    # Интерактивная пагинация — вычисляем nextOffset и prevOffset
    if isinstance(_response_data, dict):
        _pag_total = _response_data.get("{{ paginationTotalField }}", 0)
        try:
            _pag_total = int(_pag_total)
        except (ValueError, TypeError):
            _pag_total = 0
        _pag_offset = 0
        {% if paginationOffsetVar %}
        try:
            _pag_offset = int(_all_vars.get("{{ paginationOffsetVar }}", 0) or 0)
        except (ValueError, TypeError):
            _pag_offset = 0
        {% endif %}
        _pag_limit = {{ paginationLimit }}
        _next_offset = _pag_offset + _pag_limit if _pag_offset + _pag_limit < _pag_total else None
        _prev_offset = max(0, _pag_offset - _pag_limit) if _pag_offset > 0 else None
        await set_user_var(user_id, "{{ responseVariable }}.nextOffset", str(_next_offset) if _next_offset is not None else "")
        await set_user_var(user_id, "{{ responseVariable }}.prevOffset", str(_prev_offset) if _prev_offset is not None else "")
        await set_user_var(user_id, "{{ responseVariable }}.currentPage", str(_pag_offset // _pag_limit + 1))
        await set_user_var(user_id, "{{ responseVariable }}.totalPages", str((_pag_total + _pag_limit - 1) // _pag_limit) if _pag_total > 0 else "0")
    {% endif %}

    {% if enablePagination and paginationMode == 'fetch_all' %}
    # Режим fetch_all — собираем все страницы в один массив
    if isinstance(_response_data, dict) and "{{ paginationItemsField }}" in _response_data:
        _all_items = list(_response_data.get("{{ paginationItemsField }}", []))
        _fa_total = int(_response_data.get("{{ paginationTotalField }}", 0) or 0)
        _fa_limit = {{ paginationLimit }}
        _fa_max_pages = {{ paginationMaxPages }}
        _fa_offset = _fa_limit
        _fa_page = 1
        while _fa_offset < _fa_total and _fa_page < _fa_max_pages:
            try:
                _fa_url = "{{ url }}"
                _fa_url = replace_variables_in_text(_fa_url, _all_vars, {})
                _fa_sep = '&' if '?' in _fa_url else '?'
                _fa_url = _fa_url + _fa_sep + f"limit={_fa_limit}&offset={_fa_offset}"
                import aiohttp as _aiohttp2
                async with _aiohttp2.ClientSession() as _fa_session:
                    async with _fa_session.get(
                        _fa_url,
                        headers=_headers or None,
                        timeout=_aiohttp2.ClientTimeout(total={{ timeout }})
                    ) as _fa_resp:
                        _fa_data = await _fa_resp.json(content_type=None)
                        _fa_items = _fa_data.get("{{ paginationItemsField }}", [])
                        if not _fa_items:
                            break
                        _all_items.extend(_fa_items)
            except Exception as _fa_e:
                logging.warning(f"http_request [{{ nodeId }}] fetch_all страница {_fa_page + 1}: {_fa_e}")
                break
            _fa_offset += _fa_limit
            _fa_page += 1
        # Сохраняем полный список поверх ответа
        _response_data["{{ paginationItemsField }}"] = _all_items
        _response_data["{{ paginationTotalField }}"] = len(_all_items)
        await set_user_var(user_id, "{{ responseVariable }}", _response_data)
        await set_user_var(user_id, "{{ responseVariable }}.{{ paginationTotalField }}", str(len(_all_items)))
        logging.info(f"📦 http_request [{{ nodeId }}] fetch_all: собрано {len(_all_items)} элементов за {_fa_page} страниц")
    {% endif %}

    {% if autoTransitionTo %}
    {% if autoTransitionTargetExists %}
