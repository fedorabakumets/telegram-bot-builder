{#
  @fileoverview Шаблон HTTP запроса к внешнему API.
  Генерирует callback-обработчик, который выполняет HTTP запрос через aiohttp,
  сохраняет ответ в переменную пользователя и автоматически сохраняет
  скалярные поля словаря-ответа как плоские переменные вида responseVariable.field.
  Это позволяет использовать {response_var.field} в URL и текстах последующих узлов.

  @fsm Принимает опциональный state: FSMContext = None.
       Читает FSM-данные поверх user_data (FSM имеет приоритет).
       Передаёт state при автопереходе.
#}

# Обработчик HTTP запроса: {{ nodeId }}

@dp.callback_query(lambda c: c.data == "{{ nodeId }}")
async def handle_callback_{{ safeName }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Выполняет HTTP запрос и сохраняет ответ в переменную."""
    user_id = callback_query.from_user.id
    await init_user_variables(user_id, callback_query.from_user)

    # Сразу убираем анимацию загрузки — не ждём завершения HTTP-запроса
    try:
        await callback_query.answer()
    except Exception:
        pass

    _all_vars = await init_all_user_vars(user_id)
    # Читаем данные из FSM если доступен — они имеют приоритет над user_data
    if state is not None:
        try:
            _fsm_data = await state.get_data()
            if _fsm_data:
                _all_vars.update(_fsm_data)
        except Exception:
            pass

    {% if enablePagination and paginationMode == 'interactive' and paginationOffsetVar %}
    # Инициализируем переменную offset если не задана или не является числом (первый вход в список)
    _pag_offset_raw = str(_all_vars.get("{{ paginationOffsetVar }}", "") or "")
    if not _pag_offset_raw.strip().lstrip('-').isdigit():
        _all_vars["{{ paginationOffsetVar }}"] = "0"
        await set_user_var(user_id, "{{ paginationOffsetVar }}", "0")
    {% endif %}

    # Подставляем переменные в URL
    _url = "{{ url }}"
    _url = replace_variables_in_text(_url, _all_vars, {})

    {% if queryParams %}
    # Query параметры
    try:
        import json as _json_mod
        _qp_raw = """{{ queryParams }}"""
        for _k, _v in _all_vars.items():
            _qp_raw = _qp_raw.replace("{" + _k + "}", str(_v))
        _qp_list = _json_mod.loads(_qp_raw)
        if _qp_list:
            from urllib.parse import urlencode as _urlencode
            _qp_dict = {p['key']: p['value'] for p in _qp_list if p.get('key')}
            if _qp_dict:
                _sep = '&' if '?' in _url else '?'
                _url = _url + _sep + _urlencode(_qp_dict)
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга query params: {_e}")
    {% endif %}

    # Заголовки
    _headers = {}
    {% if headers %}
    try:
        import json as _json_mod
        _headers_raw = """{{ headers }}"""
        for _k, _v in _all_vars.items():
            _headers_raw = _headers_raw.replace("{" + _k + "}", str(_v))
        _headers = _json_mod.loads(_headers_raw)
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга заголовков: {_e}")
    {% endif %}

    # Аутентификация
    {% if authType == 'bearer' and authBearerToken %}
    _headers['Authorization'] = 'Bearer {{ authBearerToken }}'
    {% elif authType == 'basic' and authBasicUsername %}
    import base64 as _base64
    _basic_creds = _base64.b64encode(f'{{ authBasicUsername }}:{{ authBasicPassword }}'.encode()).decode()
    _headers['Authorization'] = f'Basic {_basic_creds}'
    {% elif authType == 'header' and authHeaderName %}
    _headers['{{ authHeaderName }}'] = '{{ authHeaderValue }}'
    {% elif authType == 'query' and authQueryName %}
    _sep = '&' if '?' in _url else '?'
    _url = _url + _sep + '{{ authQueryName }}={{ authQueryValue }}'
    {% endif %}

    # Тело запроса
    _body = None
    _body_form = None
    _body_raw = None
    {% if body and method in ['POST', 'PUT', 'PATCH'] %}
    try:
        import json as _json_mod
        _body_raw_str = """{{ body }}"""
        _body_raw_str = replace_variables_in_text(_body_raw_str, _all_vars, {})
        {% if bodyFormat == 'json' %}
        _body = _json_mod.loads(_body_raw_str)
        {% elif bodyFormat == 'form-urlencoded' %}
        _body_form = _body_raw_str
        _headers['Content-Type'] = 'application/x-www-form-urlencoded'
        {% else %}
        _body_raw = _body_raw_str
        {% endif %}
    except Exception as _e:
        logging.warning(f"http_request [{{ nodeId }}]: ошибка парсинга тела: {_e}")
    {% endif %}

    logging.info(f"🌐 http_request [{{ nodeId }}]: {{ method }} {_url} | user_id={user_id}")

    _response_data = None
    _status_code = 0
    try:
        import aiohttp as _aiohttp
        _connector = _aiohttp.TCPConnector(ssl={{ 'False' if ignoreSsl else 'True' }})
        async with _aiohttp.ClientSession(connector=_connector) as _session:
            async with _session.{{ method | lower }}(
                _url,
                headers=_headers or None,
                {% if bodyFormat == 'json' %}json=_body,{% endif %}
                {% if bodyFormat == 'form-urlencoded' %}data=_body_form,{% endif %}
                {% if bodyFormat == 'raw' %}data=_body_raw,{% endif %}
                timeout=_aiohttp.ClientTimeout(total={{ timeout }}),
                allow_redirects={{ 'True' if followRedirects else 'False' }}
            ) as _resp:
                _status_code = _resp.status
                {% if responseFormat == 'file' %}
                # Читаем ответ как бинарные данные и кодируем в base64
                _resp_bytes = await _resp.read()
                import base64 as _b64
                _resp_content_type = _resp.headers.get('Content-Type', 'application/octet-stream').split(';')[0].strip()
                _resp_filename = ""
                _cd = _resp.headers.get('Content-Disposition', '')
                if 'filename=' in _cd:
                    _resp_filename = _cd.split('filename=')[-1].strip().strip('"\'')
                if not _resp_filename:
                    _resp_filename = _url.split('/')[-1].split('?')[0] or "file"
                _response_data = {
                    "type": "file",
                    "data": _b64.b64encode(_resp_bytes).decode('utf-8'),
                    "mimeType": _resp_content_type,
                    "fileName": _resp_filename,
                }
                {% elif responseFormat == 'json' %}
                _response_data = await _resp.json(content_type=None)
                {% elif responseFormat == 'text' %}
                _response_data = await _resp.text()
                {% else %}
                try:
                    _response_data = await _resp.json(content_type=None)
                except Exception:
                    _response_data = await _resp.text()
                {% endif %}
                {% if ignoreHttpErrors %}
                # Ошибки HTTP 4xx/5xx игнорируются
                {% endif %}
                logging.info(
                    f"✅ http_request [{{ nodeId }}]: статус={_status_code} | user_id={user_id}"
                )
    except Exception as _e:
        logging.error(f"❌ http_request [{{ nodeId }}]: ошибка запроса: {_e} | user_id={user_id}")

    # Сбрасываем старые значения response-переменных перед новым запросом
    if user_id in user_data:
        user_data[user_id].pop("{{ responseVariable }}", None)
        {% if statusVariable %}
        user_data[user_id].pop("{{ statusVariable }}", None)
        {% endif %}

    # Сохраняем ответ
    await set_user_var(user_id, "{{ responseVariable }}", _response_data)
    # Автоматически сохраняем скалярные поля ответа как плоские переменные.
    # Позволяет использовать {responseVariable.field} в URL и текстах узлов.
    if isinstance(_response_data, dict):
        for _fk, _fv in _response_data.items():
            if isinstance(_fv, (str, int, float, bool)) and _fv is not None:
                await set_user_var(user_id, "{{ responseVariable }}." + _fk, str(_fv))
    {% if statusVariable %}
    await set_user_var(user_id, "{{ statusVariable }}", str(_status_code))
    {% endif %}

    {% if enablePagination and paginationMode == 'interactive' %}
    # Интерактивная пагинация — вычисляем nextOffset и prevOffset
    if isinstance(_response_data, dict):
        _pag_total = _response_data.get("{{ paginationTotalField }}", 0)
        try:
            _pag_total = int(_pag_total)
        except (ValueError, TypeError):
            _pag_total = 0
        _pag_offset = 0
        {% if paginationOffsetVar %}
        try:
            _pag_offset = int(_all_vars.get("{{ paginationOffsetVar }}", 0) or 0)
        except (ValueError, TypeError):
            _pag_offset = 0
        {% endif %}
        _pag_limit = {{ paginationLimit }}
        _next_offset = _pag_offset + _pag_limit if _pag_offset + _pag_limit < _pag_total else None
        _prev_offset = max(0, _pag_offset - _pag_limit) if _pag_offset > 0 else None
        await set_user_var(user_id, "{{ responseVariable }}.nextOffset", str(_next_offset) if _next_offset is not None else "")
        await set_user_var(user_id, "{{ responseVariable }}.prevOffset", str(_prev_offset) if _prev_offset is not None else "")
        await set_user_var(user_id, "{{ responseVariable }}.currentPage", str(_pag_offset // _pag_limit + 1))
        await set_user_var(user_id, "{{ responseVariable }}.totalPages", str((_pag_total + _pag_limit - 1) // _pag_limit) if _pag_total > 0 else "0")
    {% endif %}

    {% if enablePagination and paginationMode == 'fetch_all' %}
    # Режим fetch_all — собираем все страницы в один массив
    if isinstance(_response_data, dict) and "{{ paginationItemsField }}" in _response_data:
        _all_items = list(_response_data.get("{{ paginationItemsField }}", []))
        _fa_total = int(_response_data.get("{{ paginationTotalField }}", 0) or 0)
        _fa_limit = {{ paginationLimit }}
        _fa_max_pages = {{ paginationMaxPages }}
        _fa_offset = _fa_limit
        _fa_page = 1
        while _fa_offset < _fa_total and _fa_page < _fa_max_pages:
            try:
                _fa_url = "{{ url }}"
                _fa_url = replace_variables_in_text(_fa_url, _all_vars, {})
                _fa_sep = '&' if '?' in _fa_url else '?'
                _fa_url = _fa_url + _fa_sep + f"limit={_fa_limit}&offset={_fa_offset}"
                import aiohttp as _aiohttp2
                async with _aiohttp2.ClientSession() as _fa_session:
                    async with _fa_session.get(
                        _fa_url,
                        headers=_headers or None,
                        timeout=_aiohttp2.ClientTimeout(total={{ timeout }})
                    ) as _fa_resp:
                        _fa_data = await _fa_resp.json(content_type=None)
                        _fa_items = _fa_data.get("{{ paginationItemsField }}", [])
                        if not _fa_items:
                            break
                        _all_items.extend(_fa_items)
            except Exception as _fa_e:
                logging.warning(f"http_request [{{ nodeId }}] fetch_all страница {_fa_page + 1}: {_fa_e}")
                break
            _fa_offset += _fa_limit
            _fa_page += 1
        # Сохраняем полный список поверх ответа
        _response_data["{{ paginationItemsField }}"] = _all_items
        _response_data["{{ paginationTotalField }}"] = len(_all_items)
        await set_user_var(user_id, "{{ responseVariable }}", _response_data)
        await set_user_var(user_id, "{{ responseVariable }}.{{ paginationTotalField }}", str(len(_all_items)))
        logging.info(f"📦 http_request [{{ nodeId }}] fetch_all: собрано {len(_all_items)} элементов за {_fa_page} страниц")
    {% endif %}

    {% if autoTransitionTo %}
    {% if autoTransitionTargetExists %}
    await handle_callback_{{ autoTransitionTo | replace('-', '_') | replace('.', '_') }}(callback_query, state=state)
    {% else %}
    logging.warning(f"⚠️ http_request [{{ nodeId }}]: узел автоперехода не найден: {{ autoTransitionTo }}")
    {% endif %}
    {% endif %}
