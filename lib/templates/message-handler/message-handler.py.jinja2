        logging.info(f"Сообщение {target_message_id} закреплено через синоним '{{ synonym }}' пользователем {user_id} в группе {chat_id}")
{% else %}
        await bot.delete_message(chat_id=chat_id, message_id=target_message_id)
        await message.answer("{{ success_text }}")
        logging.info(f"Сообщение {target_message_id} удалено через синоним '{{ synonym }}' пользователем {user_id} в группе {chat_id}")
{% endif %}
{% endif %}
    except TelegramBadRequest as e:
        if "not enough rights" in str(e) or "CHAT_ADMIN_REQUIRED" in str(e):
            await message.answer("❌ Недостаточно прав")
        elif "not found" in str(e):
            await message.answer("❌ Сообщение не найдено")
        else:
            await message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка {{ nodeType }} через синоним '{{ synonym }}': {e}")
    except Exception as e:
        await message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка в {{ nodeType }}: {e}")

{% endfor %}
