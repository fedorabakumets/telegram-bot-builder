{#
  Шаблон middleware триггеров входящих callback_query

  @param {array} incomingCallbackTriggerEntries - Массив IncomingCallbackTriggerEntry:
    - nodeId: string          — ID узла incoming_callback_trigger
    - targetNodeId: string    — ID целевого узла
    - targetNodeType: string  — тип целевого узла

  @fsm Middleware получает state из data["state"] и сохраняет callback_data в FSM.
       Передаёт state целевому обработчику для сквозной передачи по цепочке.
#}

# Middleware триггеров входящих callback_query
{% for entry in incomingCallbackTriggerEntries -%}
{%- set sanitized_node_id = entry.nodeId | safe_name -%}
{%- set sanitized_target_id = entry.targetNodeId | safe_name -%}

async def incoming_callback_trigger_{{ sanitized_node_id }}_middleware(handler, event: types.CallbackQuery, data: dict):
    """Срабатывает на нажатие инлайн-кнопки пользователем{% if entry.callbackPattern %} (фильтр: {{ entry.callbackMatchType }} "{{ entry.callbackPattern }}"){% endif %}"""
    try:
        user_id = event.from_user.id
        _cb_data = event.data or ""
        {%- if entry.callbackPattern %}
        # Фильтрация по паттерну — пропускаем неподходящие callbacks
        {%- if entry.callbackMatchType == "startsWith" %}
        if not _cb_data.startswith("{{ entry.callbackPattern }}"):
            return await handler(event, data)
        {%- elif entry.callbackMatchType == "equals" %}
        if _cb_data != "{{ entry.callbackPattern }}":
            return await handler(event, data)
        {%- elif entry.callbackMatchType == "contains" %}
        if "{{ entry.callbackPattern }}" not in _cb_data:
            return await handler(event, data)
        {%- endif %}
        {%- endif %}
        logging.info(f"Нажатие кнопки от {user_id} — триггер узла {{ entry.nodeId }}")
        # Сохраняем данные нажатой кнопки
        if user_id not in user_data:
            user_data[user_id] = {}
        user_data[user_id]["callback_data"] = event.data or ""
        # Читаем текст кнопки из reply_markup
        _ict_btn_text = ""
        try:
            if event.data and event.message and hasattr(event.message, "reply_markup"):
                _rm = event.message.reply_markup
                if _rm and hasattr(_rm, "inline_keyboard"):
                    for _row in _rm.inline_keyboard:
                        for _btn in _row:
                            if getattr(_btn, "callback_data", None) == event.data:
                                _ict_btn_text = _btn.text or ""
                                break
                        if _ict_btn_text:
                            break
        except Exception:
            pass
        user_data[user_id]["button_text"] = _ict_btn_text
        # Синхронизируем callback_data в FSM если state доступен в контексте middleware
        try:
            _fsm_state = data.get("state")
            if _fsm_state is not None:
                _fsm_data = await _fsm_state.get_data()
                _fsm_data["callback_data"] = event.data or ""
                await _fsm_state.set_data(_fsm_data)
        except Exception:
            pass

        class MockCallback:
            def __init__(self, data, user, msg):
                self.data = data
                self.from_user = user
                self.message = msg
                self._is_fake = True

            async def answer(self, *args, **kwargs):
                pass

            async def edit_text(self, text, **kwargs):
                try:
                    return await self.message.edit_text(text, **kwargs)
                except Exception as e:
                    logging.warning(f"Не удалось отредактировать сообщение: {e}")
                    return await self.message.answer(text, **kwargs)

        mock_callback = MockCallback("{{ entry.targetNodeId }}", event.from_user, event.message)
        # Передаём state целевому обработчику для сквозной передачи по цепочке
        _state_for_target = data.get("state")
        await handle_callback_{{ sanitized_target_id }}(mock_callback, state=_state_for_target)
    except Exception as e:
        logging.error(f"Ошибка в incoming_callback_trigger middleware: {e}")

    return await handler(event, data)

dp.callback_query.middleware(incoming_callback_trigger_{{ sanitized_node_id }}_middleware)

{% endfor %}
