{#
  Шаблон обработчика узла сообщения (message)

  @fileoverview Генерирует Python код для обработки узла типа message.
  Включает вложенную вспомогательную функцию _send_to_<nodeId>, которая
  отправляет сообщение (с медиа или без) в произвольный чат — используется
  как для основного пользователя, так и для дополнительных получателей.

  @param {string} nodeId - Уникальный идентификатор узла
  @param {string} messageText - Текст сообщения
  @param {boolean} adminOnly - Только администраторы
  @param {boolean} requiresAuth - Требуется авторизация
  @param {boolean} userDatabaseEnabled - База данных пользователей включена
  @param {boolean} allowMultipleSelection - Множественный выбор
  @param {string} multiSelectVariable - Переменная для хранения выбора
  @param {array} buttons - Кнопки
  @param {string} keyboardType - Тип клавиатуры: 'inline', 'reply', 'none'
  @param {boolean} enableAutoTransition - Автопереход
  @param {string} autoTransitionTo - Цель автоперехода
  @param {boolean} collectUserInput - Сбор пользовательского ввода
  @param {string} formatMode - Режим форматирования: 'html', 'markdown', 'none'
  @param {string} imageUrl - URL изображения
  @param {string} documentUrl - URL документа
  @param {string} videoUrl - URL видео
  @param {string} audioUrl - URL аудио
  @param {array} attachedMedia - Прикреплённые медиа переменные
  @param {boolean} enableConditionalMessages - Условные сообщения включены
  @param {array} conditionalMessages - Условные сообщения
  @param {string} fallbackMessage - Запасное сообщение
  @param {array} messageSendRecipients - Список получателей сообщения
#}

{# Обработчики синонимов — генерируются ДО handle_callback, так как это отдельные функции #}
{%- if synonymEntries and synonymEntries|length > 0 %}
{% include 'synonyms/synonyms.py.jinja2' %}
{%- endif %}

{# Обработчик callback для навигации к узлу #}
{# Если задан callbackPattern (customCallbackData) — декоратор слушает его, иначе nodeId #}
{%- set _cb_pattern = callbackPattern if callbackPattern else nodeId %}
{%- set _cb_is_dynamic = callbackPattern and '{' in callbackPattern %}
{%- if _cb_is_dynamic %}
{%- set _cb_static_prefix = callbackPattern.split('{')[0] %}
@dp.callback_query(lambda c: c.data and c.data.startswith("{{ _cb_static_prefix }}"))
{%- else %}
@dp.callback_query(lambda c: c.data == "{{ _cb_pattern }}"{% if not callbackPattern %} or c.data.startswith("{{ nodeId }}_btn_"){% endif %})
{%- endif %}
async def handle_callback_{{ nodeId|replace('-', '_') }}(callback_query: types.CallbackQuery, state: FSMContext = None):
    """Обработчик перехода к узлу {{ nodeId }}"""
    user_id = callback_query.from_user.id
    logging.info(f"🔵 Переход к узлу {{ nodeId }} для пользователя {user_id}")
    {%- if _cb_is_dynamic %}
    # Извлекаем динамическую часть callback_data (суффикс после статичного префикса)
    if user_id not in user_data:
        user_data[user_id] = {}
    _cb_suffix = (callback_query.data or "").replace("{{ _cb_static_prefix }}", "", 1)
    if _cb_suffix:
        user_data[user_id]["_cb_dynamic_id"] = _cb_suffix
        await set_user_var(user_id, "_cb_dynamic_id", _cb_suffix)
    {%- endif %}
    {# Лог нажатия кнопки пользователем #}
    _pressed_cb = getattr(callback_query, 'data', None)
    if _pressed_cb and not getattr(callback_query, '_is_fake', False):
        logging.info(f"🖱️ Пользователь {user_id} нажал кнопку с callback_data=\"{_pressed_cb}\"")
    # Сохраняем данные нажатой кнопки для использования в переменных {callback_data} и {button_text}
    if user_id not in user_data:
        user_data[user_id] = {}
    # Не перезаписываем если это fake callback (вызов из middleware/триггера) — реальные данные уже сохранены
    # Не перезаписываем если это goto-переход к этому узлу (callback_data == nodeId) —
    # в этом случае реальный callback_data (например project_42) уже сохранён middleware
    if not getattr(callback_query, '_is_fake', False) and _pressed_cb != "{{ nodeId }}":
        user_data[user_id]["callback_data"] = _pressed_cb or ""
        # Читаем текст кнопки из reply_markup сообщения — Telegram хранит его там
        _btn_text_found = ""
        try:
            if _pressed_cb and callback_query.message and hasattr(callback_query.message, "reply_markup"):
                _rm = callback_query.message.reply_markup
                if _rm and hasattr(_rm, "inline_keyboard"):
                    for _row in _rm.inline_keyboard:
                        for _btn in _row:
                            if getattr(_btn, "callback_data", None) == _pressed_cb:
                                _btn_text_found = _btn.text or ""
                                break
                        if _btn_text_found:
                            break
        except Exception:
            pass
        user_data[user_id]["button_text"] = _btn_text_found

    # Отвечаем на callback (чтобы убрать часы загрузки)
    try:
        await callback_query.answer()
    except Exception:
        pass

    {%- if hasHideAfterClickIncoming %}
    # Скрываем клавиатуру предыдущего сообщения (hideAfterClick)
    try:
        await callback_query.message.edit_reply_markup(reply_markup=None)
    except Exception:
        pass
    {%- endif %}

    {# Проверки безопасности #}
    {%- if adminOnly %}
    if not await is_admin(user_id):
        await callback_query.answer("❌ У вас нет прав для выполнения этой команды", show_alert=True)
        return
    {%- endif %}
    {%- if requiresAuth %}
    if not await check_auth(user_id):
        await callback_query.answer("❌ Сначала запустите бота: /start", show_alert=True)
        return
    {%- endif %}
    {# Сохранение информации о пользователе #}
    username = callback_query.from_user.username
    first_name = callback_query.from_user.first_name
    last_name = callback_query.from_user.last_name

    {% if userDatabaseEnabled %}
    # Сохраняем пользователя в базу данных (пропускаем системного пользователя id=0 от schedule_trigger)
    if user_id != 0:
        # Аватарку запрашиваем если: ещё не получали в этой сессии И в БД нет (avatar_url IS NULL)
        _avatar_url = None
        _has_avatar_in_memory = user_data.get(user_id, {}).get("_avatar_fetched")
        _has_avatar_in_db = user_data.get(user_id, {}).get("_avatar_url_cached")
        if not _has_avatar_in_memory and not _has_avatar_in_db:
            try:
                _photos = await bot.get_user_profile_photos(user_id, limit=1)
                if _photos and _photos.photos:
                    # Сохраняем file_id — он постоянный, в отличие от file_path/URL
                    _avatar_url = _photos.photos[0][-1].file_id
                    user_data.setdefault(user_id, {})["_avatar_url_cached"] = _avatar_url
                    logging.info(f"✅ Аватарка (file_id) получена для {user_id}")
                else:
                    logging.info(f"ℹ️ У пользователя {user_id} нет аватарки")
                user_data.setdefault(user_id, {})["_avatar_fetched"] = True
            except Exception as _e:
                logging.warning(f"⚠️ Не удалось получить аватарку для {user_id}: {_e}")
        elif _has_avatar_in_db:
            _avatar_url = _has_avatar_in_db
        # Fire-and-forget: сохранение профиля не блокирует отправку сообщения
        # Передаём deep_link_param и referrer_id из user_data — они уже записаны set_user_var до вызова save_user_to_db
        asyncio.create_task(save_user_to_db(
            user_id, username, first_name, last_name, _avatar_url,
            deep_link_param=user_data.get(user_id, {}).get("deep_link_param"),
            referrer_id=user_data.get(user_id, {}).get("referrer_id"),
        ))

    # Инициализируем базовые переменные пользователя (память — синхронно)
    user_name = await init_user_variables(user_id, callback_query.from_user)
    # Fire-and-forget: обновление статистики в фоне
    asyncio.create_task(update_user_data_in_db(user_id, "user_name", user_name))
    asyncio.create_task(update_user_data_in_db(user_id, "first_name", first_name))
    asyncio.create_task(update_user_data_in_db(user_id, "last_name", last_name))
    asyncio.create_task(update_user_data_in_db(user_id, "username", username))
    {% endif %}

    # Сохранение в локальное хранилище
    if user_id not in user_data:
        user_data[user_id] = {}
    user_data[user_id]["username"] = username
    user_data[user_id]["first_name"] = first_name
    user_data[user_id]["last_name"] = last_name

    {# Инициализация множественного выбора #}
    {%- if allowMultipleSelection %}
    # Инициализируем состояние множественного выбора
    user_data[user_id]["multi_select"] = []
    user_data[user_id]["multi_select_node"] = "{{ nodeId }}"
    logging.info(f"Инициализировано состояние множественного выбора для узла {{ nodeId }}")
    {%- endif %}

    {# Сохранение медиа-переменных #}
    {%- if imageUrl and imageUrl != 'undefined' %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["image_url_{{ nodeId }}"] = "{{ imageUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "image_url_{{ nodeId }}", "{{ imageUrl }}")
    {%- endif %}
    {%- endif %}

    {%- if documentUrl %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["document_url_{{ nodeId }}"] = "{{ documentUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "document_url_{{ nodeId }}", "{{ documentUrl }}")
    {%- endif %}
    {%- endif %}

    {%- if videoUrl %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["video_url_{{ nodeId }}"] = "{{ videoUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "video_url_{{ nodeId }}", "{{ videoUrl }}")
    {%- endif %}
    {%- endif %}

    {%- if audioUrl %}
    user_data[user_id] = user_data.get(user_id, {})
    user_data[user_id]["audio_url_{{ nodeId }}"] = "{{ audioUrl }}"
    {%- if userDatabaseEnabled %}
    await update_user_data_in_db(user_id, "audio_url_{{ nodeId }}", "{{ audioUrl }}")
    {%- endif %}
    {%- endif %}

    {%- if attachedMedia and attachedMedia|length > 0 %}
    {# Сохранение переменных из attachedMedia #}
    {%- for mediaVar in attachedMedia %}
    {%- if 'imageUrlVar' in mediaVar and imageUrl and imageUrl != 'undefined' %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ imageUrl }}"
    {%- elif 'videoUrlVar' in mediaVar and videoUrl %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ videoUrl }}"
    {%- elif 'audioUrlVar' in mediaVar and audioUrl %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ audioUrl }}"
    {%- elif 'documentUrlVar' in mediaVar and documentUrl %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ documentUrl }}"
    {%- elif 'video_url_' in mediaVar and videoUrl %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ videoUrl }}"
    {%- elif 'audio_url_' in mediaVar and audioUrl %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ audioUrl }}"
    {%- elif 'document_url_' in mediaVar and documentUrl %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ documentUrl }}"
    {%- elif 'image_url_' in mediaVar and imageUrl and imageUrl != 'undefined' %}
    user_data[user_id]["{{ mediaVar }}"] = "{{ imageUrl }}"
    {%- endif %}
    {%- endfor %}
    {%- endif %}

    {# Текст сообщения #}
{%- if projectId %}
    text = get_content("{{ nodeId }}", {{ messageText|format_python_text }})
{%- else %}
    text = {{ messageText|format_python_text }}
{%- endif %}

    {# Универсальная замена переменных #}
    all_user_vars = await init_all_user_vars(user_id)
    {# Читаем FSM данные — они имеют приоритет (сохраняют контекст при goto-переходах) #}
    if state is not None:
        try:
            _fsm_d = await state.get_data()
            if _fsm_d:
                all_user_vars.update(_fsm_d)
        except Exception:
            pass
    {%- if hasUserIdsVariable %}
    user_ids_record = await get_user_ids_from_db(user_id)
    if user_ids_record:
        all_user_vars["user_ids"] = user_ids_record.get("user_ids", [])
        all_user_vars["user_ids_count"] = user_ids_record.get("count", 0)
    {%- endif %}
    text = replace_variables_in_text(text, all_user_vars, {})

    {# Клавиатура #}
{%- filter indent(4) %}{% include 'keyboard/keyboard.py.jinja2' %}{% endfilter %}

    {# Определяем нужно ли отправлять пользователю #}
    {# Если все получатели имеют тип chat_id — основная отправка пользователю пропускается #}
    {%- set hasUserRecipient = true %}
    {%- if messageSendRecipients and messageSendRecipients|length > 0 %}
      {%- set hasUserRecipient = false %}
      {%- for r in messageSendRecipients %}
        {%- if r.type == 'user' %}
          {%- set hasUserRecipient = true %}
        {%- endif %}
      {%- endfor %}
    {%- endif %}

    {# ------------------------------------------------------------------ #}
    {# Вспомогательная вложенная функция отправки сообщения/медиа в чат.  #}
    {# Использует замыкание: text, keyboard и медиа-переменные доступны    #}
    {# из внешней области видимости обработчика.                           #}
    {# ------------------------------------------------------------------ #}
    {%- if projectId %}
    {# Динамическое определение parse_mode из текста (для горячей перезагрузки контента) #}
    _parse_mode = "HTML" if any(tag in text for tag in ["<b>", "<i>", "<u>", "<s>", "<code>", "<pre>", "<a ", "<tg-spoiler>"]) else None
    {%- set parse_mode_arg = ', parse_mode=_parse_mode' %}
    {%- else %}
    {%- set parse_mode_arg = ', parse_mode="HTML"' if formatMode == 'html' else (', parse_mode="Markdown"' if formatMode == 'markdown' else '') %}
    {%- endif %}
    {%- set link_preview_arg = ', link_preview_options=types.LinkPreviewOptions(is_disabled=True)' if disableLinkPreview else '' %}
    {%- set effectiveKeyboard = 'ReplyKeyboardRemove()' if (hasHideAfterClickIncoming and keyboardType == 'none') else 'keyboard' %}
    async def _send_to_{{ nodeId|replace('-', '_') }}(_target_chat_id, _thread_id=None, _bot=None):
        """
        Отправляет сообщение (с медиа или без) в указанный чат через указанный бот (или глобальный).

        @param _target_chat_id - Идентификатор целевого чата
        @param _thread_id - Идентификатор треда (для групп с топиками), None если не нужен
        @param _bot - Экземпляр бота для отправки; если None — используется глобальный bot
        @returns Объект отправленного сообщения или None при ошибке
        """
        _b = _bot if _bot is not None else bot
        try:
{%- if (attachedMedia and attachedMedia|length > 0) or (imageUrl and imageUrl != 'undefined') or videoUrl or audioUrl or documentUrl %}
{%- if imageUrl and imageUrl != 'undefined' %}
{%- if isLocalImageUrl %}
            image_path = get_upload_file_path("{{ imageUrl }}")
            if not os.path.exists(image_path):
                logging.error(f"❌ Медиафайл не найден: {image_path} (узел {{ nodeId }})")
                return await _b.send_message(_target_chat_id, text{{ parse_mode_arg }}{{ link_preview_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
            _cached_fid = _media_file_id_cache.get("{{ imageUrl }}")
            if _cached_fid:
                logging.info(f"📎 Узел {{ nodeId }}: отправка фото через in-memory file_id (без перегенерации)")
                _sent_result = await _b.send_photo(_target_chat_id, _cached_fid, caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{% include 'message/partials/send-extra-file-ids.py.jinja2' %}
                return _sent_result
            logging.info(f"📤 Узел {{ nodeId }}: отправка фото через FSInputFile")
            _sent_photo = await _b.send_photo(_target_chat_id, FSInputFile(image_path), caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
            if _sent_photo and _sent_photo.photo:
                _new_fid = _sent_photo.photo[-1].file_id
                _media_file_id_cache["{{ imageUrl }}"] = _new_fid
                logging.info(f"✅ Узел {{ nodeId }}: получен file_id={_new_fid[:20]}... для фото {{ imageUrl }}")
                if db_pool:
                    try:
                        async with db_pool.acquire() as _conn:
                            await _conn.execute(
                                "UPDATE media_files SET telegram_file_id = $1 WHERE url = $2 AND project_id = $3",
                                _new_fid, "{{ imageUrl }}", PROJECT_ID
                            )
                            logging.info(f"💾 file_id сохранён в БД для {{ imageUrl }}")
                    except Exception as _db_err:
                        logging.warning(f"⚠️ Не удалось сохранить file_id в БД: {_db_err}")
            _sent_result = _sent_photo
{% include 'message/partials/send-extra-file-ids.py.jinja2' %}
            return _sent_result
{%- elif '{' in imageUrl and '}' in imageUrl %}
            {# imageUrl содержит переменную вида {var.path} — подставляем через replace_variables_in_text #}
            _image_url_resolved = replace_variables_in_text("{{ imageUrl }}", all_user_vars, {})
            if _image_url_resolved and _image_url_resolved != "{{ imageUrl }}":
                _sent_result = await _b.send_photo(_target_chat_id, _image_url_resolved, caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{% include 'message/partials/send-extra-file-ids.py.jinja2' %}
                return _sent_result
            else:
                logging.warning(f"⚠️ Не удалось разрешить переменную imageUrl: {{ imageUrl | replace('{', '{{') | replace('}', '}}') }} (узел {{ nodeId }})")
                return await _b.send_message(_target_chat_id, text{{ parse_mode_arg }}{{ link_preview_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{%- else %}
{%- set _cached_img_fid = (telegramFileIds or {})[imageUrl] if telegramFileIds and imageUrl in telegramFileIds else '' %}
{%- if _cached_img_fid %}
            logging.info(f"📎 Узел {{ nodeId }}: отправка фото через кэшированный file_id={{ _cached_img_fid }}...")
            _sent_result = await _b.send_photo(_target_chat_id, "{{ _cached_img_fid }}", caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{% include 'message/partials/send-extra-file-ids.py.jinja2' %}
            return _sent_result
{%- else %}
            _rt_fid = _media_file_id_cache.get("{{ imageUrl }}")
            if _rt_fid:
                logging.info(f"📎 Узел {{ nodeId }}: отправка фото через in-memory file_id (без перегенерации)")
                _sent_result = await _b.send_photo(_target_chat_id, _rt_fid, caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{% include 'message/partials/send-extra-file-ids.py.jinja2' %}
                return _sent_result
            logging.info(f"📤 Узел {{ nodeId }}: первая отправка фото по URL, file_id будет получен из ответа")
            _sent_photo = await _b.send_photo(_target_chat_id, "{{ imageUrl }}", caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
            if _sent_photo and _sent_photo.photo:
                _new_fid = _sent_photo.photo[-1].file_id
                _media_file_id_cache["{{ imageUrl }}"] = _new_fid
                logging.info(f"✅ Узел {{ nodeId }}: получен file_id={_new_fid[:20]}... для фото {{ imageUrl }}")
                if db_pool:
                    try:
                        async with db_pool.acquire() as _conn:
                            await _conn.execute(
                                "INSERT INTO media_files (project_id, file_name, file_type, file_path, file_size, mime_type, url, telegram_file_id, is_public, usage_count) VALUES ($1, $2, 'photo', $2, 0, 'image/jpeg', $3, $4, 0, 0) ON CONFLICT (url, project_id) DO UPDATE SET telegram_file_id = EXCLUDED.telegram_file_id",
                                PROJECT_ID, "{{ imageUrl }}", "{{ imageUrl }}", _new_fid
                            )
                            logging.info(f"💾 file_id сохранён в БД для {{ imageUrl }}")
                    except Exception as _db_err:
                        logging.warning(f"⚠️ Не удалось сохранить file_id в БД: {_db_err}")
            _sent_result = _sent_photo
{% include 'message/partials/send-extra-file-ids.py.jinja2' %}
            return _sent_result
{%- endif %}
{%- endif %}
{%- elif videoUrl %}
{%- set _vid_thumb_fid = (thumbnailFileIds or {})[videoUrl] if thumbnailFileIds and videoUrl in thumbnailFileIds else '' %}
{%- set _vid_thumb_url = (thumbnailUrls or {})[videoUrl] if thumbnailUrls and videoUrl in thumbnailUrls else '' %}
{%- set _vid_thumb_val = _vid_thumb_fid or _vid_thumb_url %}
{%- if _vid_thumb_val %}
  {%- if '/uploads/' in _vid_thumb_val %}
    {%- set _vid_thumb_arg = ', thumbnail=FSInputFile(get_upload_file_path("' + _vid_thumb_val + '"))' %}
  {%- else %}
    {%- set _vid_thumb_arg = ', thumbnail="' + _vid_thumb_val + '"' %}
  {%- endif %}
{%- else %}
  {%- set _vid_thumb_arg = '' %}
{%- endif %}
{%- if isLocalVideoUrl %}
            video_path = get_upload_file_path("{{ videoUrl }}")
            if not os.path.exists(video_path):
                logging.error(f"❌ Медиафайл не найден: {video_path} (узел {{ nodeId }})")
                return await _b.send_message(_target_chat_id, text{{ parse_mode_arg }}{{ link_preview_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
            _cached_fid = _media_file_id_cache.get("{{ videoUrl }}")
            if _cached_fid:
                logging.info(f"📎 Узел {{ nodeId }}: отправка видео через in-memory file_id (без перегенерации)")
{%- if _vid_thumb_fid %}
