{%- elif '.mp4' in _mi_lower or '.avi' in _mi_lower or '.mov' in _mi_lower or '.webm' in _mi_lower %}
                logging.info(f"📤 Узел {{ nodeId }}: медиагруппа[{{ loop.index0 }}] — видео через FSInputFile: {{ mediaItem }}")
                _mg_items.append(InputMediaVideo(media=FSInputFile(_fp_mg_{{ loop.index }})))
{%- elif '.mp3' in _mi_lower or '.wav' in _mi_lower or '.ogg' in _mi_lower %}
                logging.info(f"📤 Узел {{ nodeId }}: медиагруппа[{{ loop.index0 }}] — аудио через FSInputFile: {{ mediaItem }}")
                _mg_items.append(InputMediaAudio(media=FSInputFile(_fp_mg_{{ loop.index }})))
{%- else %}
                logging.info(f"📤 Узел {{ nodeId }}: медиагруппа[{{ loop.index0 }}] — документ через FSInputFile: {{ mediaItem }}")
                _mg_items.append(InputMediaDocument(media=FSInputFile(_fp_mg_{{ loop.index }})))
{%- endif %}
            else:
                logging.error(f"❌ Медиафайл не найден: {_fp_mg_{{ loop.index }}} (узел {{ nodeId }})")
{%- else %}
            {# Обычный URL — определяем тип по расширению #}
{%- set _mi_lower = mediaItem | lower %}
{%- if '.jpg' in _mi_lower or '.jpeg' in _mi_lower or '.png' in _mi_lower or '.gif' in _mi_lower or '.webp' in _mi_lower %}
            logging.info(f"📤 Узел {{ nodeId }}: медиагруппа[{{ loop.index0 }}] — фото по URL: {{ mediaItem }}")
            _mg_items.append(InputMediaPhoto(media="{{ mediaItem|e }}"))
{%- elif '.mp4' in _mi_lower or '.avi' in _mi_lower or '.mov' in _mi_lower or '.webm' in _mi_lower %}
            logging.info(f"📤 Узел {{ nodeId }}: медиагруппа[{{ loop.index0 }}] — видео по URL: {{ mediaItem }}")
            _mg_items.append(InputMediaVideo(media="{{ mediaItem|e }}"))
{%- elif '.mp3' in _mi_lower or '.wav' in _mi_lower or '.ogg' in _mi_lower %}
            logging.info(f"📤 Узел {{ nodeId }}: медиагруппа[{{ loop.index0 }}] — аудио по URL: {{ mediaItem }}")
            _mg_items.append(InputMediaAudio(media="{{ mediaItem|e }}"))
{%- else %}
            logging.info(f"📤 Узел {{ nodeId }}: медиагруппа[{{ loop.index0 }}] — документ по URL: {{ mediaItem }}")
            _mg_items.append(InputMediaDocument(media="{{ mediaItem|e }}"))
{%- endif %}
{%- endif %}
{%- endfor %}
            if len(_mg_items) >= 2:
                {# caption устанавливается только у первого элемента медиагруппы #}
                if _mg_items:
                    _first_mg = _mg_items[0]
                    _mg_items[0] = type(_first_mg)(media=_first_mg.media, caption=text{{ parse_mode_arg }})
                logging.info(f"📤 Узел {{ nodeId }}: отправка медиагруппы из {len(_mg_items)} файлов")
                _sent_mg = await _b.send_media_group(_target_chat_id, _mg_items, message_thread_id=_thread_id)
{%- if keyboardType != 'none' %}
                {# send_media_group не поддерживает reply_markup — клавиатура отправляется отдельным сообщением #}
                await _b.send_message(_target_chat_id, "​", reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{%- endif %}
                return _sent_mg[0] if _sent_mg else None
            elif len(_mg_items) == 1:
                {# Только один элемент собрался — отправляем как одиночное сообщение #}
                _solo = _mg_items[0]
                _solo_media = _solo.media
                if isinstance(_solo, InputMediaPhoto):
                    return await _b.send_photo(_target_chat_id, _solo_media, caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
                elif isinstance(_solo, InputMediaVideo):
                    return await _b.send_video(_target_chat_id, _solo_media, caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
                elif isinstance(_solo, InputMediaAudio):
                    return await _b.send_audio(_target_chat_id, _solo_media, caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
                else:
                    return await _b.send_document(_target_chat_id, _solo_media, caption=text{{ parse_mode_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
            return await _b.send_message(_target_chat_id, text{{ parse_mode_arg }}{{ link_preview_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{%- endif %}
{%- else %}
            return await _b.send_message(_target_chat_id, text{{ parse_mode_arg }}{{ link_preview_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{%- endif %}
{%- endif %}
{%- else %}
            return await _b.send_message(_target_chat_id, text{{ parse_mode_arg }}{{ link_preview_arg }}, reply_markup={{ effectiveKeyboard }}, message_thread_id=_thread_id)
{%- endif %}
        except Exception as _send_err:
            logging.error(f"❌ Ошибка отправки в {_target_chat_id}: {_send_err}")
            return None

    {# Отправка медиафайлов или обычного сообщения основному пользователю #}
    sent_message = None
    {%- if hasUserRecipient %}
    sent_message = await _send_to_{{ nodeId|replace('-', '_') }}(
        callback_query.message.chat.id,
        getattr(callback_query.message, "message_thread_id", None),
    )
    {%- endif %}{# /hasUserRecipient #}

    {# Отправка дополнительным получателям (chat_id / admin_ids) #}
    {%- if messageSendRecipients and messageSendRecipients|length > 0 %}
    {%- for recipient in messageSendRecipients %}
    {%- if recipient.type == 'chat_id' and recipient.chatId %}
    # Отправка получателю {{ loop.index }}: {{ recipient.chatId }}
    try:
        _rchat = replace_variables_in_text("{{ recipient.chatId }}", all_user_vars, {})
        {%- if recipient.isGroup %}
        # Добавляем -100 для групп/каналов если включён флаг isGroup
        if _rchat.lstrip('-').isdigit() and not _rchat.startswith('-'):
            _rchat = f"-100{_rchat}"
        {%- endif %}
        {%- if recipient.threadId %}
        _rthread = replace_variables_in_text("{{ recipient.threadId }}", all_user_vars, {})
        _rthread_int = int(_rthread) if _rthread and _rthread.strip().lstrip('-').isdigit() else None
        {%- else %}
        _rthread_int = None
        {%- endif %}
        _rchat_id = int(_rchat) if _rchat.lstrip('-').isdigit() else _rchat
        {%- if recipient.botToken %}
        _rbot_token = replace_variables_in_text("{{ recipient.botToken }}", all_user_vars, {})
        _rbot = Bot(token=_rbot_token) if _rbot_token and _rbot_token.strip() else None
        _rsent = await _send_to_{{ nodeId|replace('-', '_') }}(_rchat_id, _rthread_int, _bot=_rbot)
        {%- else %}
        _rsent = await _send_to_{{ nodeId|replace('-', '_') }}(_rchat_id, _rthread_int)
        {%- endif %}
        {%- if saveMessageIdTo %}
        if sent_message is None and _rsent and hasattr(_rsent, 'message_id'):
            sent_message = _rsent
        {%- endif %}
        logging.info(f"📤 Отправлено получателю {_rchat}")
    except Exception as _re:
        logging.error(f"❌ Ошибка отправки получателю {_rchat}: {_re}")
    {%- elif recipient.type == 'admin_ids' %}
    # Отправка администраторам (получатель {{ loop.index }})
    for _admin_id in ADMIN_IDS:
        try:
            await bot.send_message(_admin_id, text, reply_markup=keyboard)
            logging.info(f"📤 Сообщение отправлено администратору {_admin_id}")
        except Exception as _e_admin_{{ loop.index }}:
            logging.error(f"❌ Ошибка отправки администратору {_admin_id}: {_e_admin_{{ loop.index }}}")
    {%- endif %}
    {%- endfor %}
    {%- endif %}

    {# Сохранение ID отправленного сообщения в переменную (после всех отправок) #}
    {%- if saveMessageIdTo %}
    if sent_message and hasattr(sent_message, 'message_id'):
        user_data[user_id]["{{ saveMessageIdTo }}"] = sent_message.message_id
        await set_user_var(user_id, "{{ saveMessageIdTo }}", sent_message.message_id)
        logging.info(f"💾 ID сообщения сохранён в переменную '{{ saveMessageIdTo }}': {sent_message.message_id}")
    {%- endif %}

    {# Лог отправленных кнопок #}
    {%- if buttons and buttons|length > 0 and keyboardType == 'inline' %}
    if sent_message:
        _btn_log = [{% for btn in buttons %}{%- if btn.action != 'url' %}"{{ btn.customCallbackData or btn.target or btn.id }}"{% if not loop.last %}, {% endif %}{%- endif %}{% endfor %}]
        if _btn_log:
            logging.info(f"⌨️ Отправлено сообщение с кнопками (callback_data): {_btn_log} → пользователю {user_id}")
    {%- endif %}

    {# Автопереход #}
    {%- if enableAutoTransition and autoTransitionTo %}
    # ⚡ АВТОПЕРЕХОД к {{ autoTransitionTo }}
    logging.info(f"⚡ Автопереход от узла {{ nodeId }} к узлу {{ autoTransitionTo }}")
    class FakeCallbackQuery:
        def __init__(self, message, from_user, target_node_id):
            self.from_user = from_user
            self.chat = message.chat
            self.date = message.date
            self.message_id = message.message_id
            self.data = target_node_id
            self.message = message
            self._is_fake = True

        async def answer(self, *args, **kwargs):
            pass

    fake_callback = FakeCallbackQuery(sent_message or callback_query.message, callback_query.from_user, "{{ autoTransitionTo }}")
    try:
        await handle_callback_{{ autoTransitionTo|replace('-', '_') }}(fake_callback, state=state)
        logging.info(f"✅ Автопереход выполнен: {{ nodeId }} -> {{ autoTransitionTo }}")
    except Exception as e:
        logging.error(f"Ошибка при автопереходе к узлу {{ autoTransitionTo }}: {e}")
    return
    {%- endif %}

    {# Сбор пользовательского ввода #}
    {%- if collectUserInput and userInputBlock %}
{{ userInputBlock }}
    {%- endif %}
