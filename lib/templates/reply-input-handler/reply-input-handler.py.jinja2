{#
  Шаблон обработки reply-ввода пользователя внутри handle_user_input

  Покрывает:
  1. button_response_config  — reply-клавиатура с вариантами ответа
  2. pending_skip_buttons    — кнопки пропуска для медиа-узлов
  3. skip_buttons (waiting)  — skipDataCollection в универсальной системе
  4. response_save           — сохранение ответа + appendVariable
  5. auto_navigation_loop    — цикл автопереходов
  6. goto_navigation         — переход к узлу через handle_callback_*
  7. call_skip_target_handler — глобальная функция навигации пропуска

  @param {array}   nodes          — все узлы [{id, safeName}]
  @param {array}   commandNodes   — узлы с командами [{id, type, command}]
  @param {boolean} hasUrlButtons  — есть ли URL-кнопки в проекте
  @param {string}  indentLevel    — базовый отступ (по умолчанию '    ')
#}

{% set ind = indentLevel or '    ' %}
{% set ind2 = ind ~ '    ' %}
{% set ind3 = ind2 ~ '    ' %}
{% set ind4 = ind3 ~ '    ' %}
{% set ind5 = ind4 ~ '    ' %}

