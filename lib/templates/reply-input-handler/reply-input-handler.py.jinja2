{# ═══════════════════════════════════════════════════════════════
   БЛОК 6: call_skip_target_handler — глобальная функция
   ═══════════════════════════════════════════════════════════════ #}

async def call_skip_target_handler(fake_callback, skip_target):
    """Вызывает обработчик для целевого узла пропуска"""
    safe_func_name = skip_target.replace("-", "_").replace(" ", "_")
    handler_func_name = f"handle_callback_{safe_func_name}"
    if handler_func_name in globals():
        await globals()[handler_func_name](fake_callback)
    else:
        logging.warning(f"Обработчик {handler_func_name} не найден")
        await fake_callback.message.answer("Переход завершен")
