{#
  Шаблон обработчиков триггеров сообщений в топиках форум-групп

  @fileoverview Генерирует Python @dp.message обработчики для group_message_trigger узлов
  @param {array} entries - Массив объектов GroupMessageTriggerEntry:
    - nodeId: string                — ID узла group_message_trigger
    - safeName: string              — безопасное имя для Python-идентификаторов
    - groupChatId: string           — числовой ID группы (без -100)
    - groupChatIdSource: string     — 'manual' | 'variable'
    - groupChatVariableName: string — имя переменной с ID группы
    - threadIdVariable: string      — имя переменной где хранится thread_id
    - resolvedUserIdVariable: string — имя переменной куда класть user_id
    - targetNodeId: string          — ID целевого узла
    - targetNodeType: string        — тип целевого узла
#}
{% for entry in entries %}
@dp.message(F.chat.type.in_({'group', 'supergroup'}), F.message_thread_id)
async def group_message_trigger_{{ entry.safeName }}_handler(message: types.Message):
    """Триггер сообщения в топике группы — узел {{ entry.nodeId }}"""
    {% if entry.groupChatIdSource == 'manual' %}
    _expected_chat_ids = ('{{ entry.groupChatId }}', '-100{{ entry.groupChatId }}')
    if str(message.chat.id) not in _expected_chat_ids:
        return
    {% else %}
    _group_chat_id_var = globals().get('user_data', {}).get(0, {}).get('{{ entry.groupChatVariableName }}', '')
    if not _group_chat_id_var:
        logging.warning(f"group_message_trigger {{ entry.nodeId }}: переменная {{ entry.groupChatVariableName }} не задана, пропускаем")
        return
    _expected_group_ids = (str(_group_chat_id_var), f"-100{_group_chat_id_var}")
    if str(message.chat.id) not in _expected_group_ids:
        return
    {% endif %}

    _thread_id = message.message_thread_id
    if not _thread_id:
        return

    # Lookup user_id по thread_id через JSONB
    _resolved_user_id = None
    _db_pool_ref = globals().get('db_pool')
    _project_id = globals().get('PROJECT_ID')
    if _db_pool_ref:
        try:
            async with _db_pool_ref.acquire() as _conn:
                if _project_id is not None:
                    _row = await _conn.fetchrow(
                        "SELECT user_id FROM bot_users WHERE project_id = $1 AND user_data->>'{{ entry.threadIdVariable }}' = $2 LIMIT 1",
                        _project_id, str(_thread_id)
                    )
                else:
                    _row = await _conn.fetchrow(
                        "SELECT user_id FROM bot_users WHERE user_data->>'{{ entry.threadIdVariable }}' = $1 LIMIT 1",
                        str(_thread_id)
                    )
                if _row:
                    _resolved_user_id = _row['user_id']
        except Exception as _e:
            logging.warning(f"group_message_trigger {{ entry.nodeId }}: failed to resolve user by thread_id={_thread_id}: {_e}")

    if not _resolved_user_id:
        logging.info(f"group_message_trigger {{ entry.nodeId }}: no user found for thread_id={_thread_id}, skipping")
        return

    logging.info(f"group_message_trigger {{ entry.nodeId }}: thread_id={_thread_id} → user_id={_resolved_user_id}")

    # Сохраняем resolved_user_id в переменную
    await set_user_var(_resolved_user_id, '{{ entry.resolvedUserIdVariable }}', str(_resolved_user_id))

    # Передаём управление следующему узлу
    class MockCallback:
        def __init__(self, data, user_id, msg):
            self.data = data
            self.from_user = type('User', (), {'id': user_id, 'username': None, 'first_name': '', 'last_name': '', 'language_code': None, 'is_premium': False, 'is_bot': False})()
            self.message = msg

        async def answer(self, *args, **kwargs):
            pass

    mock_callback = MockCallback("{{ entry.targetNodeId }}", _resolved_user_id, message)
    await handle_callback_{{ entry.targetNodeId | safe_name }}(mock_callback)

{% endfor %}
