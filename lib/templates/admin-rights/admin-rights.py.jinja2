  { "key": "can_delete_messages",    "short": "can_delete_me",  "label": "Удаление сообщений" },
  { "key": "can_restrict_members",   "short": "can_restrict_m", "label": "Блокировка участников" },
  { "key": "can_invite_users",       "short": "can_invite_us",  "label": "Приглашение участников" },
  { "key": "can_pin_messages",       "short": "can_pin_messa",  "label": "Закрепление сообщений" },
  { "key": "can_manage_video_chats", "short": "can_manage_vi",  "label": "Управление видеочатами" },
  { "key": "can_post_stories",       "short": "can_post_stor",  "label": "Публикация историй" },
  { "key": "can_edit_stories",       "short": "can_edit_stor",  "label": "Редактирование историй" },
