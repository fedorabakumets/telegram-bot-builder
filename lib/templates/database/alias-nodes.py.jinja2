{#
  Шаблон алиасов функций для callback обработчиков команд

  @param {array} commandNodes - Список command_trigger [{ command, functionName }]
#}
# ┌──────────────────────────────────────────────────────────────┐
# │      Алиасы для обработчиков command_trigger                 │
# └──────────────────────────────────────────────────────────────┘
{% for cmd in commandNodes %}
async def handle_command_{{ cmd.functionName }}(message):
    """Алиас для {{ cmd.handlerName }}, используется в callback обработчиках"""
    await {{ cmd.handlerName }}(message)

{% endfor %}
