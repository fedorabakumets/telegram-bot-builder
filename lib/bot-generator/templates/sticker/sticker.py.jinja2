{#
  Шаблон обработчика отправки стикеров

  @fileoverview Генерирует Python код для отправки стикеров Telegram
  @param {string} nodeId - Уникальный идентификатор узла
  @param {string} stickerUrl - URL стикера для отправки
  @param {string} stickerFileId - File ID стикера
  @param {string} stickerSetName - Название набора стикеров
  @param {string} mediaCaption - Подпись к стикеру
  @param {boolean} disableNotification - Отправить без уведомления
#}

@dp.message(Command("sticker_{{ nodeId|safe_name }}"))
async def handle_sticker_{{ nodeId|safe_name }}(message: types.Message):
    """Обработчик отправки стикера для узла {{ nodeId }}"""
    user_id = message.from_user.id

    {% if stickerFileId %}
    {# Отправка по file_id #}
    sticker_file_id = "{{ stickerFileId|e }}"
    {% elif stickerUrl %}
    {# Отправка по URL #}
    sticker_url = "{{ stickerUrl|e }}"
    {% endif %}

    {% if mediaCaption %}
    caption = "{{ mediaCaption|e }}"

    {# Замена переменных #}
    all_user_vars = await init_all_user_vars(user_id)
    variable_filters = user_data.get(user_id, {}).get("_variable_filters", {})
    caption = replace_variables_in_text(caption, all_user_vars, variable_filters)
    {% endif %}

    try:
        {% if stickerFileId %}
        await message.answer_sticker(
            sticker=sticker_file_id,
            {% if mediaCaption %}caption=caption{% endif %}
            {% if disableNotification %}, disable_notification=True{% endif %}
        )
        {% elif stickerUrl %}
        async with aiohttp.ClientSession() as session:
            async with session.get(sticker_url) as resp:
                sticker_data = await resp.read()
                await message.answer_sticker(
                    sticker=sticker_data,
                    {% if mediaCaption %}caption=caption{% endif %}
                    {% if disableNotification %}, disable_notification=True{% endif %}
                )
        {% elif stickerSetName %}
        {# Отправка из набора стикеров #}
        await message.answer_sticker(
            sticker="{{ stickerSetName|e }}",
            {% if mediaCaption %}caption=caption{% endif %}
            {% if disableNotification %}, disable_notification=True{% endif %}
        )
        {% else %}
        await message.answer("Стикер не настроен")
        {% endif %}
    except Exception as e:
        logging.error(f"Ошибка отправки стикера: {e}")
        await message.answer("Произошла ошибка при отправке стикера")
