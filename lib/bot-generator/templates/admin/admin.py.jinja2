    except Exception as e:
        await message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при блокировке: {e}")
    
    {% elif actionType == 'kick_user' %}
    try:
        await bot.ban_chat_member(
            chat_id=chat_id,
            user_id=target_user_id
        )
        await bot.unban_chat_member(
            chat_id=chat_id,
            user_id=target_user_id
        )
        await message.answer("✅ Пользователь исключён из чата")
        logging.info(f"Пользователь {target_user_id} исключён пользователем {user_id} из группы {chat_id} (синоним: {{ synonym }})")
    except TelegramBadRequest as e:
        if "not enough rights" in str(e):
            await message.answer("❌ Недостаточно прав")
        else:
            await message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка исключения пользователя: {e}")
    except Exception as e:
        await message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при исключении: {e}")
    {% endif %}
    {% endif %}
{% endfor %}
{% endif %}
