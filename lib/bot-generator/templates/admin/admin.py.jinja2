{#
  Шаблон обработчика административных действий

  @fileoverview Генерирует Python код для административных действий в Telegram (pin, unpin, delete, ban, unban, mute, unmute, kick, promote, demote)
  @param {string} nodeId - Уникальный идентификатор узла
  @param {string} actionType - Тип действия: 'pin_message', 'unpin_message', 'delete_message', 'ban_user', 'unban_user', 'mute_user', 'unmute_user', 'kick_user', 'promote_user', 'demote_user'
  @param {array} synonyms - Синонимы команды
  @param {string} targetMessageId - ID целевого сообщения
  @param {string} messageIdSource - Источник ID сообщения: 'manual', 'variable', 'last_message'
  @param {string} targetUserId - ID целевого пользователя
  @param {string} userIdSource - Источник ID пользователя: 'manual', 'variable', 'last_message'
  @param {number} untilDate - Дата окончания ограничения (timestamp)
  @param {string} reason - Причина действия
  @param {number} muteDuration - Длительность мута в секундах
  @param {string} adminTargetUserId - ID пользователя для продвижения/понижения
  @param {boolean} can_manage_chat - Право управления чатом
  @param {boolean} can_delete_messages - Право удаления сообщений
  @param {boolean} can_manage_video_chats - Право управления видеочатами
  @param {boolean} can_restrict_members - Право ограничения участников
  @param {boolean} can_promote_members - Право продвижения участников
  @param {boolean} can_change_info - Право изменения информации
  @param {boolean} can_invite_users - Право приглашения пользователей
  @param {boolean} can_pin_messages - Право закрепления сообщений
  @param {boolean} can_manage_topics - Право управления темами
  @param {boolean} is_anonymous - Анонимный администратор
#}

{# Генерация callback обработчика #}
@dp.callback_query(lambda c: c.data.startswith("admin_{{ actionType|safe_name }}_{{ nodeId|safe_name }}_"))
async def admin_callback_{{ nodeId|safe_name }}(callback_query: types.CallbackQuery):
    """Callback обработчик административного действия {{ actionType }} для узла {{ nodeId }}"""
    user_id = callback_query.from_user.id
    chat_id = callback_query.message.chat.id
    
    # Проверяем, что это группа
    if callback_query.message.chat.type not in ['group', 'supergroup']:
        await callback_query.message.answer("❌ Команда работает только в группах")
        return
    
    # Проверяем права администратора
    chat_member = await bot.get_chat_member(chat_id=chat_id, user_id=user_id)
    if chat_member.status not in ['creator', 'administrator']:
        await callback_query.message.answer("❌ Требуются права администратора")
        return
    
    {% if actionType == 'pin_message' or actionType == 'unpin_message' or actionType == 'delete_message' %}
    # Определяем целевое сообщение из callback_data
    target_message_id = int(callback_query.data.split('_')[-1]) if len(callback_query.data.split('_')) > 3 else None
    
    if not target_message_id:
        await callback_query.message.answer("❌ Не удалось определить ID сообщения")
        return
    
    {% if actionType == 'pin_message' %}
    try:
        await bot.pin_chat_message(
            chat_id=chat_id,
            message_id=target_message_id
        )
        await callback_query.message.answer("✅ Сообщение закреплено")
        logging.info(f"Сообщение {target_message_id} закреплено пользователем {user_id} в группе {chat_id}")
    except TelegramBadRequest as e:
        if "message to pin not found" in str(e):
            await callback_query.message.answer("❌ Сообщение не найдено")
        elif "not enough rights" in str(e):
            await callback_query.message.answer("❌ Недостаточно прав")
        else:
            await callback_query.message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка закрепления сообщения: {e}")
    except Exception as e:
        await callback_query.message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при закреплении: {e}")
    
    {% elif actionType == 'unpin_message' %}
    try:
        await bot.unpin_chat_message(
            chat_id=chat_id,
            message_id=target_message_id
        )
        await callback_query.message.answer("✅ Сообщение откреплено")
        logging.info(f"Сообщение {target_message_id} откреплено пользователем {user_id} в группе {chat_id}")
    except TelegramBadRequest as e:
        if "message to unpin not found" in str(e):
            await callback_query.message.answer("❌ Сообщение не найдено")
        elif "not enough rights" in str(e):
            await callback_query.message.answer("❌ Недостаточно прав")
        else:
            await callback_query.message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка открепления сообщения: {e}")
    except Exception as e:
        await callback_query.message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при откреплении: {e}")
    
    {% elif actionType == 'delete_message' %}
    try:
        await bot.delete_message(
            chat_id=chat_id,
            message_id=target_message_id
        )
        await callback_query.message.answer("✅ Сообщение удалено")
        logging.info(f"Сообщение {target_message_id} удалено пользователем {user_id} в группе {chat_id}")
    except TelegramBadRequest as e:
        if "message to delete not found" in str(e):
            await callback_query.message.answer("❌ Сообщение не найдено")
        elif "not enough rights" in str(e):
            await callback_query.message.answer("❌ Недостаточно прав")
        else:
            await callback_query.message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка удаления сообщения: {e}")
    except Exception as e:
        await callback_query.message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при удалении: {e}")
    {% endif %}
    
    try:
        await callback_query.answer()
    except:
        pass
    
    return
    
    {% elif actionType == 'ban_user' or actionType == 'unban_user' or actionType == 'mute_user' or actionType == 'unmute_user' or actionType == 'kick_user' %}
    # Определяем целевого пользователя из callback_data
    target_user_id = int(callback_query.data.split('_')[-1]) if len(callback_query.data.split('_')) > 3 else None
    
    if not target_user_id:
        await callback_query.message.answer("❌ Не удалось определить пользователя")
        return
    
    {% if actionType == 'ban_user' %}
    try:
        await bot.ban_chat_member(
            chat_id=chat_id,
            user_id=target_user_id
        )
        await callback_query.message.answer("✅ Пользователь заблокирован")
        logging.info(f"Пользователь {target_user_id} заблокирован пользователем {user_id} в группе {chat_id}")
    except TelegramBadRequest as e:
        if "not enough rights" in str(e):
            await callback_query.message.answer("❌ Недостаточно прав")
        else:
            await callback_query.message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка блокировки пользователя: {e}")
    except Exception as e:
        await callback_query.message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при блокировке: {e}")
    
    {% elif actionType == 'unban_user' %}
    try:
        await bot.unban_chat_member(
            chat_id=chat_id,
            user_id=target_user_id
        )
        await callback_query.message.answer("✅ Пользователь разблокирован")
        logging.info(f"Пользователь {target_user_id} разблокирован пользователем {user_id} в группе {chat_id}")
    except TelegramBadRequest as e:
        if "not enough rights" in str(e):
            await callback_query.message.answer("❌ Недостаточно прав")
        else:
            await callback_query.message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка разблокировки пользователя: {e}")
    except Exception as e:
        await callback_query.message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при разблокировке: {e}")
    
    {% elif actionType == 'kick_user' %}
    try:
        await bot.ban_chat_member(
            chat_id=chat_id,
            user_id=target_user_id
        )
        await bot.unban_chat_member(
            chat_id=chat_id,
            user_id=target_user_id
        )
        await callback_query.message.answer("✅ Пользователь исключён из чата")
        logging.info(f"Пользователь {target_user_id} исключён пользователем {user_id} из группы {chat_id}")
    except TelegramBadRequest as e:
        if "not enough rights" in str(e):
            await callback_query.message.answer("❌ Недостаточно прав")
        else:
            await callback_query.message.answer(f"❌ Ошибка: {e}")
        logging.error(f"Ошибка исключения пользователя: {e}")
    except Exception as e:
        await callback_query.message.answer("❌ Произошла неожиданная ошибка")
        logging.error(f"Неожиданная ошибка при исключении: {e}")
    {% endif %}
    
    try:
        await callback_query.answer()
    except:
        pass
    
    return
