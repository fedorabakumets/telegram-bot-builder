{#
  Шаблон обработчика административных действий

  @fileoverview Генерирует Python код для административных действий в Telegram (pin, unpin, delete, ban, unban, mute, unmute, kick, promote, demote)
  @param {string} nodeId - Уникальный идентификатор узла
  @param {string} adminActionType - Тип действия: 'pin_message', 'unpin_message', 'delete_message', 'ban_user', 'unban_user', 'mute_user', 'unmute_user', 'kick_user', 'promote_user', 'demote_user'
  @param {string} targetMessageId - ID целевого сообщения
  @param {string} messageIdSource - Источник ID сообщения: 'manual', 'variable', 'last_message'
  @param {string} targetUserId - ID целевого пользователя
  @param {string} userIdSource - Источник ID пользователя: 'manual', 'variable', 'last_message'
  @param {number} untilDate - Дата окончания ограничения (timestamp)
  @param {string} reason - Причина действия
  @param {number} muteDuration - Длительность мута в секундах
  @param {string} adminTargetUserId - ID пользователя для продвижения/понижения
  @param {boolean} can_manage_chat - Право управления чатом
  @param {boolean} can_delete_messages - Право удаления сообщений
  @param {boolean} can_manage_video_chats - Право управления видеочатами
  @param {boolean} can_restrict_members - Право ограничения участников
  @param {boolean} can_promote_members - Право продвижения участников
  @param {boolean} can_change_info - Право изменения информации
  @param {boolean} can_invite_users - Право приглашения пользователей
  @param {boolean} can_pin_messages - Право закрепления сообщений
  @param {boolean} can_manage_topics - Право управления темами
  @param {boolean} is_anonymous - Анонимный администратор
#}

@dp.message(Command("admin_{{ adminActionType|safe_name }}_{{ nodeId|safe_name }}"))
async def handle_admin_{{ adminActionType|safe_name }}_{{ nodeId|safe_name }}(message: types.Message):
    """Обработчик административного действия {{ adminActionType }} для узла {{ nodeId }}"""
    user_id = message.from_user.id

    {# Проверка прав администратора #}
    chat_member = await bot.get_chat_member(chat_id=message.chat.id, user_id=user_id)
    if chat_member.status not in ['creator', 'administrator']:
        await message.answer("❌ Требуется права администратора")
        return

    {% if adminActionType == 'pin_message' or adminActionType == 'unpin_message' or adminActionType == 'delete_message' %}
    {# Действия с сообщениями #}
    {% if messageIdSource == 'manual' %}
    target_message_id = {{ targetMessageId|default(0) }}
    {% elif messageIdSource == 'variable' %}
    target_message_id = user_data.get(user_id, {}).get("target_message_id", 0)
    {% else %}
    {# last_message #}
    target_message_id = message.message_id
    {% endif %}

    {% if adminActionType == 'pin_message' %}
    try:
        await bot.pin_chat_message(
            chat_id=message.chat.id,
            message_id=target_message_id
            {% if disableNotification %}, disable_notification=True{% endif %}
        )
        await message.answer(f"✅ Сообщение закреплено (ID: {target_message_id})")
    except Exception as e:
        logging.error(f"Ошибка закрепления сообщения: {e}")
        await message.answer("❌ Ошибка при закреплении сообщения")

    {% elif adminActionType == 'unpin_message' %}
    try:
        await bot.unpin_chat_message(
            chat_id=message.chat.id,
            message_id=target_message_id
        )
        await message.answer(f"✅ Сообщение откреплено (ID: {target_message_id})")
    except Exception as e:
        logging.error(f"Ошибка открепления сообщения: {e}")
        await message.answer("❌ Ошибка при откреплении сообщения")

    {% elif adminActionType == 'delete_message' %}
    try:
        await bot.delete_message(
            chat_id=message.chat.id,
            message_id=target_message_id
        )
        await message.answer(f"✅ Сообщение удалено (ID: {target_message_id})")
    except Exception as e:
        logging.error(f"Ошибка удаления сообщения: {e}")
        await message.answer("❌ Ошибка при удалении сообщения")
    {% endif %}

    {% elif adminActionType == 'ban_user' or adminActionType == 'unban_user' or adminActionType == 'mute_user' or adminActionType == 'unmute_user' or adminActionType == 'kick_user' %}
    {# Действия с пользователями #}
    {% if userIdSource == 'manual' %}
    target_user_id = {{ targetUserId|default(0) }}
    {% elif userIdSource == 'variable' %}
    target_user_id = user_data.get(user_id, {}).get("target_user_id", 0)
    {% else %}
    {# last_message - из reply #}
    target_user_id = message.reply_to_message.from_user.id if message.reply_to_message else 0
    {% endif %}

    if target_user_id == 0:
        await message.answer("❌ Не указан целевой пользователь")
        return

    {% if adminActionType == 'ban_user' %}
    try:
        {% if untilDate %}
        until_date = {{ untilDate }}
        await bot.ban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id,
            until_date=until_date
        )
        await message.answer(f"✅ Пользователь заблокирован до {until_date}")
        {% else %}
        await bot.ban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await message.answer(f"✅ Пользователь заблокирован навсегда")
        {% endif %}
    except Exception as e:
        logging.error(f"Ошибка блокировки пользователя: {e}")
        await message.answer("❌ Ошибка при блокировке пользователя")

    {% elif adminActionType == 'unban_user' %}
    try:
        await bot.unban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await message.answer(f"✅ Пользователь разблокирован")
    except Exception as e:
        logging.error(f"Ошибка разблокировки пользователя: {e}")
        await message.answer("❌ Ошибка при разблокировке пользователя")

    {% elif adminActionType == 'mute_user' %}
    try:
        {% if muteDuration %}
        until_date = int(datetime.now().timestamp()) + {{ muteDuration }}
        {% else %}
        until_date = int(datetime.now().timestamp()) + 60
        {% endif %}
        await bot.restrict_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id,
            until_date=until_date,
            permissions=types.ChatPermissions(can_send_messages=False)
        )
        await message.answer(f"✅ Пользователь заглушен")
    except Exception as e:
        logging.error(f"Ошибка заглушения пользователя: {e}")
        await message.answer("❌ Ошибка при заглушении пользователя")

    {% elif adminActionType == 'unmute_user' %}
    try:
        await bot.restrict_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id,
            permissions=types.ChatPermissions(
                can_send_messages=True,
                can_send_media_messages=True,
                can_send_polls=True,
                can_send_other_messages=True,
                can_add_web_page_previews=True
            )
        )
        await message.answer(f"✅ Пользователь размглушен")
    except Exception as e:
        logging.error(f"Ошибка размглушения пользователя: {e}")
        await message.answer("❌ Ошибка при размглушении пользователя")

    {% elif adminActionType == 'kick_user' %}
    try:
        await bot.ban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await bot.unban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await message.answer(f"✅ Пользователь исключён из чата")
    except Exception as e:
        logging.error(f"Ошибка исключения пользователя: {e}")
        await message.answer("❌ Ошибка при исключении пользователя")
    {% endif %}

    {% elif adminActionType == 'promote_user' or adminActionType == 'demote_user' %}
    {# Продвижение/понижение администратора #}
    {% if userIdSource == 'manual' %}
    admin_target_user_id = {{ adminTargetUserId|default(0) }}
    {% elif userIdSource == 'variable' %}
    admin_target_user_id = user_data.get(user_id, {}).get("admin_target_user_id", 0)
    {% else %}
    admin_target_user_id = message.reply_to_message.from_user.id if message.reply_to_message else 0
    {% endif %}

    if admin_target_user_id == 0:
        await message.answer("❌ Не указан целевой пользователь")
        return

    {% if adminActionType == 'promote_user' %}
    try:
        await bot.promote_chat_member(
            chat_id=message.chat.id,
            user_id=admin_target_user_id,
            can_manage_chat={{ can_manage_chat|default(false)|lower }},
            can_delete_messages={{ can_delete_messages|default(false)|lower }},
            can_manage_video_chats={{ can_manage_video_chats|default(false)|lower }},
            can_restrict_members={{ can_restrict_members|default(false)|lower }},
            can_promote_members={{ can_promote_members|default(false)|lower }},
            can_change_info={{ can_change_info|default(false)|lower }},
            can_invite_users={{ can_invite_users|default(false)|lower }},
            can_pin_messages={{ can_pin_messages|default(false)|lower }},
            can_manage_topics={{ can_manage_topics|default(false)|lower }},
            is_anonymous={{ is_anonymous|default(false)|lower }}
        )
        await message.answer(f"✅ Пользователь повышен в правах")
    except Exception as e:
        logging.error(f"Ошибка продвижения пользователя: {e}")
        await message.answer("❌ Ошибка при продвижении пользователя")

    {% elif adminActionType == 'demote_user' %}
    try:
        await bot.promote_chat_member(
            chat_id=message.chat.id,
            user_id=admin_target_user_id,
            can_manage_chat=False,
            can_delete_messages=False,
            can_manage_video_chats=False,
            can_restrict_members=False,
            can_promote_members=False,
            can_change_info=False,
            can_invite_users=False,
            can_pin_messages=False,
            can_manage_topics=False,
            is_anonymous=False
        )
        await message.answer(f"✅ Пользователь понижен в правах")
    except Exception as e:
        logging.error(f"Ошибка понижения пользователя: {e}")
        await message.answer("❌ Ошибка при понижении пользователя")
    {% endif %}
    {% endif %}
