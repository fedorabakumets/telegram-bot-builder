{#
  Макросы для генерации обработчиков узлов
  
  @fileoverview Предоставляет функции для рендеринга обработчиков разных типов узлов
  @param {Object} node - Объект узла
  @param {boolean} enableComments - Включить ли комментарии
#}

{# Рендеринг обработчика узла #}
{% macro render_node_handler(node, enableComments) %}

{% if enableComments %}
# @@NODE_START:{{ node.id }}@@
{% endif %}

{% if node.type == 'start' %}
{{ render_start_handler(node, enableComments) }}

{% elif node.type == 'command' %}
{{ render_command_handler(node, enableComments) }}

{% elif node.type == 'callback' %}
{{ render_callback_handler(node, enableComments) }}

{# === Новые типы узлов === #}

{% elif node.type == 'broadcast' %}
{{ render_broadcast_handler(node, enableComments) }}

{% elif node.type == 'sticker' %}
{{ render_sticker_handler(node, enableComments) }}

{% elif node.type == 'voice' %}
{{ render_voice_handler(node, enableComments) }}

{% elif node.type in ['pin_message', 'unpin_message', 'delete_message', 'ban_user', 'unban_user', 'mute_user', 'unmute_user', 'kick_user', 'promote_user', 'demote_user', 'admin_rights'] %}
{{ render_admin_handler(node, enableComments) }}

{% endif %}

{% if enableComments %}
# @@NODE_END:{{ node.id }}@@
{% endif %}

{% endmacro %}


{# Обработчик команды /start #}
{% macro render_start_handler(node, enableComments) %}
@dp.message(CommandStart())
async def start_handler(message: types.Message):
    {# Регистрация пользователя #}
    user_id = message.from_user.id
    username = message.from_user.username
    first_name = message.from_user.first_name
    last_name = message.from_user.last_name
    
    await save_user_to_db(user_id, username, first_name, last_name)
    
    {# Инициализация переменных #}
    user_name = await init_user_variables(user_id, message.from_user)
    
    {% if node.data.messageText %}
    text = "{{ node.data.messageText|e }}"
    
    {# Замена переменных #}
    all_user_vars = await init_all_user_vars(user_id)
    variable_filters = user_data.get(user_id, {}).get("_variable_filters", {})
    text = replace_variables_in_text(text, all_user_vars, variable_filters)
    {% endif %}
    
    {% if node.data.buttons %}
    {{ render_keyboard(node.data.buttons, node.data.keyboardType) }}
    await message.answer(text, reply_markup=keyboard)
    {% else %}
    await message.answer(text)
    {% endif %}
{% endmacro %}


{# Обработчик команды #}
{% macro render_command_handler(node, enableComments) %}
@dp.message(Command("{{ node.data.command|e }}"))
async def handle_{{ node.data.command|replace('/', '') }}_command(message: types.Message):
    user_id = message.from_user.id
    
    {% if node.data.messageText %}
    text = "{{ node.data.messageText|e }}"
    all_user_vars = await init_all_user_vars(user_id)
    variable_filters = user_data.get(user_id, {}).get("_variable_filters", {})
    text = replace_variables_in_text(text, all_user_vars, variable_filters)
    {% endif %}
    
    {% if node.data.buttons %}
    {{ render_keyboard(node.data.buttons, node.data.keyboardType) }}
    await message.answer(text, reply_markup=keyboard)
    {% else %}
    await message.answer(text)
    {% endif %}
{% endmacro %}


{# Обработчик callback query #}
{% macro render_callback_handler(node, enableComments) %}
@dp.callback_query(lambda c: c.data == "{{ node.id|e }}" or c.data.startswith("{{ node.id|e }}_btn_"))
async def handle_callback_{{ node.id|safe_name }}(callback_query: types.CallbackQuery):
    user_id = callback_query.from_user.id
    
    {# Ответ на callback #}
    try:
        await callback_query.answer()
    except Exception:
        pass
    
    {% if node.data.messageText %}
    text = "{{ node.data.messageText|e }}"
    
    {# Замена переменных #}
    all_user_vars = await init_all_user_vars(user_id)
    variable_filters = user_data.get(user_id, {}).get("_variable_filters", {})
    text = replace_variables_in_text(text, all_user_vars, variable_filters)
    {% endif %}
    
    {% if node.data.buttons %}
    {{ render_keyboard(node.data.buttons, node.data.keyboardType) }}
    await safe_edit_or_send(callback_query, text, node_id="{{ node.id|e }}", reply_markup=keyboard)
    {% else %}
    await safe_edit_or_send(callback_query, text, node_id="{{ node.id|e }}")
    {% endif %}
{% endmacro %}


{# Рендеринг клавиатуры #}
{% macro render_keyboard(buttons, keyboardType) %}
{% if keyboardType == 'inline' %}
keyboard = InlineKeyboardMarkup(inline_keyboard=[
    {% for row in buttons %}
    [
        {% for button in row %}
        InlineKeyboardButton(text="{{ button.text|e }}", {% if button.callback_data %}callback_data="{{ button.callback_data|e }}"{% endif %}{% if button.url %}url="{{ button.url|e }}"{% endif %}),
        {% endfor %}
    ],
    {% endfor %}
])
{% else %}
builder = ReplyKeyboardBuilder()
{% for row in buttons %}
{% for button in row %}
builder.add(KeyboardButton(text="{{ button.text|e }}"))
{% endfor %}
{% endfor %}
keyboard = builder.as_markup(resize_keyboard=True)
{% endif %}
{% endmacro %}


{# === Макросы для новых типов узлов === #}

{# Обработчик рассылки #}
{% macro render_broadcast_handler(node, enableComments) %}
@dp.message(Command("broadcast_{{ node.id|safe_name }}"))
async def handle_broadcast_{{ node.id|safe_name }}(message: types.Message):
    """Обработчик рассылки для узла {{ node.id }}"""
    user_id = message.from_user.id

    {% if node.data.enableBroadcast %}
    {# Получение списка пользователей #}
    target_users = []

    {% if node.data.idSourceType == 'user_ids' or node.data.idSourceType == 'both' %}
    if db_pool:
        async with db_pool.acquire() as conn:
            rows = await conn.fetch("SELECT user_id FROM users WHERE is_bot = FALSE")
            target_users.extend([row['user_id'] for row in rows])
    {% endif %}

    {% if node.data.idSourceType == 'bot_users' or node.data.idSourceType == 'both' %}
    if db_pool:
        async with db_pool.acquire() as conn:
            rows = await conn.fetch("SELECT user_id FROM users WHERE is_bot = TRUE")
            target_users.extend([row['user_id'] for row in rows])
    {% endif %}

    broadcast_text = "{{ node.data.messageText|e }}" if node.data.get("messageText") else "Рассылка сообщений"
    all_user_vars = await init_all_user_vars(user_id)
    variable_filters = user_data.get(user_id, {}).get("_variable_filters", {})
    broadcast_text = replace_variables_in_text(broadcast_text, all_user_vars, variable_filters)

    success_count = 0
    error_count = 0

    {% if node.data.broadcastApiType == 'bot' %}
    for target_user_id in target_users:
        try:
            await bot.send_message(target_user_id, broadcast_text)
            success_count += 1
        except Exception as e:
            logging.error(f"Ошибка отправки пользователю {target_user_id}: {e}")
            error_count += 1
        await asyncio.sleep(0.1)
    {% else %}
    logging.warning("Рассылка через клиента требует дополнительной настройки")
    {% endif %}

    result_text = f"✅ Рассылка завершена\\nУспешно: {success_count}\\nОшибок: {error_count}"
    await message.answer(result_text)
    {% else %}
    await message.answer("Рассылка отключена")
    {% endif %}
{% endmacro %}


{# Обработчик стикера #}
{% macro render_sticker_handler(node, enableComments) %}
@dp.message(Command("sticker_{{ node.id|safe_name }}"))
async def handle_sticker_{{ node.id|safe_name }}(message: types.Message):
    """Обработчик отправки стикера для узла {{ node.id }}"""
    user_id = message.from_user.id

    {% if node.data.stickerFileId %}
    sticker_file_id = "{{ node.data.stickerFileId|e }}"
    {% elif node.data.stickerUrl %}
    sticker_url = "{{ node.data.stickerUrl|e }}"
    {% endif %}

    {% if node.data.mediaCaption %}
    caption = "{{ node.data.mediaCaption|e }}"
    all_user_vars = await init_all_user_vars(user_id)
    variable_filters = user_data.get(user_id, {}).get("_variable_filters", {})
    caption = replace_variables_in_text(caption, all_user_vars, variable_filters)
    {% endif %}

    try:
        {% if node.data.stickerFileId %}
        await message.answer_sticker(
            sticker=sticker_file_id,
            {% if node.data.mediaCaption %}caption=caption{% endif %}
            {% if node.data.disableNotification %}disable_notification=True{% endif %}
        )
        {% elif node.data.stickerUrl %}
        async with aiohttp.ClientSession() as session:
            async with session.get(sticker_url) as resp:
                sticker_data = await resp.read()
                await message.answer_sticker(
                    sticker=sticker_data,
                    {% if node.data.mediaCaption %}caption=caption{% endif %}
                    {% if node.data.disableNotification %}disable_notification=True{% endif %}
                )
        {% elif node.data.stickerSetName %}
        await message.answer_sticker(sticker="{{ node.data.stickerSetName|e }}")
        {% else %}
        await message.answer("Стикер не настроен")
        {% endif %}
    except Exception as e:
        logging.error(f"Ошибка отправки стикера: {e}")
        await message.answer("Произошла ошибка при отправке стикера")
{% endmacro %}


{# Обработчик голосового сообщения #}
{% macro render_voice_handler(node, enableComments) %}
@dp.message(Command("voice_{{ node.id|safe_name }}"))
async def handle_voice_{{ node.id|safe_name }}(message: types.Message):
    """Обработчик отправки голосового сообщения для узла {{ node.id }}"""
    user_id = message.from_user.id

    {% if node.data.voiceUrl %}
    voice_url = "{{ node.data.voiceUrl|e }}"
    {% else %}
    voice_url = None
    {% endif %}

    {% if node.data.mediaCaption %}
    caption = "{{ node.data.mediaCaption|e }}"
    all_user_vars = await init_all_user_vars(user_id)
    variable_filters = user_data.get(user_id, {}).get("_variable_filters", {})
    caption = replace_variables_in_text(caption, all_user_vars, variable_filters)
    {% endif %}

    {% if node.data.mediaDuration %}
    duration = {{ node.data.mediaDuration }}
    {% endif %}

    if not voice_url:
        await message.answer("Голосовое сообщение не настроено")
        return

    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(voice_url) as resp:
                voice_data = await resp.read()

                {% if node.data.mediaCaption and node.data.mediaDuration %}
                await message.answer_voice(
                    voice=voice_data,
                    caption=caption,
                    duration=duration
                    {% if node.data.disableNotification %}, disable_notification=True{% endif %}
                )
                {% elif node.data.mediaCaption %}
                await message.answer_voice(
                    voice=voice_data,
                    caption=caption
                    {% if node.data.disableNotification %}, disable_notification=True{% endif %}
                )
                {% elif node.data.mediaDuration %}
                await message.answer_voice(
                    voice=voice_data,
                    duration=duration
                    {% if node.data.disableNotification %}, disable_notification=True{% endif %}
                )
                {% else %}
                await message.answer_voice(
                    voice=voice_data
                    {% if node.data.disableNotification %}, disable_notification=True{% endif %}
                )
                {% endif %}
    except Exception as e:
        logging.error(f"Ошибка отправки голосового сообщения: {e}")
        await message.answer("Произошла ошибка при отправке голосового сообщения")
{% endmacro %}


{# Обработчик административного действия #}
{% macro render_admin_handler(node, enableComments) %}
@dp.message(Command("admin_{{ node.type|safe_name }}_{{ node.id|safe_name }}"))
async def handle_admin_{{ node.type|safe_name }}_{{ node.id|safe_name }}(message: types.Message):
    """Обработчик административного действия {{ node.type }} для узла {{ node.id }}"""
    user_id = message.from_user.id

    {# Проверка прав администратора #}
    chat_member = await bot.get_chat_member(chat_id=message.chat.id, user_id=user_id)
    if chat_member.status not in ['creator', 'administrator']:
        await message.answer("❌ Требуется права администратора")
        return

    {% if node.type in ['pin_message', 'unpin_message', 'delete_message'] %}
    {# Действия с сообщениями #}
    {% if node.data.messageIdSource == 'manual' %}
    target_message_id = {{ node.data.targetMessageId|default(0) }}
    {% elif node.data.messageIdSource == 'variable' %}
    target_message_id = user_data.get(user_id, {}).get("target_message_id", 0)
    {% else %}
    target_message_id = message.message_id
    {% endif %}

    {% if node.type == 'pin_message' %}
    try:
        await bot.pin_chat_message(
            chat_id=message.chat.id,
            message_id=target_message_id
            {% if node.data.disableNotification %}, disable_notification=True{% endif %}
        )
        await message.answer(f"✅ Сообщение закреплено (ID: {target_message_id})")
    except Exception as e:
        logging.error(f"Ошибка закрепления сообщения: {e}")
        await message.answer("❌ Ошибка при закреплении сообщения")

    {% elif node.type == 'unpin_message' %}
    try:
        await bot.unpin_chat_message(
            chat_id=message.chat.id,
            message_id=target_message_id
        )
        await message.answer(f"✅ Сообщение откреплено (ID: {target_message_id})")
    except Exception as e:
        logging.error(f"Ошибка открепления сообщения: {e}")
        await message.answer("❌ Ошибка при откреплении сообщения")

    {% elif node.type == 'delete_message' %}
    try:
        await bot.delete_message(
            chat_id=message.chat.id,
            message_id=target_message_id
        )
        await message.answer(f"✅ Сообщение удалено (ID: {target_message_id})")
    except Exception as e:
        logging.error(f"Ошибка удаления сообщения: {e}")
        await message.answer("❌ Ошибка при удалении сообщения")
    {% endif %}

    {% elif node.type in ['ban_user', 'unban_user', 'mute_user', 'unmute_user', 'kick_user'] %}
    {# Действия с пользователями #}
    {% if node.data.userIdSource == 'manual' %}
    target_user_id = {{ node.data.targetUserId|default(0) }}
    {% elif node.data.userIdSource == 'variable' %}
    target_user_id = user_data.get(user_id, {}).get("target_user_id", 0)
    {% else %}
    target_user_id = message.reply_to_message.from_user.id if message.reply_to_message else 0
    {% endif %}

    if target_user_id == 0:
        await message.answer("❌ Не указан целевой пользователь")
        return

    {% if node.type == 'ban_user' %}
    try:
        {% if node.data.untilDate %}
        until_date = {{ node.data.untilDate }}
        await bot.ban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id,
            until_date=until_date
        )
        await message.answer(f"✅ Пользователь заблокирован до {until_date}")
        {% else %}
        await bot.ban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await message.answer(f"✅ Пользователь заблокирован навсегда")
        {% endif %}
    except Exception as e:
        logging.error(f"Ошибка блокировки пользователя: {e}")
        await message.answer("❌ Ошибка при блокировке пользователя")

    {% elif node.type == 'unban_user' %}
    try:
        await bot.unban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await message.answer(f"✅ Пользователь разблокирован")
    except Exception as e:
        logging.error(f"Ошибка разблокировки пользователя: {e}")
        await message.answer("❌ Ошибка при разблокировке пользователя")

    {% elif node.type == 'mute_user' %}
    try:
        {% if node.data.muteDuration %}
        until_date = int(datetime.now().timestamp()) + {{ node.data.muteDuration }}
        {% else %}
        until_date = int(datetime.now().timestamp()) + 60
        {% endif %}
        await bot.restrict_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id,
            until_date=until_date,
            permissions=types.ChatPermissions(can_send_messages=False)
        )
        await message.answer(f"✅ Пользователь заглушен")
    except Exception as e:
        logging.error(f"Ошибка заглушения пользователя: {e}")
        await message.answer("❌ Ошибка при заглушении пользователя")

    {% elif node.type == 'unmute_user' %}
    try:
        await bot.restrict_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id,
            permissions=types.ChatPermissions(
                can_send_messages=True,
                can_send_media_messages=True,
                can_send_polls=True,
                can_send_other_messages=True,
                can_add_web_page_previews=True
            )
        )
        await message.answer(f"✅ Пользователь разглушен")
    except Exception as e:
        logging.error(f"Ошибка разглушения пользователя: {e}")
        await message.answer("❌ Ошибка при разглушении пользователя")

    {% elif node.type == 'kick_user' %}
    try:
        await bot.ban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await bot.unban_chat_member(
            chat_id=message.chat.id,
            user_id=target_user_id
        )
        await message.answer(f"✅ Пользователь исключён из чата")
    except Exception as e:
        logging.error(f"Ошибка исключения пользователя: {e}")
        await message.answer("❌ Ошибка при исключении пользователя")
    {% endif %}

    {% elif node.type in ['promote_user', 'demote_user', 'admin_rights'] %}
    {# Продвижение/понижение администратора #}
    {% if node.data.userIdSource == 'manual' %}
    admin_target_user_id = {{ node.data.adminTargetUserId|default(0) }}
    {% elif node.data.userIdSource == 'variable' %}
    admin_target_user_id = user_data.get(user_id, {}).get("admin_target_user_id", 0)
    {% else %}
    admin_target_user_id = message.reply_to_message.from_user.id if message.reply_to_message else 0
    {% endif %}

    if admin_target_user_id == 0:
        await message.answer("❌ Не указан целевой пользователь")
        return

    {% if node.type == 'promote_user' or node.type == 'admin_rights' %}
    try:
        await bot.promote_chat_member(
            chat_id=message.chat.id,
            user_id=admin_target_user_id,
            can_manage_chat={{ node.data.can_manage_chat|default(false)|lower }},
            can_delete_messages={{ node.data.can_delete_messages|default(false)|lower }},
            can_manage_video_chats={{ node.data.can_manage_video_chats|default(false)|lower }},
            can_restrict_members={{ node.data.can_restrict_members|default(false)|lower }},
            can_promote_members={{ node.data.can_promote_members|default(false)|lower }},
            can_change_info={{ node.data.can_change_info|default(false)|lower }},
            can_invite_users={{ node.data.can_invite_users|default(false)|lower }},
            can_pin_messages={{ node.data.can_pin_messages|default(false)|lower }},
            can_manage_topics={{ node.data.can_manage_topics|default(false)|lower }},
            is_anonymous={{ node.data.is_anonymous|default(false)|lower }}
        )
        await message.answer(f"✅ Пользователь повышен в правах")
    except Exception as e:
        logging.error(f"Ошибка продвижения пользователя: {e}")
        await message.answer("❌ Ошибка при продвижении пользователя")

    {% elif node.type == 'demote_user' %}
    try:
        await bot.promote_chat_member(
            chat_id=message.chat.id,
            user_id=admin_target_user_id,
            can_manage_chat=False,
            can_delete_messages=False,
            can_manage_video_chats=False,
            can_restrict_members=False,
            can_promote_members=False,
            can_change_info=False,
            can_invite_users=False,
            can_pin_messages=False,
            can_manage_topics=False,
            is_anonymous=False
        )
        await message.answer(f"✅ Пользователь понижен в правах")
    except Exception as e:
        logging.error(f"Ошибка понижения пользователя: {e}")
        await message.answer("❌ Ошибка при понижении пользователя")
    {% endif %}
    {% endif %}
{% endmacro %}
