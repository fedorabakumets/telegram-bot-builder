# ВАЖНО: этот файл — исторический артефакт.
# Проект является SaaS-сервисом с единым сервером и единым .env.
# Этот шаблон не используется пользователями — они просто заходят на сайт.
# Актуальные переменные окружения настраиваются только администратором сервера.

# ─── База данных PostgreSQL ───────────────────────────────────────────────────

# Полный URL подключения
# Для локальной разработки:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_bot_builder
# Для Railway (подставляется автоматически):
# DATABASE_URL="${{Postgres.DATABASE_URL}}"

# Отдельные параметры подключения (используются docker-compose и пулом соединений)
PGHOST=localhost
PGPORT=5432
PGDATABASE=telegram_bot_builder
PGUSER=postgres
PGPASSWORD=postgres

# Отключить SSL для локального PostgreSQL (без SSL-сертификата)
# В продакшене с внешним PostgreSQL — уберите эту строку или установите значение require
PGSSLMODE=disable

# Учётные данные PostgreSQL контейнера (только для docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=telegram_bot_builder

# ─── Сервер приложения ────────────────────────────────────────────────────────

# Порт сервера
PORT=5000

# Хост привязки сервера
# Локально: 0.0.0.0 (все интерфейсы)
# Продакшен за reverse proxy: 127.0.0.1 (только локальный)
HOST=0.0.0.0

# Режим работы
NODE_ENV=development

# Пропустить авторизацию через Telegram (работает в любом NODE_ENV)
# При SKIP_AUTH=true Setup Wizard не требуется, вход по Telegram ID без верификации
# SKIP_AUTH=true

# Секрет для подписи сессий — ОБЯЗАТЕЛЕН в production (иначе приложение не стартует).
# Сгенерируйте надёжное случайное значение, например: openssl rand -hex 32
SESSION_SECRET=change-this-secret-in-production

# ─── Redis ────────────────────────────────────────────────────────────────────

# Redis URL для кэша переменных и FSM хранилища ботов
# Для локальной разработки:
REDIS_URL=redis://localhost:6379
# Для Railway (подставляется автоматически после добавления Redis сервиса):
# REDIS_URL="${{Redis.REDIS_URL}}"

# ─── Telegram ─────────────────────────────────────────────────────────────────

# Прокси для Telegram API (если заблокирован)
# LogVPN использует HTTP прокси на http://127.0.0.1:10809
# Оставьте пустым, если прокси не нужен
TELEGRAM_PROXY_URL=http://127.0.0.1:10809

# Telegram Login (настраивается через Setup Wizard при первом запуске)
# Эти переменные хранятся в PostgreSQL таблице app_settings.
# При первом запуске можно задать их здесь — они автоматически перенесутся в БД.
# После переноса эти строки можно удалить.
# TELEGRAM_CLIENT_ID=         # числовой Client ID из BotFather → Bot Settings → Web Login
# TELEGRAM_CLIENT_SECRET=     # Client Secret из BotFather → Bot Settings → Web Login
# VITE_TELEGRAM_CLIENT_ID=    # то же значение что и TELEGRAM_CLIENT_ID
# VITE_TELEGRAM_BOT_USERNAME= # имя бота без @ (например: blogspotbotbotbot)
# TELEGRAM_BOT_TOKEN=         # токен бота для Mini App авторизации (опционально)

# ─── Прочее ───────────────────────────────────────────────────────────────────

# Публичный URL API сервера (используется ботами для HTTP-запросов)
# Локально: http://localhost:5000
# На Railway: задаётся автоматически через RAILWAY_PUBLIC_DOMAIN, можно переопределить
API_BASE_URL=http://localhost:5000

# Персональный токен агента (PAT) для MCP-процесса — генерируется во вкладке «Агент».
# MCP_AGENT_TOKEN=mcp_...

# ─── Worker Pool ──────────────────────────────────────────────────────────────

# Путь к Python интерпретатору (если не в PATH)
# По умолчанию: "python" на Windows, "python3" на Linux/Mac
# PYTHON_PATH=C:\Users\1\AppData\Local\Programs\Python\Python313\python.exe

# Режим запуска ботов: 1 проект = 1 Python процесс = N ботов внутри
# Снижает потребление RAM в ~10 раз при большом количестве ботов
# true/не задано — все боты проекта работают в одном asyncio event loop
# false — каждый бот запускается как отдельный процесс (legacy)
USE_WORKER_POOL=true

# ─── Хранилище файлов ─────────────────────────────────────────────────────────

# Лимит дискового хранилища в гигабайтах (учитываются только локальные файлы,
# storage_backend = 'local'; файлы в S3 в серверную квоту не входят).
# Допускается дробное число (например 1.5). Пусто / 0 / не задано → безлимитно.
# STORAGE_LIMIT_GB=

# Тип дефолтного хранилища для первичного сидирования реестра storage_configs:
#   local — локальная папка uploads/ (по умолчанию)
#   s3    — S3-совместимое хранилище (требует переменные S3_* ниже)
# ENV используется только для бутстрапа дефолтов при пустом реестре —
# дальнейшие хранилища добавляются через API/UI.
STORAGE_BACKEND=local

# ─── S3-хранилище (опционально, для STORAGE_BACKEND=s3) ────────────────────────
# Минимально необходим S3_BUCKET — без него S3-конфиг не создаётся.

# Endpoint S3. Для MinIO/совместимых — адрес сервера; пусто = AWS S3.
# Пример для локального MinIO:
# S3_ENDPOINT_URL=http://localhost:9000

# Регион (по умолчанию us-east-1, если не задан)
# S3_REGION=us-east-1

# Имя бакета
# S3_BUCKET=botcraft-files

# Ключ доступа S3 (плейсхолдер — подставьте реальный на сервере)
# S3_ACCESS_KEY_ID=your-access-key-id

# Секретный ключ S3 (плейсхолдер — подставьте реальный на сервере)
# S3_SECRET_ACCESS_KEY=your-secret-access-key

# Path-style адресация бакета (true — нужно для MinIO; false — для AWS S3)
# S3_FORCE_PATH_STYLE=true

# Базовый публичный URL для отдачи объектов (опционально).
# Если не задан — приватные объекты отдаются через серверный прокси/presigned URL.
# S3_PUBLIC_URL_BASE=

# Ключ шифрования секретов S3 (storage_configs.secretsEnc).
# Без него креды S3 не сохраняются в БД и задаются позже через UI.
# Сгенерируйте надёжное случайное значение, например: openssl rand -hex 32
# STORAGE_ENCRYPTION_KEY=change-this-storage-encryption-key
